{
  "NodeService": {
    "Backend": "Local",
    "Local": {
      "KubeContext": "docker-desktop",
      "DataVolumeHostPath": "/run/desktop/mnt/host/c/Users/YOU/data/ducklake",
      "DataVolumeMountPath": "/data/ducklake"
    },
    "Aks": {
      "SubscriptionId": "00000000-0000-0000-0000-000000000000",
      "ResourceGroupName": "myResourceGroup",
      "ClusterName": "myAKSCluster",
      "DefaultVmSize": "Standard_D4as_v5",
      "RuntimeImage": "myregistry.azurecr.io/duckhouse-runtime:latest",
      "NodeSubnetId": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/myResourceGroup/providers/Microsoft.Network/virtualNetworks/myVnet/subnets/mySubnet",
      "TenantId": "00000000-0000-0000-0000-000000000000",
      "ClientId": "00000000-0000-0000-0000-000000000000",
      "ClientSecret": "myClientSecret"
    }
  },
  "InactivityEviction": {
    "Enabled": true,
    "KernelIdleTimeout": "00:10:00",
    "NodeIdleTimeout": "00:20:00",
    "CheckInterval": "00:01:00"
  },
  "ServiceAuth": { "ExpectedApiKey": "dummy_value" },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
