<style>#@_id { height: @(ComputedHeight)px; }</style>
<StandaloneCodeEditor @ref="_editor"
                      Id="@_id"
                      CssClass="@(Class ?? "")"
                      ConstructionOptions="GetConstructionOptions"
                      OnDidChangeModelContent="OnContentChangedAsync"
                      OnDidChangeCursorSelection="OnCursorSelectionChangedAsync"
                      OnKeyDown="OnKeyDownAsync"
                      OnDidInit="OnEditorInitAsync" />

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string Language { get; set; } = "python";
    [Parameter] public int Height { get; set; } = 0; // 0 = auto-size from line count
    [Parameter] public EventCallback OnExecute { get; set; }
    [Parameter] public EventCallback OnEditorReady { get; set; }
    [Parameter] public EventCallback<string> OnSelectionChanged { get; set; }
    [Parameter] public string? Class { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = default!;
    private IJSInProcessRuntime? JSSync => JS as IJSInProcessRuntime;

    public StandaloneCodeEditor? Editor => _editor;

    private readonly string _id = $"code-cell-{Guid.NewGuid():N}";
    private StandaloneCodeEditor _editor = default!;
    private bool _editorInitialized;
    private bool _suppressChange;
    private bool _lastReadOnly;
    private string _lastLanguage = "";

    private int ComputedHeight => Height > 0
        ? Height
        : Math.Max(1, (Value ?? "").Split('\n').Length) * 20 + 20;

    private StandaloneEditorConstructionOptions GetConstructionOptions(StandaloneCodeEditor _)
    {
        string monacoTheme = "vs";
        try { monacoTheme = JSSync?.Invoke<string>("getDuckhouseMonacoTheme") ?? "vs"; }
        catch { /* JS not ready on first prerender — fall back to light theme */ }

        return new()
        {
            Language = Language,
            Value = Value,
            ReadOnly = ReadOnly,
            Theme = monacoTheme,
            AutomaticLayout = true,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
            WordWrap = "on",
            GlyphMargin = false,
            OverviewRulerLanes = 0,
            Padding = new EditorPaddingOptions { Top = 8, Bottom = 8 },
            RenderLineHighlight = "none",
        };
    }

    private async Task OnContentChangedAsync(ModelContentChangedEvent _)
    {
        if (ReadOnly || _suppressChange) return;
        var value = await _editor.GetValue();
        await ValueChanged.InvokeAsync(value);
    }

    private async Task OnKeyDownAsync(KeyboardEvent e)
    {
        if (!ReadOnly && e.CtrlKey && e.Code == "Enter")
            await OnExecute.InvokeAsync();
    }

    private async Task OnCursorSelectionChangedAsync(CursorSelectionChangedEvent e)
    {
        if (!OnSelectionChanged.HasDelegate) return;
        var sel = e.Selection;
        bool isEmpty = sel.StartLineNumber == sel.EndLineNumber && sel.StartColumn == sel.EndColumn;
        if (isEmpty)
        {
            await OnSelectionChanged.InvokeAsync("");
            return;
        }
        try
        {
            var text = await JS.InvokeAsync<string>("getMonacoEditorSelection", _id);
            await OnSelectionChanged.InvokeAsync(text ?? "");
        }
        catch { await OnSelectionChanged.InvokeAsync(""); }
    }

    private async Task OnEditorInitAsync()
    {
        _editorInitialized = true;
        // Record the state that was baked into construction options
        _lastLanguage = Language;
        _lastReadOnly = ReadOnly;
        // Sync value in case it changed between construction and editor init
        _suppressChange = true;
        try
        {
            var current = await _editor.GetValue();
            if (current != Value)
                await _editor.SetValue(Value);
        }
        finally
        {
            _suppressChange = false;
        }
        await OnEditorReady.InvokeAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_editor is null || !_editorInitialized) return;

        if (_lastReadOnly != ReadOnly)
        {
            _lastReadOnly = ReadOnly;
            await _editor.UpdateOptions(new EditorUpdateOptions { ReadOnly = ReadOnly });
        }

        if (_lastLanguage != Language)
        {
            _lastLanguage = Language;
            try { await JS.InvokeVoidAsync("setMonacoEditorLanguage", _id, Language); }
            catch { /* best effort */ }
        }

        _suppressChange = true;
        try
        {
            var current = await _editor.GetValue();
            if (current != Value)
                await _editor.SetValue(Value);
        }
        finally
        {
            _suppressChange = false;
        }
    }
}
