@using DuckHouse.Ui.Client.Notebook
@using DuckHouse.Core.Kernels
@using System.Text.RegularExpressions
@using Markdig

<div style="margin-bottom: 12px;">
    @* ── Cell header: label + language badge + toolbar ── *@
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
        @if (Cell.CellType == NotebookCellType.Code)
        {
            <span style="color: var(--ant-color-primary); font-family: monospace; font-size: 0.875rem; white-space: nowrap;">In [@(Cell.ExecutionCount?.ToString() ?? " ")]:</span>
        }

        <select style="padding: 2px 6px; border: 1px solid var(--ant-color-border); border-radius: 6px; font-size: 0.75rem; height: auto;"
                disabled="@Cell.IsExecuting"
                value="@CellTypeValue"
                @onchange="OnCellTypeChanged">
            <option value="python">Python</option>
            <option value="sql">SQL</option>
            <option value="markdown">Markdown</option>
        </select>

        <Space Style="margin-left: auto;" Size="@("4")">
            @if (Cell.CellType == NotebookCellType.Code)
            {
                @if (Cell.IsExecuting)
                {
                    <SpaceItem>
                        <Tooltip Title="Interrupt execution">
                            <Button Size="ButtonSize.Small"
                                    OnClick="OnInterrupt"
                                    Icon="@IconType.Outline.PauseCircle" />
                        </Tooltip>
                    </SpaceItem>
                }
                else
                {
                    <SpaceItem>
                        <Tooltip Title="Run cell">
                            <Button Size="ButtonSize.Small" Type="ButtonType.Primary"
                                    Disabled="@(!HasKernel)"
                                    Icon="@IconType.Outline.PlayCircle"
                                    OnClick="OnExecute" />
                        </Tooltip>
                    </SpaceItem>
                    <SpaceItem>
                        <Tooltip Title="Run above cells">
                            <Button Size="ButtonSize.Small"
                                    Disabled="@(!HasKernel || !CanMoveUp)"
                                    Icon="@IconType.Outline.ArrowUp"
                                    OnClick="OnRunAbove" />
                        </Tooltip>
                    </SpaceItem>
                    <SpaceItem>
                        <Tooltip Title="Run cell and below">
                            <Button Size="ButtonSize.Small"
                                    Disabled="@(!HasKernel)"
                                    Icon="@IconType.Outline.VerticalAlignBottom"
                                    OnClick="OnRunBelow" />
                        </Tooltip>
                    </SpaceItem>
                }
            }
            else
            {
                @if (Cell.IsEditingMarkdown)
                {
                    <SpaceItem>
                        <Tooltip Title="Stop editing markdown">
                            <Button Size="ButtonSize.Small"
                                    Icon="@IconType.Outline.Check"
                                    OnClick="StopEditingMarkdown" />
                        </Tooltip>
                    </SpaceItem>
                }
                else
                {
                    <SpaceItem>
                        <Tooltip Title="Start editing markdown">
                            <Button Size="ButtonSize.Small"
                                    Icon="@IconType.Outline.Edit"
                                    OnClick="StartEditingMarkdown" />
                        </Tooltip>
                    </SpaceItem>
                }
            }
            <SpaceItem>
                <Tooltip Title="Move cell up">
                    <Button Size="ButtonSize.Small"
                            Disabled="@(!CanMoveUp)"
                            Icon="@IconType.Outline.Up"
                            OnClick="OnMoveUp" />
                </Tooltip>
            </SpaceItem>
            <SpaceItem>
                <Tooltip Title="Move cell down">
                    <Button Size="ButtonSize.Small"
                            Disabled="@(!CanMoveDown)"
                            Icon="@IconType.Outline.Down"
                            OnClick="OnMoveDown" />
                </Tooltip>
            </SpaceItem>
            <SpaceItem>
                <Tooltip Title="Delete cell">
                    <Button Size="ButtonSize.Small" Danger Type="ButtonType.Primary"
                            Icon="@IconType.Outline.Close"
                            OnClick="OnDelete" />
                </Tooltip>
            </SpaceItem>
        </Space>
    </div>

    @* ── Editor ── *@
    @if (Cell.CellType == NotebookCellType.Code)
    {
        @if (HasKernel && Cell.Language == NotebookCellLanguage.Python)
        {
            <KernelCodeCell Value="@Cell.Source"
                            ValueChanged="@(async v => { Cell.Source = v; await OnCellChanged.InvokeAsync(); })"
                            NodeName="@(NodeName ?? "")"
                            KernelId="@(KernelId ?? "")"
                            ReadOnly="@Cell.IsExecuting"
                            PriorContext="PriorContext"
                            OnExecute="OnExecute"
                            Class="editor-cell" />
        }
        else
        {
            <CodeCell Value="@Cell.Source"
                      ValueChanged="@(async v => { Cell.Source = v; await OnCellChanged.InvokeAsync(); })"
                      Language="@(Cell.Language == NotebookCellLanguage.Sql ? "sql" : "python")"
                      ReadOnly="@Cell.IsExecuting"
                      OnExecute="OnExecute"
                      Class="editor-cell" />
        }
    }
    else
    {
        @if (Cell.IsEditingMarkdown)
        {
            <CodeCell Value="@Cell.Source"
                      ValueChanged="@(async v => { Cell.Source = v; await OnCellChanged.InvokeAsync(); })"
                      Language="markdown"
                      Class="editor-cell" />
        }
        else
        {
            <div style="padding: 8px; border: 1px solid var(--ant-color-border); border-radius: 6px; margin-bottom: 4px; cursor: pointer; min-height: 2.5rem;"
                 @onclick="StartEditingMarkdown">
                @if (string.IsNullOrWhiteSpace(Cell.Source))
                {
                    <span style="color: var(--ant-color-text-quaternary); font-style: italic; font-size: 0.875rem;">Click to edit markdown…</span>
                }
                else
                {
                    @((MarkupString)Markdig.Markdown.ToHtml(Cell.Source, _mdPipeline))
                }
            </div>
        }
    }

    @* ── Outputs (code cells only) ── *@
    @if (Cell.CellType == NotebookCellType.Code)
    {
        @if (Cell.IsExecuting || Cell.DurationMs.HasValue)
        {
            <div style="display: flex; align-items: flex-end; gap: 8px; margin-bottom: 4px;">
                <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap;">In [ ]:</span>
                @if (!Cell.IsExecuting)
                {
                    @if (Cell.Error is not null)
                    {
                        <Icon Type="@IconType.Outline.CloseCircle" Style="color: var(--ant-color-error);" />
                    }
                    else if (HasStderr)
                    {
                        <Icon Type="@IconType.Outline.Warning" Style="color: var(--ant-color-warning);" />
                    }
                    else
                    {
                        <Icon Type="@IconType.Outline.CheckCircle" Style="color: var(--ant-color-success);" />
                    }
                }
                else
                {
                    <Icon Type="@IconType.Outline.Sync" Style="color: var(--ant-color-text-secondary);" />
                }
                <ExecutionTimer IsRunning="@Cell.IsExecuting" DurationMs="@(Cell.IsExecuting ? null : Cell.DurationMs)" />
                @if (!Cell.IsExecuting && ExtractRowCount() is { } rowCount)
                {
                    bool atCap = rowCount == DataFrameOutput.RowCap;
                    <span style="color: var(--ant-color-text-secondary); font-size: 0.875rem;">· @rowCount.ToString("N0")@(atCap ? "+" : "") rows</span>
                }
            </div>
        }

        @foreach (var output in Cell.Outputs)
        {
            @if (output.Type == "stream")
            {
                bool isStderr = output.Name == "stderr";
                <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                    <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                    <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid @(isStderr ? "var(--ant-color-warning)" : "var(--ant-color-border)"); padding-left: 8px; color: @(isStderr ? "var(--ant-color-warning)" : "inherit");">@output.Text</pre>
                </div>
            }
            else if (output.Type is "execute_result" or "display_data")
            {
                string outLabel = $"Out[{output.ExecutionCount ?? Cell.ExecutionCount}]:";

                @if (output.Data is not null
                     && output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                     && DataFrameOutput.TryParse(dfRaw) is { } dfOutput)
                {
                    <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                        <span style="color: var(--ant-color-info); font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                        <div style="flex: 1 1 0%; border-left: 3px solid var(--ant-color-info); padding-left: 8px; min-width: 0;">
                            <DataFrameView Data="dfOutput" />
                        </div>
                    </div>
                }
                else
                {
                    string? htmlText = GetDataText(output.Data, "text/html");
                    string? plainText = GetDataText(output.Data, "text/plain") ?? output.Text;

                    @if (htmlText is not null)
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                            <span style="color: var(--ant-color-info); font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                            <div style="flex: 1 1 0%; border-left: 3px solid var(--ant-color-info); padding-left: 8px; font-size: 0.875rem;">@((MarkupString)htmlText)</div>
                        </div>
                    }
                    else if (plainText is not null)
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                            <span style="color: var(--ant-color-info); font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                            <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid var(--ant-color-info); padding-left: 8px;">@plainText</pre>
                        </div>
                    }
                }
            }
        }

        @if (Cell.Error is { } err)
        {
            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                <div style="flex: 1 1 0%; border-left: 3px solid var(--ant-color-error); padding-left: 8px; background-color: var(--ant-color-error-bg); border-radius: 0 4px 4px 0; padding: 8px 8px 8px 12px;">
                    <div style="color: var(--ant-color-error); font-weight: 700; font-size: 0.875rem; margin-bottom: 4px;">@err.Ename: @err.Evalue</div>
                    <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; margin: 0; color: var(--ant-color-error-text);">@string.Join("\n", err.Traceback.Select(StripAnsi))</pre>
                </div>
            </div>
        }
    }
</div>

@code {
    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    [Parameter, EditorRequired] public NotebookCell Cell { get; set; } = default!;
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string? KernelId { get; set; }
    [Parameter] public bool CanMoveUp { get; set; }
    [Parameter] public bool CanMoveDown { get; set; }
    [Parameter] public Func<string>? PriorContext { get; set; }
    [Parameter] public EventCallback OnExecute { get; set; }
    [Parameter] public EventCallback OnRunAbove { get; set; }
    [Parameter] public EventCallback OnRunBelow { get; set; }
    [Parameter] public EventCallback OnInterrupt { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnMoveUp { get; set; }
    [Parameter] public EventCallback OnMoveDown { get; set; }
    [Parameter] public EventCallback OnCellChanged { get; set; }

    private bool HasKernel => !string.IsNullOrEmpty(NodeName) && !string.IsNullOrEmpty(KernelId);

    private bool HasStderr => Cell.Outputs.Any(o => o.Type == "stream" && o.Name == "stderr");

    private string CellTypeValue => Cell.CellType == NotebookCellType.Markdown
        ? "markdown"
        : Cell.Language == NotebookCellLanguage.Sql ? "sql" : "python";

    private async Task OnCellTypeChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();

        var newType = value == "markdown" ? NotebookCellType.Markdown : NotebookCellType.Code;
        var newLang = value == "sql" ? NotebookCellLanguage.Sql : NotebookCellLanguage.Python;

        // Clear outputs when switching away from code, or between languages
        if (Cell.CellType != newType || Cell.Language != newLang)
        {
            if (newType == NotebookCellType.Markdown)
            {
                Cell.ClearOutput();
                Cell.IsEditingMarkdown = true;
            }
            else if (Cell.CellType == NotebookCellType.Markdown)
            {
                // Switching from markdown to code — start in edit mode makes no sense; just show the editor
                Cell.IsEditingMarkdown = false;
            }

            Cell.CellType = newType;
            Cell.Language = newLang;
            await OnCellChanged.InvokeAsync();
        }
    }

    private void StartEditingMarkdown()
    {
        Cell.IsEditingMarkdown = true;
    }

    private void StopEditingMarkdown()
    {
        Cell.IsEditingMarkdown = false;
    }

    private static string? GetDataText(Dictionary<string, object>? data, string mimeType)
    {
        if (data?.TryGetValue(mimeType, out var value) != true) return null;
        return value?.ToString();
    }

    private int? ExtractRowCount()
    {
        foreach (var output in Cell.Outputs)
        {
            if (output.Type is not ("execute_result" or "display_data")) continue;

            if (output.Data is not null
                && output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                && DataFrameOutput.TryParse(dfRaw) is { } df)
                return df.TotalRows;

            string? plainText = GetDataText(output.Data, "text/plain") ?? output.Text;
            if (plainText is not null)
            {
                var m = Regex.Match(plainText, @"\[(\d[\d,]*)\s+rows?\s+[x×]");
                if (m.Success && int.TryParse(m.Groups[1].Value.Replace(",", ""), out int n))
                    return n;
            }
        }
        return null;
    }

    private static string StripAnsi(string text) =>
        Regex.Replace(text, @"\x1B\[[0-9;]*[a-zA-Z]", "");
}
