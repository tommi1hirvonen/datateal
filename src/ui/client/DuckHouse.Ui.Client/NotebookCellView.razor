@using DuckHouse.Ui.Client.Notebook
@using DuckHouse.Core.Kernels
@using System.Text.RegularExpressions
@using Markdig

<div>
    @* ── Cell header: label + language badge + toolbar ── *@
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
        @if (Cell.CellType == NotebookCellType.Code)
        {
            <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap;">In [@(Cell.ExecutionCount?.ToString() ?? " ")]:</span>
        }

        @if (Cell.CellType == NotebookCellType.Code)
        {
            <Space Size="SpaceSize.Small" Align="SpaceAlign.End">
                @if (Cell.IsExecuting)
                {
                    <SpaceItem>
                        <Button Size="ButtonSize.Small"
                                OnClick="OnInterrupt"
                                Icon="@IconType.Outline.Loading">
                                Interrupt
                        </Button>
                    </SpaceItem>
                    
                }
                else
                {
                    <SpaceItem>
                        <DropdownButton Disabled="@(!HasKernel)"
                                        OnClick="OnExecute"
                                        Size="ButtonSize.Small"
                                        Trigger="[Trigger.Click]"
                                        Type="(ButtonType.Primary, ButtonType.Default)">
                            <Overlay>
                                <Menu>
                                    <MenuItem Disabled="@(!HasKernel)" OnClick="OnExecute">
                                        Run cell (Ctrl+Enter)
                                    </MenuItem>
                                    <MenuItem Disabled="@(!HasKernel || !CanMoveUp)" OnClick="OnRunAbove">
                                        Run above cells
                                    </MenuItem>
                                    <MenuItem Disabled="@(!HasKernel)" OnClick="OnRunBelow">
                                        Run cell and below
                                    </MenuItem>
                                </Menu>
                            </Overlay>
                            <Unbound>
                                <Tooltip Title="Run cell (Ctrl+Enter)">
                                    <Unbound Context="tooltip">
                                        <span @ref="tooltip.Current">
                                            <Icon Type="@IconType.Outline.PlayCircle" />
                                            Run
                                        </span>
                                    </Unbound>
                                </Tooltip>
                            </Unbound>
                        </DropdownButton>
                    </SpaceItem>
                }
                @if (Cell.IsExecuting || Cell.DurationMs.HasValue)
                {
                    @if (!Cell.IsExecuting)
                    {
                        @if (Cell.Error is not null)
                        {
                            <SpaceItem>
                                <Text Type="TextElementType.Danger">
                                    <Icon Type="@IconType.Outline.CloseCircle" />
                                </Text>
                            </SpaceItem>
                        }
                        else if (HasStderr)
                        {
                            <SpaceItem>
                                <Text Type="TextElementType.Warning">
                                    <Icon Type="@IconType.Outline.Warning" />
                                </Text>
                            </SpaceItem>
                        }
                        else
                        {
                            <SpaceItem>
                                <Text Type="TextElementType.Success">
                                    <Icon Type="@IconType.Outline.CheckCircle" />
                                </Text>
                            </SpaceItem>
                        }
                    }
                    <SpaceItem>
                        <Text Type="TextElementType.Secondary">
                            <ExecutionTimer IsRunning="@Cell.IsExecuting" DurationMs="@(Cell.IsExecuting ? null : Cell.DurationMs)" />
                        </Text>
                    </SpaceItem>
                    @if (!Cell.IsExecuting && ExtractRowCount() is { } rowCount)
                    {
                        bool atCap = rowCount == DataFrameOutput.RowCap;
                        <SpaceItem>
                            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">· @rowCount.ToString("N0")@(atCap ? "+" : "") rows</Text>
                        </SpaceItem>
                    }
                }
            </Space>
        }

        <Space Style="margin-left: auto;">

            @if (Cell.CellType == NotebookCellType.Code && Cell.Language == NotebookCellLanguage.Python)
            {
                <SpaceItem>
                    <Tooltip Title="@(Cell.IsParameterCell ? "Clear parameters role" : "Mark as parameters cell")">
                        <Button Size="ButtonSize.Small"
                                Type="@(Cell.IsParameterCell ? ButtonType.Primary : ButtonType.Default)"
                                OnClick="OnToggleParameters">
                            @@
                        </Button>
                    </Tooltip>
                </SpaceItem>
            }

            <SpaceItem>
                <Select TItemValue="string"
                        TItem="string"
                        Value="@CellTypeValue"
                        ValueChanged="OnCellTypeChanged"
                        Disabled="@Cell.IsExecuting"
                        Bordered="false"
                        Size="InputSize.Small"
                        Style="min-width: 90px;">
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("python")" Label="Python" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("sql")" Label="SQL" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("markdown")" Label="Markdown" />
                    </SelectOptions>
                </Select>
            </SpaceItem>

            @if (Cell.CellType == NotebookCellType.Markdown)
            {
                @if (Cell.IsEditingMarkdown)
                {
                    <SpaceItem>
                        <Tooltip Title="Stop editing markdown">
                            <Button Size="ButtonSize.Small"
                                    Icon="@IconType.Outline.Check"
                                    OnClick="StopEditingMarkdown" />
                        </Tooltip>
                    </SpaceItem>
                }
                else
                {
                    <SpaceItem>
                        <Tooltip Title="Start editing markdown">
                            <Button Size="ButtonSize.Small"
                                    Icon="@IconType.Outline.Edit"
                                    OnClick="StartEditingMarkdown" />
                        </Tooltip>
                    </SpaceItem>
                }
            }
            <SpaceItem>
                <Tooltip Title="Move cell up">
                    <Button Size="ButtonSize.Small"
                            Disabled="@(!CanMoveUp)"
                            Icon="@IconType.Outline.Up"
                            OnClick="OnMoveUp" />
                </Tooltip>
            </SpaceItem>
            <SpaceItem>
                <Tooltip Title="Move cell down">
                    <Button Size="ButtonSize.Small"
                            Disabled="@(!CanMoveDown)"
                            Icon="@IconType.Outline.Down"
                            OnClick="OnMoveDown" />
                </Tooltip>
            </SpaceItem>
            <SpaceItem>
                <Tooltip Title="Clear cell output">
                    <Button Size="ButtonSize.Small" Type="ButtonType.Default"
                            Icon="@IconType.Outline.Clear"
                            OnClick="Cell.ClearOutput" />
                </Tooltip>
            </SpaceItem>
            <SpaceItem>
                <Tooltip Title="Delete cell">
                    <Button Size="ButtonSize.Small" Type="ButtonType.Default"
                            Icon="@IconType.Outline.Delete"
                            OnClick="OnDelete" />
                </Tooltip>
            </SpaceItem>
        </Space>
    </div>

    @* ── Parameters banner ── *@
    @if (Cell.IsParameterCell)
    {
        <div style="display: flex; align-items: center; gap: 6px; padding: 2px 8px;
                    background: #e6f4ff; border-top: 1px dashed #91caff; border-bottom: 1px dashed #91caff;
                    font-size: 11px; color: #0958d9;">
            <span>@@ Parameters</span>
        </div>
    }

    @* ── Editor ── *@
    @if (Cell.CellType == NotebookCellType.Code)
    {
        @if (HasKernel && Cell.Language == NotebookCellLanguage.Python)
        {
            <KernelCodeCell Value="@Cell.Source"
                            ValueChanged="@(v => { Cell.Source = v; OnCellChanged?.Invoke(); })"
                            NodeName="@(NodeName ?? "")"
                            KernelId="@(KernelId ?? "")"
                            PriorContext="PriorContext"
                            ProvideRunMagicCompletions="ProvideRunMagicCompletions"
                            OnExecute="OnExecute"
                            AlwaysConsumeMouseWheel="@AlwaysConsumeMouseWheel"
                            Class="editor-cell" />
        }
        else
        {
            <CodeCell Value="@Cell.Source"
                      ValueChanged="@(v => { Cell.Source = v; OnCellChanged?.Invoke(); })"
                      Language="@(Cell.Language == NotebookCellLanguage.Sql ? "duckdb-sql" : "duckhouse-python")"
                      OnExecute="OnExecute"
                      AlwaysConsumeMouseWheel="@AlwaysConsumeMouseWheel"
                      Class="editor-cell" />
        }
    }
    else
    {
        @if (Cell.IsEditingMarkdown)
        {
            <CodeCell Value="@Cell.Source"
                      ValueChanged="@(v => { Cell.Source = v; OnCellChanged?.Invoke(); })"
                      Language="markdown"
                      AlwaysConsumeMouseWheel="@AlwaysConsumeMouseWheel"
                      Class="editor-cell" />
        }
        else
        {
            <div class="markdown-cell" style="padding: 12px; margin-bottom: 8px; cursor: pointer; min-height: 2.5rem;"
                 @onclick="StartEditingMarkdown">
                @if (string.IsNullOrWhiteSpace(Cell.Source))
                {
                    <span style="font-style: italic; font-size: 0.875rem;">Click to edit markdown…</span>
                }
                else
                {
                    @((MarkupString)HtmlSanitizeHelper.Sanitize(Markdig.Markdown.ToHtml(Cell.Source, _mdPipeline)))
                }
            </div>
        }
    }

    @* ── Outputs (code cells only) ── *@
    @if (Cell.CellType == NotebookCellType.Code)
    {
        @foreach (var output in Cell.Outputs)
        {
            @if (output.Type == "stream")
            {
                bool isStderr = output.Name == "stderr";
                <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                    <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                    @if (isStderr)
                    {
                        <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid var(--ant-color-warning); padding-left: 8px;"><Text Type="TextElementType.Warning">@output.Text</Text></pre>
                    }
                    else
                    {
                        <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid var(--ant-color-border); padding-left: 8px;">@output.Text</pre>
                    }
                </div>
            }
            else if (output.Type is "execute_result" or "display_data")
            {
                string outLabel = $"Out[{output.ExecutionCount ?? Cell.ExecutionCount}]:";

                @if (output.Data is not null
                     && output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                     && DataFrameOutput.TryParse(dfRaw) is { } dfOutput)
                {
                    <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                        <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                        <div style="flex: 1 1 0%; border-left: 3px solid; padding-left: 8px; min-width: 0;">
                            <DataFrameView Data="dfOutput" />
                        </div>
                    </div>
                }
                else
                {
                    string? htmlText = GetDataText(output.Data, "text/html");
                    string? plainText = GetDataText(output.Data, "text/plain") ?? output.Text;

                    @if (htmlText is not null)
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                            <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                            <div style="flex: 1 1 0%; border-left: 3px solid; padding-left: 8px; font-size: 0.875rem;">@((MarkupString)HtmlSanitizeHelper.Sanitize(htmlText))</div>
                        </div>
                    }
                    else if (plainText is not null)
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                            <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                            <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid; padding-left: 8px;">@plainText</pre>
                        </div>
                    }
                }
            }
        }

        @if (Cell.Error is { } err)
        {
            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                <div style="flex: 1 1 0%; border-left: 3px solid; padding-left: 8px; border-radius: 0 4px 4px 0; padding: 8px 8px 8px 12px;">
                    <Text Type="TextElementType.Danger" Strong Style="display: block; font-size: 0.875rem; margin-bottom: 4px;">@err.Ename: @err.Evalue</Text>
                    <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; margin: 0;"><Text Type="TextElementType.Danger">@string.Join("\n", err.Traceback.Select(StripAnsi))</Text></pre>
                </div>
            </div>
        }
    }
</div>

@code {
    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    [Parameter, EditorRequired] public NotebookCell Cell { get; set; } = default!;
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string? KernelId { get; set; }
    [Parameter] public bool CanMoveUp { get; set; }
    [Parameter] public bool CanMoveDown { get; set; }
    [Parameter] public Func<Task<string>>? PriorContext { get; set; }
    [Parameter] public Func<string, Task<IReadOnlyList<RunMagicCompletionItem>>>? ProvideRunMagicCompletions { get; set; }
    [Parameter] public EventCallback OnExecute { get; set; }
    [Parameter] public EventCallback OnRunAbove { get; set; }
    [Parameter] public EventCallback OnRunBelow { get; set; }
    [Parameter] public EventCallback OnInterrupt { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnMoveUp { get; set; }
    [Parameter] public EventCallback OnMoveDown { get; set; }
    [Parameter] public Action? OnCellChanged { get; set; }
    [Parameter] public EventCallback OnToggleParameters { get; set; }
    [Parameter] public bool AlwaysConsumeMouseWheel { get; set; } = true;

    // Change-tracking fields for ShouldRender
    private string? _lastNodeName;
    private string? _lastKernelId;
    private bool _lastCanMoveUp;
    private bool _lastCanMoveDown;
    private string _lastSource = "";
    private NotebookCellType _lastCellType;
    private NotebookCellLanguage _lastLanguage;
    private bool _lastIsExecuting;
    private int? _lastExecutionCount;
    private double? _lastDurationMs;
    private ErrorInfo? _lastError;
    private int _lastOutputsCount;
    private bool _lastIsEditingMarkdown;
    private bool _lastIsParameterCell;

    protected override bool ShouldRender()
    {
        bool changed = _lastNodeName != NodeName
            || _lastKernelId != KernelId
            || _lastCanMoveUp != CanMoveUp
            || _lastCanMoveDown != CanMoveDown
            || _lastSource != Cell.Source
            || _lastCellType != Cell.CellType
            || _lastLanguage != Cell.Language
            || _lastIsExecuting != Cell.IsExecuting
            || _lastExecutionCount != Cell.ExecutionCount
            || _lastDurationMs != Cell.DurationMs
            || !ReferenceEquals(_lastError, Cell.Error)
            || _lastOutputsCount != Cell.Outputs.Count
            || _lastIsEditingMarkdown != Cell.IsEditingMarkdown
            || _lastIsParameterCell != Cell.IsParameterCell;

        if (!changed) return false;

        _lastNodeName = NodeName;
        _lastKernelId = KernelId;
        _lastCanMoveUp = CanMoveUp;
        _lastCanMoveDown = CanMoveDown;
        _lastSource = Cell.Source;
        _lastCellType = Cell.CellType;
        _lastLanguage = Cell.Language;
        _lastIsExecuting = Cell.IsExecuting;
        _lastExecutionCount = Cell.ExecutionCount;
        _lastDurationMs = Cell.DurationMs;
        _lastError = Cell.Error;
        _lastOutputsCount = Cell.Outputs.Count;
        _lastIsEditingMarkdown = Cell.IsEditingMarkdown;
        _lastIsParameterCell = Cell.IsParameterCell;
        return true;
    }

    private bool HasKernel => !string.IsNullOrEmpty(NodeName) && !string.IsNullOrEmpty(KernelId);

    private bool HasStderr => Cell.Outputs.Any(o => o.Type == "stream" && o.Name == "stderr");

    private string CellTypeValue => Cell.CellType == NotebookCellType.Markdown
        ? "markdown"
        : Cell.Language == NotebookCellLanguage.Sql ? "sql" : "python";

    private void OnCellTypeChanged(string value)
    {
        var newType = value == "markdown" ? NotebookCellType.Markdown : NotebookCellType.Code;
        var newLang = value == "sql" ? NotebookCellLanguage.Sql : NotebookCellLanguage.Python;

        // Clear outputs when switching away from code, or between languages
        if (Cell.CellType != newType || Cell.Language != newLang)
        {
            if (newType == NotebookCellType.Markdown)
            {
                Cell.ClearOutput();
                Cell.IsEditingMarkdown = true;
            }
            else if (Cell.CellType == NotebookCellType.Markdown)
            {
                // Switching from markdown to code — start in edit mode makes no sense; just show the editor
                Cell.IsEditingMarkdown = false;
            }

            Cell.CellType = newType;
            Cell.Language = newLang;
            OnCellChanged?.Invoke();
        }
    }

    private void StartEditingMarkdown()
    {
        Cell.IsEditingMarkdown = true;
    }

    private void StopEditingMarkdown()
    {
        Cell.IsEditingMarkdown = false;
    }

    private static string? GetDataText(Dictionary<string, object>? data, string mimeType)
    {
        if (data?.TryGetValue(mimeType, out var value) != true) return null;
        return value?.ToString();
    }

    private int? ExtractRowCount()
    {
        foreach (var output in Cell.Outputs)
        {
            if (output.Type is not ("execute_result" or "display_data")) continue;

            if (output.Data is not null
                && output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                && DataFrameOutput.TryParse(dfRaw) is { } df)
                return df.TotalRows;

            string? plainText = GetDataText(output.Data, "text/plain") ?? output.Text;
            if (plainText is not null)
            {
                var m = Regex.Match(plainText, @"\[(\d[\d,]*)\s+rows?\s+[x×]");
                if (m.Success && int.TryParse(m.Groups[1].Value.Replace(",", ""), out int n))
                    return n;
            }
        }
        return null;
    }

    private static string StripAnsi(string text) =>
        Regex.Replace(text, @"\x1B\[[0-9;]*[a-zA-Z]", "");
}
