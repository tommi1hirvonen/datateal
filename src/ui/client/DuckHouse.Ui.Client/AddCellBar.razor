@using DuckHouse.Ui.Client.Notebook

<div class="d-flex align-items-center gap-1 my-1 opacity-50" style="font-size: 0.75rem;">
    <div class="flex-grow-1 border-top border-secondary-subtle"></div>
    <button class="btn btn-outline-primary btn-xs px-2 py-0 d-flex align-items-center" @onclick="OnAddPython">
        <SvgIcon Icon="LucideIcon.Plus" /> Python
    </button>
    <button class="btn btn-outline-success btn-xs px-2 py-0 d-flex align-items-center" @onclick="OnAddSql">
        <SvgIcon Icon="LucideIcon.Plus" /> SQL
    </button>
    <button class="btn btn-outline-secondary btn-xs px-2 py-0 d-flex align-items-center" @onclick="OnAddMarkdown">
        <SvgIcon Icon="LucideIcon.Plus" /> MD
    </button>
    <div class="flex-grow-1 border-top border-secondary-subtle"></div>
</div>

@code {
    [Parameter] public EventCallback OnAddPython { get; set; }
    [Parameter] public EventCallback OnAddSql { get; set; }
    [Parameter] public EventCallback OnAddMarkdown { get; set; }
}
