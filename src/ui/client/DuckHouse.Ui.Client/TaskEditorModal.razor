@using DuckHouse.Ui.Client.Models
@using DuckHouse.Ui.Client.Validation
@using DuckHouse.Ui.Shared.Orchestration
@inject INodePoolService NodePoolService
@inject IJobService JobService

<Drawer Title="@(_isEdit ? "Edit task" : "Add task")"
        Visible="Visible"
        OnClose="HandleCancel"
        Width="520">
    <div style="display: flex; flex-direction: column; gap: 24px; padding-bottom: 60px;">

        @* Section 1: Basic Settings *@
        <div>
            <h4 style="margin: 0 0 12px;">Basic settings</h4>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500;">Name</label>
                    <Input @bind-Value="_name" Placeholder="task-name" />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500;">Task type</label>
                    <Select TItem="string" TItemValue="string" @bind-Value="_taskType" Style="width: 100%;" OnSelectedItemChanged="@((string _) => OnTaskTypeChanged())">
                        <SelectOption TItem="string" TItemValue="string" Value="@("Notebook")" Label="Notebook" />
                        <SelectOption TItem="string" TItemValue="string" Value="@("SqlQuery")" Label="SQL Query" />
                        <SelectOption TItem="string" TItemValue="string" Value="@("SubJob")" Label="Sub-Job" />
                    </Select>
                </div>
            </div>
        </div>

        @* Section 2: Type-Specific Settings *@
        <div>
            <h4 style="margin: 0 0 12px;">Type settings</h4>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                @if (_taskType == "Notebook")
                {
                    <div>
                        <label style="display: block; margin-bottom: 4px; font-weight: 500;">Notebook <span style="color: #ff4d4f;">*</span></label>
                        <WorkspaceItemPicker ItemType="Notebook"
                                             @bind-SelectedId="_notebookId" />
                        @if (_notebookId is null)
                        {
                            <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">A notebook must be selected.</div>
                        }
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 4px; font-weight: 500;">Node pool <span style="color: #ff4d4f;">*</span></label>
                        <Select TItem="NodePoolOption"
                                TItemValue="string"
                                DataSource="_nodePoolOptions"
                                @bind-Value="_nodePoolRef"
                                LabelName="@nameof(NodePoolOption.Label)"
                                ValueName="@nameof(NodePoolOption.Value)"
                                Style="width: 100%;"
                                Placeholder="Select node pool">
                            <ItemTemplate>
                                @{ var pool = (NodePoolOption)(object)context!; }
                                <div style="line-height: 1.4;">
                                    <div>@pool.Label</div>
                                    <div style="font-size: 11px; color: #888; margin-top: 1px;">@pool.PoolType · @pool.VmSize</div>
                                </div>
                            </ItemTemplate>
                        </Select>
                        @if (_nodePoolRef is null)
                        {
                            <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">A node pool must be selected.</div>
                        }
                    </div>
                }
                else if (_taskType == "SqlQuery")
                {
                    <div>
                        <label style="display: block; margin-bottom: 4px; font-weight: 500;">Query <span style="color: #ff4d4f;">*</span></label>
                        <WorkspaceItemPicker ItemType="Query"
                                             @bind-SelectedId="_queryId" />
                        @if (_queryId is null)
                        {
                            <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">A query must be selected.</div>
                        }
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 4px; font-weight: 500;">Node pool <span style="color: #ff4d4f;">*</span></label>
                        <Select TItem="NodePoolOption"
                                TItemValue="string"
                                DataSource="_nodePoolOptions"
                                @bind-Value="_nodePoolRef"
                                LabelName="@nameof(NodePoolOption.Label)"
                                ValueName="@nameof(NodePoolOption.Value)"
                                Style="width: 100%;"
                                Placeholder="Select node pool">
                            <ItemTemplate>
                                @{ var pool = (NodePoolOption)(object)context!; }
                                <div style="line-height: 1.4;">
                                    <div>@pool.Label</div>
                                    <div style="font-size: 11px; color: #888; margin-top: 1px;">@pool.PoolType · @pool.VmSize</div>
                                </div>
                            </ItemTemplate>
                        </Select>
                        @if (_nodePoolRef is null)
                        {
                            <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">A node pool must be selected.</div>
                        }
                    </div>
                }
                else if (_taskType == "SubJob")
                {
                    <div>
                        <label style="display: block; margin-bottom: 4px; font-weight: 500;">Job <span style="color: #ff4d4f;">*</span></label>
                        <Select TItem="JobOption"
                                TItemValue="Guid?"
                                DataSource="_jobOptions"
                                @bind-Value="_subJobId"
                                LabelName="@nameof(JobOption.Label)"
                                ValueName="@nameof(JobOption.Value)"
                                EnableSearch
                                AllowClear
                                Style="width: 100%;"
                                Placeholder="Select job" />
                        @if (_subJobId is null)
                        {
                            <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">A sub-job must be selected.</div>
                        }
                    </div>
                }
            </div>
        </div>

        @* Section 3: Execution Settings *@
        <div>
            <h4 style="margin: 0 0 12px;">Execution settings</h4>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500;">Max retries</label>
                    <AntDesign.InputNumber @bind-Value="_maxRetries" Min="0" Style="width: 100%;" />
                </div>
                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500;">Retry interval</label>
                    <Input @bind-Value="_retryInterval" Placeholder="00:00:30"
                           Status="@(ValidationHelper.ValidateTimeSpan(_retryInterval, required: true) is not null ? "error" : "")" />
                    @if (ValidationHelper.ValidateTimeSpan(_retryInterval, required: true) is { } retryErr)
                    {
                        <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">@retryErr</div>
                    }
                </div>
                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500;">Timeout</label>
                    <Input @bind-Value="_timeout" Placeholder="01:00:00 (optional)"
                           Status="@(ValidationHelper.ValidateTimeSpan(_timeout, required: false) is not null ? "error" : "")" />
                    @if (ValidationHelper.ValidateTimeSpan(_timeout, required: false) is { } timeoutErr)
                    {
                        <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">@timeoutErr</div>
                    }
                </div>
            </div>
        </div>

        @* Section 4: Parameters *@
        <div>
            <h4 style="margin: 0 0 4px;">Parameters</h4>
            <p style="font-size: 12px; color: #888; margin: 0 0 12px;">
                Use <code>$&#123;&#123; param_name &#125;&#125;</code> in a value to inherit from a job parameter at execution time.
            </p>
            @foreach (var (param, index) in _parameters.Select((p, i) => (p, i)))
            {
                var idx = index;
                var keyErr = _taskType == "Notebook" ? ValidationHelper.ValidatePythonIdentifier(param.Key) : null;
                <div style="margin-bottom: 8px;">
                    <div style="display: flex; gap: 8px; align-items: flex-start;">
                        <div style="flex: 1;">
                            <Input @bind-Value="param.Key" Placeholder="Key"
                                   Status="@(keyErr is not null ? "error" : "")" />
                            @if (keyErr is not null)
                            {
                                <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">@keyErr</div>
                            }
                        </div>
                        <Input @bind-Value="param.Value" Placeholder="Value" Style="flex: 1;" />
                        <Button Danger Size="@ButtonSize.Small" OnClick="() => _parameters.RemoveAt(idx)">
                            <Icon Type="@IconType.Outline.Delete" />
                        </Button>
                    </div>
                </div>
            }
            <Button Size="@ButtonSize.Small" OnClick="() => _parameters.Add(new EditableTaskParameter())">
                <Icon Type="@IconType.Outline.Plus" /> Add parameter
            </Button>
        </div>

        @* Section 5: Dependencies *@
        <div>
            <h4 style="margin: 0 0 12px;">Dependencies</h4>
            @foreach (var (dep, index) in _dependencies.Select((d, i) => (d, i)))
            {
                var idx = index;
                <div style="display: flex; gap: 8px; margin-bottom: 8px; align-items: center;">
                    <Select TItem="string" TItemValue="string"
                            DataSource="@OtherTaskNames"
                            @bind-Value="dep.TaskName"
                            Style="flex: 1;"
                            Placeholder="Depends on..." />
                    <Select TItem="string" TItemValue="string" @bind-Value="dep.Condition" Style="width: 140px;">
                        <SelectOption TItem="string" TItemValue="string" Value="@("OnSuccess")" Label="On Success" />
                        <SelectOption TItem="string" TItemValue="string" Value="@("OnFailure")" Label="On Failure" />
                        <SelectOption TItem="string" TItemValue="string" Value="@("OnCompletion")" Label="On Completion" />
                        <SelectOption TItem="string" TItemValue="string" Value="@("OnSkip")" Label="On Skip" />
                    </Select>
                    <Button Danger Size="@ButtonSize.Small" OnClick="() => _dependencies.RemoveAt(idx)">
                        <Icon Type="@IconType.Outline.Delete" />
                    </Button>
                </div>
            }
            <Button Size="@ButtonSize.Small" OnClick="() => _dependencies.Add(new EditableDependency())">
                <Icon Type="@IconType.Outline.Plus" /> Add dependency
            </Button>
        </div>
    </div>

    @* Footer *@
    <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 10px 16px; border-top: 1px solid #d9d9d9; background: #fff; display: flex; justify-content: flex-end; gap: 8px;">
        <Button OnClick="HandleCancel">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="HandleSave" Disabled="@HasValidationErrors()">Save</Button>
    </div>
</Drawer>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EditableTask? Task { get; set; }
    [Parameter] public EventCallback<EditableTask> OnSave { get; set; }
    [Parameter] public List<string> OtherTaskNames { get; set; } = [];
    [Parameter] public Guid CurrentJobId { get; set; }

    private bool _isEdit;
    private bool _prevVisible;

    // Form fields
    private string _name = "";
    private string _taskType = "Notebook";
    private int _maxRetries;
    private string _retryInterval = "00:00:30";
    private string? _timeout;
    private Guid? _notebookId;
    private Guid? _queryId;
    private Guid? _subJobId;
    private string? _nodePoolRef;
    private List<EditableTaskParameter> _parameters = [];
    private List<EditableDependency> _dependencies = [];

    // Data sources
    private List<NodePoolOption> _nodePoolOptions = [];
    private List<JobOption> _jobOptions = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pools = await NodePoolService.GetNodePoolsAsync();
            _nodePoolOptions = pools.Select(p => new NodePoolOption(p.Name, p.Name, p.PoolType.ToString(), p.VmSize)).ToList();
        }
        catch { /* Node pools may not be available */ }

        try
        {
            var jobs = await JobService.GetJobsAsync();
            _jobOptions = jobs
                .Where(j => j.Id != CurrentJobId)
                .Select(j => new JobOption(j.Id, j.Name))
                .ToList();
        }
        catch { /* Jobs may fail to load */ }
    }

    protected override void OnParametersSet()
    {
        if (Visible && !_prevVisible)
        {
            if (Task is not null)
            {
                _isEdit = true;
                _name = Task.Name;
                _taskType = Task.TaskType;
                _maxRetries = Task.MaxRetries;
                _retryInterval = Task.RetryInterval;
                _timeout = Task.Timeout;
                _notebookId = Task.NotebookId;
                _queryId = Task.QueryId;
                _subJobId = Task.SubJobId;
                _nodePoolRef = Task.NodePoolRef;
                _parameters = Task.Parameters.Select(p => new EditableTaskParameter { Key = p.Key, Value = p.Value }).ToList();
                _dependencies = Task.Dependencies.Select(d => new EditableDependency { TaskName = d.TaskName, Condition = d.Condition }).ToList();
            }
            else
            {
                _isEdit = false;
                _name = "";
                _taskType = "Notebook";
                _maxRetries = 0;
                _retryInterval = "00:00:30";
                _timeout = null;
                _notebookId = null;
                _queryId = null;
                _subJobId = null;
                _nodePoolRef = null;
                _parameters = [];
                _dependencies = [];
            }
        }
        _prevVisible = Visible;
    }

    private void OnTaskTypeChanged()
    {
        _notebookId = null;
        _queryId = null;
        _subJobId = null;
        _nodePoolRef = null;
    }

    private bool HasValidationErrors()
    {
        if (string.IsNullOrWhiteSpace(_name)) return true;
        if (_taskType == "Notebook" && _notebookId is null) return true;
        if (_taskType == "SqlQuery" && _queryId is null) return true;
        if (_taskType == "SubJob" && _subJobId is null) return true;
        if ((_taskType == "Notebook" || _taskType == "SqlQuery") && _nodePoolRef is null) return true;
        if (ValidationHelper.ValidateTimeSpan(_retryInterval, required: true) is not null) return true;
        if (ValidationHelper.ValidateTimeSpan(_timeout, required: false) is not null) return true;
        if (_taskType == "Notebook" && _parameters.Any(p => ValidationHelper.ValidatePythonIdentifier(p.Key) is not null)) return true;
        return false;
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        var result = new EditableTask
        {
            Name = _name.Trim(),
            TaskType = _taskType,
            MaxRetries = _maxRetries,
            RetryInterval = _retryInterval,
            Timeout = _timeout,
            NotebookId = _notebookId,
            QueryId = _queryId,
            SubJobId = _subJobId,
            NodePoolRef = _nodePoolRef,
            Parameters = _parameters.Where(p => !string.IsNullOrWhiteSpace(p.Key)).ToList(),
            Dependencies = _dependencies.Where(d => !string.IsNullOrWhiteSpace(d.TaskName)).ToList(),
        };
        await OnSave.InvokeAsync(result);
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCancel()
    {
        await VisibleChanged.InvokeAsync(false);
    }

    private record NodePoolOption(string Value, string Label, string PoolType, string VmSize);
    private record JobOption(Guid Value, string Label);
}
