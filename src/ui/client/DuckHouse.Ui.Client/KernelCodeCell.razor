@using BlazorMonaco
@using BlazorMonaco.Languages
@using BlazorMonaco.Editor
@using DuckHouse.Core.Kernels
@using DuckHouse.Ui.Client.Notebook
@using System.Text.Json
@using System.Text.RegularExpressions
@inject IKernelService KernelService
@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<CodeCell @ref="_codeCell"
          Value="@Value"
          ValueChanged="OnValueChangedAsync"
          Height="@Height"
          ReadOnly="@ReadOnly"
          OnExecute="OnExecute"
          OnEditorReady="OnEditorReadyAsync"
          Class="@Class" />

@code {
    [Parameter, EditorRequired] public string NodeName { get; set; } = "";
    [Parameter, EditorRequired] public string KernelId { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public int Height { get; set; } = 0;
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public EventCallback OnExecute { get; set; }
    [Parameter] public string? Class { get; set; }
    /// <summary>Returns the accumulated code from all prior cells (joined by newlines).
    /// Used as context for completions and diagnostics so Jedi/pyflakes can see
    /// variables and imports defined in earlier cells of the same session.</summary>
    [Parameter] public Func<string>? PriorContext { get; set; }
    /// <summary>
    /// Optional callback to provide workspace item completions for <c>%run</c> magic lines.
    /// Given a directory path (e.g., <c>./</c> or <c>../subfolder/</c>), returns folder names,
    /// notebook titles, and query titles in the resolved folder.
    /// </summary>
    [Parameter] public Func<string, Task<IReadOnlyList<RunMagicCompletionItem>>>? ProvideRunMagicCompletions { get; set; }

    private static readonly Regex RunLinePrefix = new(@"^\s*%run\s+(.*)", RegexOptions.Compiled);

    private CodeCell _codeCell = default!;
    private TextModel? _model;
    private string _currentCode = "";
    private CancellationTokenSource? _diagCts;

    private async Task OnEditorReadyAsync()
    {
        _model = await _codeCell.Editor!.GetModel();
        await RegisterCompletionProviderAsync();
        await RunDiagnosticsAsync(_currentCode);
    }

    private Task RegisterCompletionProviderAsync() =>
        BlazorMonaco.Languages.Global.RegisterCompletionItemProvider(
            JsRuntime,
            "python",
            new CompletionItemProvider(new List<string> { ".", "/" }, ProvideCompletionsAsync, null));

    private async Task<CompletionList> ProvideCompletionsAsync(
        string modelUri,
        BlazorMonaco.Position position,
        CompletionContext context)
    {
        try
        {
            // Check if the current line is a %run line
            if (_model is not null && ProvideRunMagicCompletions is not null)
            {
                string lineContent = await _model.GetLineContent(position.LineNumber);
                var runMatch = RunLinePrefix.Match(lineContent);
                if (runMatch.Success)
                    return await ProvideRunMagicCompletionListAsync(runMatch.Groups[1].Value, position);
            }

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(3));

            int startCol = position.Column;
            if (_model is not null)
            {
                var wordInfo = await _model.GetWordUntilPosition(position);
                startCol = wordInfo?.StartColumn ?? position.Column;
            }

            var response = await KernelService.CompleteAsync(
                NodeName, KernelId,
                new CompleteRequest(_currentCode, position.LineNumber, position.Column - 1, PriorContext?.Invoke() ?? ""),
                cts.Token);

            var range = JsonSerializer.SerializeToElement(new
            {
                startLineNumber = position.LineNumber,
                startColumn = startCol,
                endLineNumber = position.LineNumber,
                endColumn = position.Column,
            });

            var suggestions = response.Items
                .Select(item => new BlazorMonaco.Languages.CompletionItem
                {
                    Label = JsonSerializer.SerializeToElement(item.Label),
                    Kind = MapKind(item.Kind),
                    InsertText = item.InsertText,
                    Detail = item.Detail,
                    SortText = GetSortText(item.Label),
                    Range = range,
                })
                .ToList();

            return new CompletionList { Suggestions = suggestions, Incomplete = false };
        }
        catch
        {
            return new CompletionList { Suggestions = [], Incomplete = false };
        }
    }

    private async Task<CompletionList> ProvideRunMagicCompletionListAsync(
        string typedPath,
        BlazorMonaco.Position position)
    {
        // Split typed path into directory portion and name prefix
        string dirPath;
        string namePrefix;
        int lastSlash = typedPath.LastIndexOf('/');
        if (lastSlash >= 0)
        {
            dirPath = typedPath[..(lastSlash + 1)];
            namePrefix = typedPath[(lastSlash + 1)..];
        }
        else
        {
            dirPath = "./";
            namePrefix = typedPath;
        }

        var items = await ProvideRunMagicCompletions!(dirPath);

        // Calculate the column where the name prefix starts (after "%run " and the dir path)
        string lineContent = await _model!.GetLineContent(position.LineNumber);
        var match = RunLinePrefix.Match(lineContent);
        int runArgStart = match.Groups[1].Index + 1; // 1-based column
        int nameStartCol = runArgStart + (lastSlash >= 0 ? lastSlash + 1 : 0);

        var range = JsonSerializer.SerializeToElement(new
        {
            startLineNumber = position.LineNumber,
            startColumn = nameStartCol,
            endLineNumber = position.LineNumber,
            endColumn = position.Column,
        });

        var suggestions = items
            .Where(i => string.IsNullOrEmpty(namePrefix) || i.Label.StartsWith(namePrefix, StringComparison.OrdinalIgnoreCase))
            .Select(item => new BlazorMonaco.Languages.CompletionItem
            {
                Label = JsonSerializer.SerializeToElement(item.Label),
                Kind = item.Kind switch
                {
                    "folder" => BlazorMonaco.Languages.CompletionItemKind.Folder,
                    _ => BlazorMonaco.Languages.CompletionItemKind.File,
                },
                InsertText = item.InsertText,
                Detail = item.Kind,
                SortText = item.Kind == "folder" ? "0" + item.Label : "1" + item.Label,
                Range = range,
            })
            .ToList();

        return new CompletionList { Suggestions = suggestions, Incomplete = false };
    }

    private async Task OnValueChangedAsync(string value)
    {
        Value = value;
        _currentCode = value;
        await ValueChanged.InvokeAsync(value);
        await ScheduleDiagnosticsAsync(value);
    }

    private async Task ScheduleDiagnosticsAsync(string value)
    {
        _diagCts?.Cancel();
        _diagCts = new CancellationTokenSource();
        var ct = _diagCts.Token;
        try
        {
            await Task.Delay(400, ct);
            await RunDiagnosticsAsync(value, ct);
        }
        catch (OperationCanceledException) { }
    }

    private async Task RunDiagnosticsAsync(string value, CancellationToken ct = default)
    {
        if (_model is null) return;
        try
        {
            var codeForDiag = RunMagicHelper.ReplaceRunLinesWithPass(value);
            var response = await KernelService.DiagnoseAsync(
                NodeName, KernelId,
                new DiagnoseRequest(codeForDiag, PriorContext?.Invoke() ?? ""),
                ct);

            var markers = response.Diagnostics
                .Select(d => new MarkerData
                {
                    StartLineNumber = d.Row,
                    StartColumn = d.Col + 1,
                    EndLineNumber = d.Row,
                    EndColumn = 9999,
                    Message = d.Message,
                    Severity = d.Severity == "error" ? MarkerSeverity.Error : MarkerSeverity.Warning,
                })
                .ToList();

            await BlazorMonaco.Editor.Global.SetModelMarkers(JsRuntime, _model!, "duckhouse-kernel", markers);
        }
        catch (OperationCanceledException) { }
        catch { /* diagnostics are best-effort */ }
    }

    private static string GetSortText(string label) =>
        label.StartsWith("__") ? "2" + label :
        label.StartsWith("_")  ? "1" + label :
                                  "0" + label;

    private static BlazorMonaco.Languages.CompletionItemKind MapKind(string jediType) => jediType switch
    {
        "function"  => BlazorMonaco.Languages.CompletionItemKind.Function,
        "class"     => BlazorMonaco.Languages.CompletionItemKind.Class,
        "module"    => BlazorMonaco.Languages.CompletionItemKind.Module,
        "instance"  => BlazorMonaco.Languages.CompletionItemKind.Variable,
        "keyword"   => BlazorMonaco.Languages.CompletionItemKind.Keyword,
        "statement" => BlazorMonaco.Languages.CompletionItemKind.Variable,
        "import"    => BlazorMonaco.Languages.CompletionItemKind.Module,
        "param"     => BlazorMonaco.Languages.CompletionItemKind.Variable,
        "property"  => BlazorMonaco.Languages.CompletionItemKind.Property,
        "path"      => BlazorMonaco.Languages.CompletionItemKind.File,
        _           => BlazorMonaco.Languages.CompletionItemKind.Text,
    };

    public async ValueTask DisposeAsync()
    {
        _diagCts?.Cancel();
        _diagCts?.Dispose();
    }
}
