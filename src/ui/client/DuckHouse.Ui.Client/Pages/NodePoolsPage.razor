@page "/node-pools"

@using DuckHouse.Ui.Shared.Orchestration
@using DuckHouse.Ui.Shared.Environment
@using DuckHouse.Ui.Shared.Nodes
@using DuckHouse.Core.Nodes
@using DuckHouse.Ui.Client.Validation
@using DuckHouse.Ui.Shared.Packages
@inject INodePoolService NodePoolService
@inject IInteractivePoolService InteractivePoolService
@inject INodeService NodeService
@inject IWheelPackageService WheelPackageService
@inject IEnvironmentService EnvironmentService

<PageTitle>Node Pools — DuckHouse</PageTitle>

<Flex Justify="FlexJustify.FlexStart" Align="FlexAlign.Center" Style="margin-bottom: 24px;" Gap="FlexGap.Small">
    <Space Align="SpaceAlign.End" Size="SpaceSize.Middle">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.Cluster" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">Node pool configurations</h2>
        </SpaceItem>
    </Space>
</Flex>

@if (!string.IsNullOrEmpty(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
            Style="margin-bottom: 16px;" />
}

<Tabs ActiveKey="@_activeTab" OnChange="key => _activeTab = key">
    <TabPane Key="interactive" Tab="Interactive">
        <Flex Align="FlexAlign.Center" Justify="FlexJustify.End" Style="margin-bottom: 12px;">
            <Space Size="SpaceSize.Small">
                <SpaceItem>
                    <Button OnClick="LoadAsync" Loading="_loading">
                        <Icon Type="@IconType.Outline.Reload" /> Refresh
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" OnClick="StartCreate">
                        <Icon Type="@IconType.Outline.Plus" /> New interactive node pool
                    </Button>
                </SpaceItem>
            </Space>
        </Flex>
        <Spin Spinning="_loading">
            @if (_interactivePools.Count == 0 && !_loading)
            {
                <p><Text Type="TextElementType.Secondary">No interactive node pools. Create one to connect from Notebook and Query pages.</Text></p>
            }
            else
            {
                <Table TItem="InteractivePoolDto" DataSource="_interactivePools" Size="@TableSize.Small">
                    <PropertyColumn Property="c => c.Name" Title="Name" Sortable />
                    <PropertyColumn Property="c => c.VmSize" Title="VM size" />
                    <PropertyColumn Property="c => c.KernelIdleTimeout" Title="Kernel idle">
                        @(context.KernelIdleTimeout.HasValue ? $"{context.KernelIdleTimeout.Value.TotalMinutes:F0} min" : "Default")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.NodeIdleTimeout" Title="Node idle">
                        @(context.NodeIdleTimeout.HasValue ? $"{context.NodeIdleTimeout.Value.TotalMinutes:F0} min" : "Default")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.Description" Title="Description">
                        @(context.Description ?? "—")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.NodeState" Title="State">
                        @if (context.NodeState.HasValue)
                        {
                            <Tag Color="@NodeStateTagColor(context.NodeState.Value)">@context.NodeState.Value</Tag>
                        }
                        else
                        {
                            <Tag Color="@("default")">Idle</Tag>
                        }
                    </PropertyColumn>
                    <ActionColumn Title="Actions">
                        <Space>
                            @{
                                var poolForEdit = _jobAndInteractivePools.FirstOrDefault(p => p.Id == context.Id);
                            }
                            <SpaceItem>
                                <Button Size="@ButtonSize.Small"
                                        Disabled="@(poolForEdit is null)"
                                        OnClick="() => StartEdit(poolForEdit!)">
                                    <Icon Type="@IconType.Outline.Edit" />
                                </Button>
                            </SpaceItem>
                            <SpaceItem>
                                <Popconfirm Title="@($"Delete pool '{context.Name}'?")"
                                            OnConfirm="() => DeleteInteractiveAsync(context)">
                                    <Button Danger Size="@ButtonSize.Small">
                                        <Icon Type="@IconType.Outline.Delete" />
                                    </Button>
                                </Popconfirm>
                            </SpaceItem>
                            @if (!context.NodeState.HasValue || context.NodeState.Value == NodeState.Failure)
                            {
                                var poolName = context.Name;
                                <SpaceItem>
                                    <Button Size="@ButtonSize.Small"
                                            Loading="@(_startingPool == poolName)"
                                            Disabled="@(_startingPool is not null || _busyNode is not null)"
                                            OnClick="() => StartInteractiveNodeAsync(poolName)">
                                        <Icon Type="@IconType.Outline.PlayCircle" /> Start
                                    </Button>
                                </SpaceItem>
                            }
                            @if (context.NodeState is NodeState.Running or NodeState.Creating)
                            {
                                var nodeName = context.NodeName;
                                <SpaceItem>
                                    <Popconfirm Title="@($"Stop the node pool '{context.Name}'? The pool config will remain.")"
                                                OnConfirm="() => RemoveInteractiveNodeAsync(nodeName)">
                                        <Button Size="@ButtonSize.Small"
                                                Loading="@(_busyNode == nodeName)"
                                                Disabled="@(_busyNode is not null || _startingPool is not null)">
                                            <Icon Type="@IconType.Outline.Poweroff" /> Stop
                                        </Button>
                                    </Popconfirm>
                                </SpaceItem>
                            }
                        </Space>
                    </ActionColumn>
                </Table>
            }
        </Spin>
    </TabPane>
    <TabPane Key="job" Tab="Job">
        <Flex Align="FlexAlign.Center" Justify="FlexJustify.End" Style="margin-bottom: 12px;">
            <Space Size="SpaceSize.Small">
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" OnClick="StartCreate">
                        <Icon Type="@IconType.Outline.Plus" /> New job node pool
                    </Button>
                </SpaceItem>
            </Space>
        </Flex>
        <Spin Spinning="_loading">
            @if (_jobPools.Count == 0 && !_loading)
            {
                <p><Text Type="TextElementType.Secondary">No job node pools.</Text></p>
            }
            else
            {
                <Table TItem="NodePoolConfigDto" DataSource="_jobPools" Size="@TableSize.Small">
                    <PropertyColumn Property="c => c.Name" Title="Name" Sortable />
                    <PropertyColumn Property="c => c.VmSize" Title="VM size" />
                    <PropertyColumn Property="c => c.KernelIdleTimeout" Title="Kernel idle timeout">
                        @(context.KernelIdleTimeout.HasValue ? $"{context.KernelIdleTimeout.Value.TotalMinutes:F0} min" : "Default")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.NodeIdleTimeout" Title="Node idle timeout">
                        @(context.NodeIdleTimeout.HasValue ? $"{context.NodeIdleTimeout.Value.TotalMinutes:F0} min" : "Default")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.Description" Title="Description">
                        @(context.Description ?? "—")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.UpdatedAt" Title="Updated" Sortable>
                        @context.UpdatedAt.ToString("yyyy-MM-dd")
                    </PropertyColumn>
                    <ActionColumn Title="Actions">
                        <Space>
                            <SpaceItem>
                                <Button Size="@ButtonSize.Small" OnClick="() => StartEdit(context)">
                                    <Icon Type="@IconType.Outline.Edit" />
                                </Button>
                            </SpaceItem>
                            <SpaceItem>
                                <Popconfirm Title="@($"Delete node pool '{context.Name}'?")"
                                            OnConfirm="() => DeleteAsync(context)">
                                    <Button Danger Size="@ButtonSize.Small">
                                        <Icon Type="@IconType.Outline.Delete" />
                                    </Button>
                                </Popconfirm>
                            </SpaceItem>
                        </Space>
                    </ActionColumn>
                </Table>
            }
        </Spin>
    </TabPane>
</Tabs>

<Drawer Closable="true" @bind-Visible="_showDrawer" Placement="DrawerPlacement.Right"
        Width="480" Title="@(_editTarget is null ? "New node pool" : "Edit node pool")"
        OnClose="() => _showDrawer = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Name</label>
            <Input @bind-Value="_formName" Placeholder="analyticsnode"
                    Status="@(ValidationHelper.ValidateNodePoolName(_formName) is not null ? "error" : "")" />
            @if (ValidationHelper.ValidateNodePoolName(_formName) is { } poolNameErr)
            {
                <div style="color: #ff4d4f; font-size: 12px; margin-top: 2px;">@poolNameErr</div>
            }
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">VM Size</label>
            <Input @bind-Value="_formVmSize" Placeholder="Standard_D4as_v5" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Kernel idle timeout (minutes)</label>
            <AntDesign.InputNumber @bind-Value="_formKernelIdleMin" Min="0" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Node idle timeout (minutes)</label>
            <AntDesign.InputNumber @bind-Value="_formNodeIdleMin" Min="0" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Kernel requirements (pip)</label>
            <TextArea @bind-Value="_formKernelReqs" Rows="3" Placeholder="@("scipy>=1.14\nscikit-learn>=1.6")" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Wheel packages</label>
            <Select Mode="SelectMode.Multiple"
                    TItem="WheelPackageDto"
                    TItemValue="Guid"
                    DataSource="_availablePackages"
                    LabelName="@nameof(WheelPackageDto.Name)"
                    ValueName="@nameof(WheelPackageDto.Id)"
                    @bind-Values="_formWheelPackageIds"
                    Placeholder="Select packages to install"
                    Style="width: 100%;" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Environment variables</label>
            <Select Mode="SelectMode.Multiple"
                    TItem="EnvironmentVariableDto"
                    TItemValue="Guid"
                    DataSource="_availableEnvVars"
                    LabelName="@nameof(EnvironmentVariableDto.Key)"
                    ValueName="@nameof(EnvironmentVariableDto.Id)"
                    @bind-Values="_formEnvVarIds"
                    Placeholder="Select environment variables"
                    Style="width: 100%;" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Secrets</label>
            <Select Mode="SelectMode.Multiple"
                    TItem="SecretDto"
                    TItemValue="Guid"
                    DataSource="_availableSecrets"
                    LabelName="@nameof(SecretDto.Key)"
                    ValueName="@nameof(SecretDto.Id)"
                    @bind-Values="_formSecretIds"
                    Placeholder="Select secrets"
                    Style="width: 100%;" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Description</label>
            <TextArea @bind-Value="_formDescription" Rows="2" />
        </div>
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showDrawer = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmSave" Loading="_saving"
                Disabled="@(string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formVmSize) || ValidationHelper.ValidateNodePoolName(_formName) is not null)">
            Save
        </Button>
    </div>
</Drawer>

@code {
    private IReadOnlyList<NodePoolConfigDto> _jobAndInteractivePools = [];
    private IReadOnlyList<InteractivePoolDto> _interactivePools = [];
    private bool _loading = true;
    private string? _error;
    private string _activeTab = "interactive";
    private string? _busyNode;
    private string? _startingPool;

    private List<NodePoolConfigDto> _jobPools => _jobAndInteractivePools
        .Where(p => p.PoolType == "Job").ToList();

    // Drawer state
    private bool _showDrawer;
    private bool _saving;
    private NodePoolConfigDto? _editTarget;
    private string _formName = "";
    private string _formVmSize = "";
    private int _formKernelIdleMin;
    private int _formNodeIdleMin;
    private string? _formKernelReqs;
    private string? _formDescription;
    private IEnumerable<Guid> _formWheelPackageIds = [];
    private IEnumerable<Guid> _formEnvVarIds = [];
    private IEnumerable<Guid> _formSecretIds = [];

    private List<WheelPackageDto> _availablePackages = [];
    private List<EnvironmentVariableDto> _availableEnvVars = [];
    private List<SecretDto> _availableSecrets = [];

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadAsync(), LoadPackagesAsync(), LoadEnvVarsAsync(), LoadSecretsAsync());
    }

    private async Task LoadPackagesAsync()
    {
        try { _availablePackages = [.. await WheelPackageService.GetPackagesAsync()]; }
        catch { /* non-fatal */ }
    }

    private async Task LoadEnvVarsAsync()
    {
        try { _availableEnvVars = [.. await EnvironmentService.GetVariablesAsync()]; }
        catch { /* non-fatal */ }
    }

    private async Task LoadSecretsAsync()
    {
        try { _availableSecrets = [.. await EnvironmentService.GetSecretsAsync()]; }
        catch { /* non-fatal */ }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var allTask = NodePoolService.GetNodePoolsAsync();
            var interactiveTask = InteractivePoolService.GetInteractivePoolsAsync();
            await Task.WhenAll(allTask, interactiveTask);
            _jobAndInteractivePools = await allTask;
            _interactivePools = [.. await interactiveTask];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load node pools: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartCreate()
    {
        _editTarget = null;
        _formName = "";
        _formVmSize = "";
        _formKernelIdleMin = 0;
        _formNodeIdleMin = 0;
        _formKernelReqs = null;
        _formDescription = null;
        _formWheelPackageIds = [];
        _formEnvVarIds = [];
        _formSecretIds = [];
        _showDrawer = true;
    }

    private void StartEdit(NodePoolConfigDto pool)
    {
        _editTarget = pool;
        _formName = pool.Name;
        _formVmSize = pool.VmSize;
        _formKernelIdleMin = (int)(pool.KernelIdleTimeout?.TotalMinutes ?? 0);
        _formNodeIdleMin = (int)(pool.NodeIdleTimeout?.TotalMinutes ?? 0);
        _formKernelReqs = pool.KernelRequirements;
        _formDescription = pool.Description;
        _formWheelPackageIds = pool.WheelPackageIds ?? [];
        _formEnvVarIds = pool.EnvironmentVariableIds ?? [];
        _formSecretIds = pool.SecretIds ?? [];
        _showDrawer = true;
    }

    private async Task ConfirmSave()
    {
        if (string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formVmSize)) return;

        var kernelTimeout = _formKernelIdleMin > 0 ? TimeSpan.FromMinutes(_formKernelIdleMin) : (TimeSpan?)null;
        var nodeTimeout = _formNodeIdleMin > 0 ? TimeSpan.FromMinutes(_formNodeIdleMin) : (TimeSpan?)null;

        _saving = true;
        try
        {
            if (_editTarget is null)
            {
                var poolType = _activeTab == "interactive" ? "Interactive" : "Job";
                await NodePoolService.CreateNodePoolAsync(new CreateNodePoolRequest(
                    _formName.Trim(), poolType, _formVmSize.Trim(), kernelTimeout, nodeTimeout,
                    _formKernelReqs?.Trim(), _formDescription?.Trim(),
                    _formWheelPackageIds.Any() ? [.. _formWheelPackageIds] : null,
                    _formEnvVarIds.Any() ? [.. _formEnvVarIds] : null,
                    _formSecretIds.Any() ? [.. _formSecretIds] : null));
            }
            else
            {
                await NodePoolService.UpdateNodePoolAsync(_editTarget.Id, new UpdateNodePoolRequest(
                    _formName.Trim(), _formVmSize.Trim(), kernelTimeout, nodeTimeout,
                    _formKernelReqs?.Trim(), _formDescription?.Trim(),
                    _formWheelPackageIds.Any() ? [.. _formWheelPackageIds] : null,
                    _formEnvVarIds.Any() ? [.. _formEnvVarIds] : null,
                    _formSecretIds.Any() ? [.. _formSecretIds] : null));
            }
            _showDrawer = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to save: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync(NodePoolConfigDto pool)
    {
        try
        {
            await NodePoolService.DeleteNodePoolAsync(pool.Id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete: {ex.Message}";
        }
    }

    private async Task DeleteInteractiveAsync(InteractivePoolDto pool)
    {
        var dto = _jobAndInteractivePools.FirstOrDefault(p => p.Id == pool.Id);
        if (dto is null) return;
        await DeleteAsync(dto);
    }

    private async Task StartInteractiveNodeAsync(string poolName)
    {
        _startingPool = poolName;
        _error = null;
        try
        {
            await InteractivePoolService.EnsureNodeAsync(poolName);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to start node: {ex.Message}";
        }
        finally
        {
            _startingPool = null;
        }
    }

    private async Task RemoveInteractiveNodeAsync(string nodeName)
    {
        _busyNode = nodeName;
        _error = null;
        try
        {
            await NodeService.RemoveNodeAsync(nodeName);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to remove node: {ex.Message}";
        }
        finally
        {
            _busyNode = null;
        }
    }

    private static string NodeStateTagColor(NodeState state) => state switch
    {
        NodeState.Running => "success",
        NodeState.Failure => "error",
        _ => "warning"
    };
}
