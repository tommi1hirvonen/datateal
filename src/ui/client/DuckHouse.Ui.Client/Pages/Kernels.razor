@page "/nodes/{Name}/kernels"

@using DuckHouse.Core.Kernels
@inject IKernelService KernelService
@inject NavigationManager Navigation

<PageTitle>Kernels — DuckHouse</PageTitle>

<Breadcrumb Style="margin-bottom: 12px;">
    <BreadcrumbItem OnClick="@(() => Navigation.NavigateTo("/nodes"))" Href="">Nodes</BreadcrumbItem>
    <BreadcrumbItem>@Name — Kernels</BreadcrumbItem>
</Breadcrumb>

<Flex Justify="@("space-between")" Align="FlexAlign.Center" Style="margin-bottom: 24px;">
    <Space Align="SpaceAlign.Center" Size="@("small")">
        <SpaceItem><SvgIcon Icon="LucideIcon.Cpu" /></SpaceItem>
        <SpaceItem><h2 style="margin: 0;">Kernels</h2></SpaceItem>
    </Space>
    <Space>
        <SpaceItem>
            <Button OnClick="LoadKernelsAsync" Disabled="@(_loading || _busy is not null)">
                <SvgIcon Icon="LucideIcon.RefreshCw" />
                Refresh
            </Button>
        </SpaceItem>
        <SpaceItem>
            <Button Type="ButtonType.Primary" Loading="_creating" Disabled="_creating"
                    OnClick="CreateKernelAsync">
                <SvgIcon Icon="LucideIcon.Plus" />
                New Kernel
            </Button>
        </SpaceItem>
    </Space>
</Flex>

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
}

@if (_loading)
{
    <Flex Justify="@("center")" Style="padding: 40px 0;">
        <Spin />
    </Flex>
}
else if (_kernels.Count == 0)
{
    <p style="color: var(--ant-color-text-secondary);">No kernels running on <strong>@Name</strong>. Create one to get started.</p>
}
else
{
    <Table TItem="KernelInfo" DataSource="@_kernels" Bordered>
        <PropertyColumn Property="k => k.Id" Title="ID">
            <span style="font-family: monospace; font-size: 0.875rem;">@context.Id</span>
        </PropertyColumn>
        <PropertyColumn Property="k => k.Status" Title="Status">
            <Tag Color="@StatusTagColor(context.Status)">@context.Status</Tag>
        </PropertyColumn>
        <PropertyColumn Property="k => k.CreatedAt" Title="Created">
            <span style="color: var(--ant-color-text-secondary); font-size: 0.875rem;">@context.CreatedAt.LocalDateTime.ToString("g")</span>
        </PropertyColumn>
        <PropertyColumn Property="k => k.LastActivity" Title="Last Activity">
            <span style="color: var(--ant-color-text-secondary); font-size: 0.875rem;">@context.LastActivity.LocalDateTime.ToString("g")</span>
        </PropertyColumn>
        <ActionColumn Title="Actions">
            @{
                var id = context.Id;
                var busy = _busy == id;
                var isDead = context.Status == KernelStatus.Dead;
            }
            <Space>
                <SpaceItem>
                    <Button Size="ButtonSize.Small" Disabled="@isDead"
                            OnClick="@(() => Navigation.NavigateTo($"nodes/{Name}/kernels/{id}"))">
                        <SvgIcon Icon="LucideIcon.ExternalLink" />
                        Open
                    </Button>
                </SpaceItem>
                @if (!isDead)
                {
                    <SpaceItem>
                        <Button Size="ButtonSize.Small" Type="ButtonType.Primary"
                                Loading="@busy" Disabled="@busy"
                                OnClick="@(() => RestartKernelAsync(id))">
                            <SvgIcon Icon="LucideIcon.RotateCw" />
                        </Button>
                    </SpaceItem>
                }
                @if (context.Status == KernelStatus.Busy)
                {
                    <SpaceItem>
                        <Button Size="ButtonSize.Small"
                                Loading="@busy" Disabled="@busy"
                                OnClick="@(() => InterruptKernelAsync(id))">
                            <SvgIcon Icon="LucideIcon.CircleStop" />
                        </Button>
                    </SpaceItem>
                }
                <SpaceItem>
                    <Popconfirm Title="@($"Are you sure you want to delete kernel '{id}'?")"
                                OkText="Delete"
                                CancelText="Cancel"
                                OkType="ButtonType.Primary"
                                OkButtonProps="new ButtonProps { Danger = true }"
                                OnConfirm="@(() => DeleteKernelAsync(id))">
                        <Button Size="ButtonSize.Small" Danger Type="ButtonType.Primary"
                                Loading="@busy" Disabled="@(busy || (_busy is not null && _busy != id))">
                            <SvgIcon Icon="LucideIcon.Trash2" />
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
}

@code {
    [Parameter] public string Name { get; set; } = "";

    private List<KernelInfo> _kernels = [];
    private bool _loading = true;
    private string? _error;
    private string? _busy;
    private bool _creating;

    protected override async Task OnInitializedAsync() => await LoadKernelsAsync();

    private async Task LoadKernelsAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _kernels = [.. await KernelService.GetKernelsAsync(Name)];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load kernels: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateKernelAsync()
    {
        _creating = true;
        _error = null;
        try
        {
            var kernel = await KernelService.CreateKernelAsync(Name);
            _kernels.Add(kernel);
        }
        catch (Exception ex)
        {
            _error = $"Failed to create kernel: {ex.Message}";
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task RestartKernelAsync(string kernelId) =>
        await RunActionAsync(kernelId, async (n, k, ct) => await KernelService.RestartKernelAsync(n, k, ct), "restart");

    private async Task InterruptKernelAsync(string kernelId) =>
        await RunActionAsync(kernelId, KernelService.InterruptKernelAsync, "interrupt");

    private async Task DeleteKernelAsync(string kernelId) =>
        await RunActionAsync(kernelId, KernelService.DeleteKernelAsync, "delete");

    private async Task RunActionAsync(string kernelId, Func<string, string, CancellationToken, Task> action, string verb)
    {
        _busy = kernelId;
        _error = null;
        try
        {
            await action(Name, kernelId, CancellationToken.None);
            await LoadKernelsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to {verb} kernel '{kernelId}': {ex.Message}";
        }
        finally
        {
            _busy = null;
        }
    }

    private static string StatusTagColor(KernelStatus status) => status switch
    {
        KernelStatus.Idle                                     => "success",
        KernelStatus.Busy                                     => "warning",
        KernelStatus.Starting or KernelStatus.Restarting     => "processing",
        KernelStatus.Dead                                     => "error",
        _                                                     => "default"
    };
}

