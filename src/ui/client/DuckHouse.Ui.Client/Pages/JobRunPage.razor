@page "/runs/{Id:guid}"
@attribute [Authorize(Policy = AuthPolicy.JobRead)]

@using DuckHouse.Ui.Shared.Orchestration
@using DuckHouse.Core.Orchestration
@inject IJobService JobService
@inject NavigationManager Navigation

<PageTitle>Job Run — DuckHouse</PageTitle>

<div style="padding: 24px;">
    @if (!string.IsNullOrEmpty(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
               Style="margin-bottom: 16px;" />
    }

    <Spin Spinning="_loading">
        @if (_run is not null)
        {
            <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 16px; flex-wrap: wrap; gap: 8px;">
                <Space Align="SpaceAlign.Center" Size="SpaceSize.Small">
                    <SpaceItem>
                        <Button OnClick="@(() => Navigation.NavigateTo(_run.JobId.HasValue ? $"/jobs/{_run.JobId}" : "/jobs"))">
                            <Icon Type="@IconType.Outline.ArrowLeft" /> Back to job
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <h2 style="margin: 0;">Run: @_run.JobName</h2>
                    </SpaceItem>
                    <SpaceItem>
                        <Tag Color="@GetStatusColor(_run.Status)">@_run.Status</Tag>
                    </SpaceItem>
                </Space>
                <Space>
                    @if (_run.Status is JobRunStatus.Running or JobRunStatus.Pending)
                    {
                        <AuthorizeView Policy="@AuthPolicy.JobOperate">
                            <SpaceItem>
                                <Popconfirm Title="Cancel this run?" OnConfirm="CancelAsync">
                                    <Button Danger>
                                        <Icon Type="@IconType.Outline.Stop" /> Cancel
                                    </Button>
                                </Popconfirm>
                            </SpaceItem>
                        </AuthorizeView>
                        <SpaceItem>
                            <Button OnClick="RefreshAsync">
                                <Icon Type="@IconType.Outline.Reload" /> Refresh
                            </Button>
                        </SpaceItem>
                    }
                </Space>
            </Flex>

            <Descriptions Bordered="false" Size="@DescriptionsSize.Small" Style="margin-bottom: 16px;">
                <DescriptionsItem Title="Trigger">@_run.Trigger</DescriptionsItem>
                <DescriptionsItem Title="Created">@_run.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</DescriptionsItem>
                @if (_run.StartedAt.HasValue)
                {
                    <DescriptionsItem Title="Started">@_run.StartedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</DescriptionsItem>
                }
                @if (_run.CompletedAt.HasValue)
                {
                    <DescriptionsItem Title="Completed">@_run.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</DescriptionsItem>
                }
                @if (_run.StartedAt.HasValue && _run.CompletedAt.HasValue)
                {
                    <DescriptionsItem Title="Duration">@FormatDuration((_run.CompletedAt.Value - _run.StartedAt.Value).TotalMilliseconds)</DescriptionsItem>
                }
                @if (_run.Parameters is { Count: > 0 })
                {
                    <DescriptionsItem Title="Parameters" Span="3">
                        @foreach (var kv in _run.Parameters)
                        {
                            <Tag Style="margin-bottom: 4px; font-family: monospace;">@kv.Key = @kv.Value</Tag>
                        }
                    </DescriptionsItem>
                }
            </Descriptions>

            <h3>Tasks</h3>
            <Table TItem="TaskRunDto" DataSource="SortedTaskRuns" Size="@TableSize.Small"
                   PageSize="int.MaxValue" HidePagination="true">
                <PropertyColumn Property="c => c.TaskName" Title="Task">
                    @context.TaskName
                </PropertyColumn>
                <PropertyColumn Property="c => c.TaskType" Title="Type">
                    <Tag Color="@GetTaskTypeColor(context.TaskType)">@context.TaskType</Tag>
                </PropertyColumn>
                <PropertyColumn Property="c => c.Status" Title="Status">
                    <Tag Color="@GetStatusColor(context.Status)">@context.Status</Tag>
                </PropertyColumn>
                <PropertyColumn Property="c => c.AttemptNumber" Title="Attempt" />
                <PropertyColumn Property="c => c.DurationMs" Title="Duration">
                    @(context.DurationMs.HasValue ? FormatDuration(context.DurationMs.Value) : "—")
                </PropertyColumn>
                <PropertyColumn Property="c => c.NodeName" Title="Node">
                    @(context.NodeName ?? "—")
                </PropertyColumn>
                <PropertyColumn Property="c => c.Parameters" Title="Parameters">
                    @if (context.Parameters is { Count: > 0 })
                    {
                        <Popover ContentTemplate="@ParametersContent(context.Parameters)" Trigger="@(new AntDesign.Trigger[] { AntDesign.Trigger.Click })">
                            <Tag Style="cursor:pointer;">@context.Parameters.Count param(s)</Tag>
                        </Popover>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </PropertyColumn>
                <PropertyColumn Property="c => c.ErrorMessage" Title="Error">
                    @if (!string.IsNullOrEmpty(context.ErrorMessage))
                    {
                        <span style="color: #ff4d4f; font-size: 12px;" title="@context.ErrorMessage">
                            @(context.ErrorMessage.Length > 60
                                ? context.ErrorMessage[..60] + "..."
                                : context.ErrorMessage)
                        </span>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </PropertyColumn>
                <ActionColumn Title="">
                    @if (context.TaskType == TaskType.Notebook)
                    {
                        <Button Size="@ButtonSize.Small"
                                OnClick="@(() => Navigation.NavigateTo($"/runs/{Id}/tasks/{context.Id}/notebook"))">
                            <Icon Type="@IconType.Outline.FileText" /> Notebook
                        </Button>
                    }
                    else if (context.TaskType == TaskType.SqlQuery)
                    {
                        <Button Size="@ButtonSize.Small"
                                OnClick="@(() => Navigation.NavigateTo($"/runs/{Id}/tasks/{context.Id}/query"))">
                            <Icon Type="@IconType.Outline.Code" /> Query
                        </Button>
                    }
                </ActionColumn>
            </Table>
        }
    </Spin>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private JobRunDetail? _run;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _run = await JobService.GetRunAsync(Id);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load run: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private IEnumerable<TaskRunDto> SortedTaskRuns
    {
        get
        {
            if (_run is null) return [];
            var tasks = _run.TaskRuns;
            if (tasks.Count <= 1) return tasks;

            var topoRank = BuildTopoRanks(tasks);
            return tasks
                .OrderBy(t => t.StartedAt ?? DateTime.MaxValue)
                .ThenBy(t => topoRank.GetValueOrDefault(t.TaskName, -1))
                .ThenBy(t => t.TaskName, NaturalSortComparer.OrdinalIgnoreCase);
        }
    }

    private static Dictionary<string, int> BuildTopoRanks(List<TaskRunDto> tasks)
    {
        if (tasks.Count == 0) return [];
        var nameComparer = Comparer<TaskRunDto>.Create((a, b) =>
            NaturalSortComparer.OrdinalIgnoreCase.Compare(a.TaskName, b.TaskName));
        var comparer = new TopologicalComparer<TaskRunDto, string>(
            tasks,
            t => t?.TaskName ?? "",
            t => t.DependencyTaskNames,
            nameComparer);
        var ordered = tasks.OrderBy(t => t, comparer).ToList();
        var rank = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        for (int i = 0; i < ordered.Count; i++)
            rank[ordered[i].TaskName] = i;
        return rank;
    }

    private async Task RefreshAsync() => await LoadAsync();

    private async Task CancelAsync()
    {
        try
        {
            await JobService.CancelRunAsync(Id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to cancel: {ex.Message}";
        }
    }

    private static string GetStatusColor(JobRunStatus status) => status switch
    {
        JobRunStatus.Succeeded => "green",
        JobRunStatus.Failed => "red",
        JobRunStatus.Running => "blue",
        JobRunStatus.Cancelled => "orange",
        _ => "default",
    };

    private static string GetStatusColor(string status) => status.ToLowerInvariant() switch
    {
        "succeeded" => "green",
        "failed" => "red",
        "running" => "blue",
        "pending" or "waiting" => "default",
        "cancelled" => "orange",
        "skipped" => "default",
        "retrying" => "gold",
        _ => "default",
    };

    private static RenderFragment ParametersContent(Dictionary<string, string> parameters) =>
        @<div style="font-family: monospace; font-size: 12px; min-width: 160px;">
            @foreach (var kv in parameters)
            {
                <div><strong>@kv.Key</strong> = @kv.Value</div>
            }
        </div>;

    private static string GetTaskTypeColor(TaskType taskType) => taskType switch
    {
        TaskType.Notebook => "blue",
        TaskType.SqlQuery => "purple",
        TaskType.SubJob => "orange",
        _ => "default",
    };

    private static string FormatDuration(double ms)
    {
        double s = ms / 1000.0;
        if (s < 10.0) return $"{s:F1}s";
        int total = (int)s;
        if (total < 60) return $"{total}s";
        return $"{total / 60}m {total % 60}s";
    }
}
