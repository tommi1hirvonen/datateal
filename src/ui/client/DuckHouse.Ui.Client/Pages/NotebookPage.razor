@page "/notebook"
@page "/notebook/{Id:guid}"

@using DuckHouse.Core.Catalogs
@using DuckHouse.Ui.Client.Notebook
@using DuckHouse.Core.Kernels
@using DuckHouse.Core.Nodes
@using DuckHouse.Ui.Shared.Kernels
@using DuckHouse.Ui.Shared.Workspace
@using DuckHouse.Ui.Shared.Catalogs
@using DuckHouse.Ui.Shared.Nodes
@inject IKernelService KernelService
@inject INodeService NodeService
@inject IInteractivePoolService InteractivePoolService
@inject IWorkspaceService WorkspaceService
@inject ICatalogService CatalogService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Notebook — DuckHouse</PageTitle>

<div class="cp-layout">
    <CatalogSidePanel AllCatalogs="@_allCatalogs"
                    SelectedCatalogNames="@_selectedCatalogNames"
                    SelectedCatalogNamesChanged="@(v => _selectedCatalogNames = v)"
                    OnCatalogSelectionChanged="OnCatalogSelectionChanged"
                    CatalogSetupRunning="@_catalog.SetupRunning" />
    <div class="cp-main" style="margin-left: 24px; overflow-y: auto;">

        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap; gap: 8px;">
            <Space Align="SpaceAlign.End" Size="SpaceSize.Middle">
                <SpaceItem>
                    <Icon Height="24px" Width="24px" Type="@IconType.Outline.FileText" />
                </SpaceItem>
                <SpaceItem>
                    <h2 style="margin: 0;">
                        @if (_editingTitle)
                        {
                            <Input Style="width: 30ch; font-size: inherit;"
                                @bind-Value="_editingTitleValue"
                                OnPressEnter="@(_ => CommitTitleEdit())"
                                OnBlur="@(_ => CommitTitleEdit())" />
                        }
                        else
                        {
                            <span style="cursor: pointer;" @onclick="StartEditTitle">
                                @_notebook.Title@(_notebook.IsDirty ? " *" : "")
                            </span>
                        }
                    </h2>
                </SpaceItem>
            </Space>

            @* File toolbar *@
            <Space Size="SpaceSize.Small" Style="flex-wrap: wrap;">
                <SpaceItem>
                    <Button OnClick="@(() => Navigation.NavigateTo("/workspace"))" Icon="@IconType.Outline.FolderOpen">
                        Browse workspace
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button OnClick="OpenFileDialogAsync" Icon="@IconType.Outline.Upload">
                        Open from file
                    </Button>
                    <InputFile @ref="_fileInput" style="display:none;" accept=".ipynb" OnChange="OnFileSelectedAsync" />
                </SpaceItem>
                @if (_workspaceNotebookId.HasValue)
                {
                    <SpaceItem>
                        <Button Disabled="@(!_notebook.IsDirty)" Icon="@IconType.Outline.Save" OnClick="SaveToWorkspaceAsync">
                            Save
                        </Button>
                    </SpaceItem>
                }
                else
                {
                    <SpaceItem>
                        <Button Disabled="@(!_notebook.IsDirty)" Icon="@IconType.Outline.CloudUpload" OnClick="OpenFolderPickerAsync">
                            Save to workspace
                        </Button>
                    </SpaceItem>
                }
                <SpaceItem>
                    <Button Icon="@IconType.Outline.Download" OnClick="ExportFileAsync">
                        Export
                    </Button>
                </SpaceItem>
                <SpaceItem><Divider Type="DividerType.Vertical" /></SpaceItem>
                <SpaceItem>
                    @if (AnyExecuting)
                    {
                        <Button Disabled="@(!HasKernel || !AnyExecuting)"
                                Icon="@IconType.Outline.Loading"
                                OnClick="InterruptAsync">
                            Interrupt
                        </Button>
                    }
                    else
                    {
                        <Button Type="ButtonType.Primary"
                                Disabled="@(!HasKernel)"
                                Icon="@IconType.Outline.PlayCircle"
                                OnClick="RunAllAsync">
                            Run all
                        </Button>
                    }
                </SpaceItem>
                <SpaceItem>
                    <Button Disabled="@(!_notebook.Cells.Any())"
                            Icon="@IconType.Outline.Clear"
                            OnClick="ClearAllOutputs">
                        Clear outputs
                    </Button>
                </SpaceItem>
            </Space>
        </Flex>

        @* Workspace breadcrumb — only visible when the notebook is saved in the workspace *@
        @if (_workspaceNotebookId.HasValue && _breadcrumbs.Count > 0)
        {
            <Breadcrumb Style="margin-bottom: 8px;">
                @foreach (var crumb in _breadcrumbs)
                {
                    <BreadcrumbItem>
                        <a @onclick="() => NavigateToWorkspace(crumb.Id)" @onclick:preventDefault style="cursor: pointer;">
                            @crumb.Name
                        </a>
                    </BreadcrumbItem>
                }
                <BreadcrumbItem>@_notebook.Title</BreadcrumbItem>
            </Breadcrumb>
        }

        @* Kernel connection toolbar *@
        <Space Align="SpaceAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap;" Size="SpaceSize.Small">
            <SpaceItem>
                <Icon Type="@IconType.Outline.CloudServer" />
            </SpaceItem>
            <SpaceItem>
                <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">Pool:</Text>
            </SpaceItem>
            @if (_loadingPools)
            {
                <SpaceItem><Spin Size="SpinSize.Small" /></SpaceItem>
            }
            else
            {
                <SpaceItem>
                    <Select TItemValue="string"
                            TItem="InteractivePoolDto"
                            DataSource="@_pools.ToList()"
                            @bind-Value="@_poolName"
                            ItemValue="p => p.Name"
                            ItemLabel="p => p.Name"
                            Placeholder="— select pool —"
                            AllowClear
                            Disabled="@(_connecting || HasKernel)"
                            DropdownMatchSelectWidth="false"
                            Style="min-width: 150px;">
                        <ItemTemplate>
                            @{ var pool = (InteractivePoolDto)context!; }
                            <div style="line-height: 1.4;">
                                <div>
                                    <span>@pool.Name</span>
                                    @if (pool.NodeState.HasValue)
                                    {
                                        <Tag Color="@NodeStateTagColor(pool.NodeState.Value)" Style="margin-left: 6px; font-size: 0.75rem;">@pool.NodeState.Value</Tag>
                                    }
                                    else
                                    {
                                        <Tag Color="@("default")" Style="margin-left: 6px; font-size: 0.75rem;">Stopped</Tag>
                                    }
                                </div>
                                <div style="font-size: 11px; color: #888; margin-top: 1px;">@pool.VmSize</div>
                            </div>
                        </ItemTemplate>
                    </Select>
                </SpaceItem>
            }

            @if (!HasKernel)
            {
                <SpaceItem>
                    <Button Type="ButtonType.Primary" Size="ButtonSize.Small"
                            Disabled="@(string.IsNullOrEmpty(_poolName) || _connecting)"
                            Loading="_connecting"
                            Icon="@IconType.Outline.Api"
                            OnClick="ConnectAsync">
                        @(SelectedPool?.NodeState switch
                        {
                            NodeState.Running => "Connect",
                            NodeState.Creating => "Wait and connect",
                            _ => "Start and connect"
                        })
                    </Button>
                </SpaceItem>
            }
            else
            {
                <SpaceItem><Tag Color="@StatusTagColor(_kernel!.Status)">@_kernel!.Status</Tag></SpaceItem>
                <SpaceItem>
                    <Button Size="ButtonSize.Small"
                            Disabled="_disconnecting"
                            Loading="_disconnecting"
                            Icon="@IconType.Outline.Disconnect"
                            OnClick="DisconnectAsync">
                        Disconnect
                    </Button>
                </SpaceItem>
            }
        </Space>

        @* Catalog selector moved to the side panel *@

        @if (_error is not null)
        {
            <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
                OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
        }

        @* Cell list *@
        <AddCellBar OnAddPython="() => AddCell(0, NotebookCellType.Code, NotebookCellLanguage.Python)"
                    OnAddSql="() => AddCell(0, NotebookCellType.Code, NotebookCellLanguage.Sql)"
                    OnAddMarkdown="() => AddCell(0, NotebookCellType.Markdown)" />

        @for (int ci = 0; ci < _notebook.Cells.Count; ci++)
        {
            var cell = _notebook.Cells[ci];
            var index = ci; // capture for closure
            <NotebookCellView Cell="cell"
                            NodeName="@_nodeName"
                            KernelId="@_kernelId"
                            CanMoveUp="@(index > 0)"
                            CanMoveDown="@(index < _notebook.Cells.Count - 1)"
                            PriorContext="@(() => PriorContextFor(index))"
                            ProvideRunMagicCompletions="ProvideRunMagicCompletionsAsync"
                            OnExecute="@(() => _ = ExecuteCellAsync(cell))"
                            OnRunAbove="@(() => _ = RunAboveAsync(cell))"
                            OnRunBelow="@(() => _ = RunBelowAsync(cell))"
                            OnInterrupt="InterruptAsync"
                            OnDelete="@(() => DeleteCell(cell))"
                            OnMoveUp="@(() => MoveCell(index, -1))"
                            OnMoveDown="@(() => MoveCell(index, 1))"
                            OnCellChanged="@(() => _notebook.IsDirty = true)"
                            OnToggleParameters="@(() => ToggleParameterCell(cell))" />
            <AddCellBar OnAddPython="() => AddCell(index + 1, NotebookCellType.Code, NotebookCellLanguage.Python)"
                        OnAddSql="() => AddCell(index + 1, NotebookCellType.Code, NotebookCellLanguage.Sql)"
                        OnAddMarkdown="() => AddCell(index + 1, NotebookCellType.Markdown)" />
        }

        @if (_notebook.Cells.Count == 0)
        {
            <div style="font-style: italic; font-size: 0.875rem; text-align: center; padding: 32px 0;">
                <Text Type="TextElementType.Secondary">No cells yet — use the <strong>+</strong> buttons above to add your first cell.</Text>
            </div>
        }

        @* Folder picker modal — shown when saving to workspace for the first time *@
        <FolderPickerModal Visible="_showFolderPicker"
                        Title="@("Choose folder to save in")"
                        OkText="@("Save here")"
                        OnConfirm="ConfirmSaveToFolderAsync"
                        OnCancel="@(() => _showFolderPicker = false)" />

    </div>@* end .cp-main *@
</div>@* end .cp-layout *@

@code {
    [Parameter] public Guid Id { get; set; }

    private NotebookDocument _notebook = new();
    private Guid? _workspaceNotebookId;
    private Guid? _workspaceNotebookFolderId;
    private List<(Guid? Id, string Name)> _breadcrumbs = [];
    private string? _poolName;
    private string? _nodeName;
    private string? _kernelId;
    private KernelInfo? _kernel;
    private IReadOnlyList<InteractivePoolDto> _pools = [];
    private bool _loadingPools;
    private bool _connecting;
    private bool _disconnecting;
    private string? _error;
    private bool _editingTitle;
    private string _editingTitleValue = "";
    private InputFile _fileInput = default!;
    private CancellationTokenSource? _kernelPollingCts;
    private CancellationTokenSource? _connectCts;

    // Folder picker (first-time workspace save)
    private bool _showFolderPicker;

    // Catalogs
    private IReadOnlyList<CatalogDto> _allCatalogs = [];
    private IEnumerable<string> _selectedCatalogNames = [];
    private CatalogSession _catalog = default!;

    private bool HasKernel => !string.IsNullOrEmpty(_kernelId);
    private bool AnyExecuting => _notebook.Cells.Any(c => c.IsExecuting);
    private InteractivePoolDto? SelectedPool => _pools.FirstOrDefault(p => p.Name == _poolName);

    private void NavigateToWorkspace(Guid? folderId) =>
        Navigation.NavigateTo(folderId is null ? "/workspace" : $"/workspace?folder={folderId}");

    private void StartEditTitle()
    {
        _editingTitleValue = _notebook.Title;
        _editingTitle = true;
    }

    private void CommitTitleEdit()
    {
        var value = string.IsNullOrWhiteSpace(_editingTitleValue) ? "Untitled" : _editingTitleValue;
        if (value.Contains('/'))
        {
            _error = "Notebook title cannot contain '/'.";
            return;
        }
        _notebook.Title = value;
        _notebook.IsDirty = true;
        _editingTitle = false;
    }

    protected override async Task OnInitializedAsync()
    {
        _catalog = new CatalogSession(
            KernelService, CatalogService,
            () => _nodeName, () => _kernelId, () => _allCatalogs,
            StateHasChanged, msg => _error = msg);

        // Load notebook from workspace if an Id was provided
        if (Id != Guid.Empty)
        {
            try
            {
                var detail = await WorkspaceService.GetNotebookAsync(Id);
                if (detail is not null)
                {
                    _notebook = NotebookSerializer.Deserialize(detail.Content);
                    _notebook.IsDirty = false;
                    _workspaceNotebookId = detail.Id;
                    _workspaceNotebookFolderId = detail.FolderId;

                    if (detail.FolderId is not null)
                    {
                        var ancestors = await WorkspaceService.GetFolderAncestorsAsync(detail.FolderId.Value);
                        _breadcrumbs = [(null, "Workspace"), ..ancestors.Select(f => ((Guid?)f.Id, f.Name))];
                    }
                    else
                    {
                        _breadcrumbs = [(null, "Workspace")];
                    }
                }
                else
                {
                    _error = "Notebook not found in workspace.";
                }
            }
            catch (Exception ex)
            {
                _error = $"Failed to load notebook: {ex.Message}";
            }
        }

        // Generate a timestamped placeholder title for new (unsaved) notebooks
        if (Id == Guid.Empty)
        {
            _notebook.Title = $"Untitled {DateTime.Now:yyyy-MM-dd HH:mm:ss}";
            _notebook.IsDirty = true;
        }

        _loadingPools = true;
        try { _pools = await InteractivePoolService.GetInteractivePoolsAsync(); }
        catch (Exception ex) { _error = $"Failed to load pools: {ex.Message}"; }
        finally { _loadingPools = false; }

        // Load available catalogs
        try { _allCatalogs = await CatalogService.GetCatalogsAsync(); }
        catch { /* non-fatal — catalog list just stays empty */ }

        // Restore saved catalog selections
        if (_workspaceNotebookId.HasValue)
        {
            try
            {
                var savedNames = await CatalogService.GetWorkspaceItemCatalogsAsync(_workspaceNotebookId.Value);
                _selectedCatalogNames = savedNames;
            }
            catch { /* non-fatal */ }
        }

        // Restore last-used pool preference
        if (_workspaceNotebookId.HasValue)
        {
            try
            {
                var storedPool = await JS.InvokeAsync<string>("getItemNodePref", _workspaceNotebookId.Value.ToString());
                if (!string.IsNullOrEmpty(storedPool))
                {
                    var match = _pools.FirstOrDefault(p => p.Name == storedPool);
                    if (match is not null)
                    {
                        _poolName = match.Name;
                        if (match.NodeState == NodeState.Running)
                            _ = ConnectAsync();
                    }
                }
            }
            catch { /* JS interop failure is non-fatal */ }
        }
    }

    private async Task ConnectAsync()
    {
        if (string.IsNullOrEmpty(_poolName)) return;
        _connecting = true;
        _error = null;
        _connectCts = new CancellationTokenSource();
        var ct = _connectCts.Token;
        try
        {
            // Ensure the interactive pool's node exists (creates it if needed)
            var nodeInfo = await InteractivePoolService.EnsureNodeAsync(_poolName, ct);
            if (nodeInfo is null) throw new Exception("Interactive pool not found.");

            var nodeName = nodeInfo.Name;

            // Poll until running if the node is still being provisioned
            if (nodeInfo.State != NodeState.Running)
            {
                var deadline = DateTime.UtcNow.AddMinutes(15);
                while (DateTime.UtcNow < deadline)
                {
                    await Task.Delay(3000, ct);
                    var updated = await NodeService.GetNodeAsync(nodeName, ct);
                    if (updated is null) throw new Exception("Node not found.");
                    _pools = _pools.Select(p => p.NodeName == nodeName ? p with { NodeState = updated.State } : p).ToList();
                    StateHasChanged();
                    if (updated.State == NodeState.Running) break;
                    if (updated.State == NodeState.Failure) throw new Exception("Node failed to start.");
                }
                var finalNode = await NodeService.GetNodeAsync(nodeName, ct);
                if (finalNode?.State != NodeState.Running)
                    throw new Exception("Node did not reach Running state in time.");
            }

            _nodeName = nodeName;
            var kernel = await CreateKernelWithRetryAsync(nodeName, ct);
            _kernelId = kernel.Id;
            _kernel = kernel;
            _kernelPollingCts = new CancellationTokenSource();
            _ = PollKernelStatusAsync(_kernelPollingCts.Token);
            if (_workspaceNotebookId.HasValue)
                await JS.InvokeVoidAsync("setItemNodePref", _workspaceNotebookId.Value.ToString(), _poolName);

            // Attach catalogs if any are selected
            await _catalog.SetupAllAsync(_selectedCatalogNames);
        }
        catch (OperationCanceledException)
        {
            // Page was disposed while waiting — discard silently
        }
        catch (Exception ex)
        {
            _error = $"Failed to connect: {ex.Message}";
        }
        finally
        {
            _connecting = false;
            _connectCts.Dispose();
            _connectCts = null;
        }
        StateHasChanged();
    }

    private static readonly int KernelCreateMaxRetries = 6;
    private static readonly TimeSpan KernelCreateRetryInterval = TimeSpan.FromSeconds(5);

    private async Task<KernelInfo> CreateKernelWithRetryAsync(string nodeName, CancellationToken ct = default)
    {
        HttpRequestException? lastEx = null;
        for (var attempt = 0; attempt <= KernelCreateMaxRetries; attempt++)
        {
            if (attempt > 0)
                await Task.Delay(KernelCreateRetryInterval, ct);
            try
            {
                return await KernelService.CreateKernelAsync(nodeName, ct);
            }
            catch (HttpRequestException ex) when (IsTransientRuntimeError(ex.StatusCode))
            {
                lastEx = ex;
            }
        }
        throw lastEx!;
    }

    private static bool IsTransientRuntimeError(System.Net.HttpStatusCode? statusCode) =>
        statusCode is
            System.Net.HttpStatusCode.BadRequest            // 400 — runtime not fully initialised
            or System.Net.HttpStatusCode.InternalServerError // 500 — unexpected startup error
            or System.Net.HttpStatusCode.BadGateway          // 502 — pod not yet reachable
            or System.Net.HttpStatusCode.ServiceUnavailable  // 503 — pod not ready
            or System.Net.HttpStatusCode.GatewayTimeout;     // 504 — pod responded too slowly

    private async Task DisconnectAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName)) return;
        _disconnecting = true;
        _error = null;
        try
        {
            await StopKernelPollingAsync();
            await KernelService.DeleteKernelAsync(_nodeName, _kernelId!);
            _kernelId = null;
            _kernel = null;
            _catalog.Clear();
        }
        catch (Exception ex)
        {
            _error = $"Failed to disconnect: {ex.Message}";
        }
        finally
        {
            _disconnecting = false;
        }
    }

    private async Task PollKernelStatusAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (AnyExecuting || string.IsNullOrEmpty(_kernelId) || string.IsNullOrEmpty(_nodeName))
                    continue;
                try
                {
                    _kernel = await KernelService.GetKernelAsync(_nodeName, _kernelId, cancellationToken);
                    await InvokeAsync(StateHasChanged);
                }
                catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _kernelId = null;
                    _kernel = null;
                    _error = "The kernel was evicted, likely due to inactivity. Please reconnect.";
                    await InvokeAsync(StateHasChanged);
                    break;
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch { /* ignore transient errors — will retry on next tick */ }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task StopKernelPollingAsync()
    {
        if (_kernelPollingCts is not null)
        {
            await _kernelPollingCts.CancelAsync();
            _kernelPollingCts.Dispose();
            _kernelPollingCts = null;
        }
    }

    private async Task ExecuteCellAsync(NotebookCell cell)
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName) || cell.IsExecuting) return;

        cell.ClearOutput();
        cell.IsExecuting = true;
        _error = null;
        if (_kernel is not null)
            _kernel = _kernel with { Status = KernelStatus.Busy };

        string codeToRun;
        if (cell.Language == NotebookCellLanguage.Sql)
        {
            codeToRun = $"import duckdb; duckdb.sql(\"\"\"{cell.Source}\"\"\")";
        }
        else if (RunMagicHelper.HasRunLines(cell.Source))
        {
            try
            {
                codeToRun = await RunMagicHelper.ExpandAsync(
                    cell.Source, _workspaceNotebookFolderId, WorkspaceService);
                cell.CachedExpandedSource = codeToRun;
            }
            catch (RunMagicException ex)
            {
                cell.Error = new ErrorInfo("RunMagicError", ex.Message, []);
                cell.IsExecuting = false;
                return;
            }
        }
        else
        {
            codeToRun = cell.Source;
            cell.CachedExpandedSource = null;
        }

        try
        {
            var handle = await KernelService.StartExecuteAsync(
                _nodeName, _kernelId!, new ExecuteKernelRequest(codeToRun));
            cell.ExecutionId = handle.ExecutionId;

            PollExecutionResponse poll;
            do
            {
                await Task.Delay(1000);
                poll = await KernelService.PollExecutionAsync(_nodeName, _kernelId!, handle.ExecutionId);
                StateHasChanged();
            } while (!poll.IsComplete);

            var result = poll.Result!;
            cell.Outputs = result.Outputs.ToList();
            cell.Error = result.Error;
            cell.ExecutionCount = result.ExecutionCount;
            cell.DurationMs = result.DurationMs;
            _kernel = await KernelService.GetKernelAsync(_nodeName, _kernelId!);
            _notebook.IsDirty = true;
        }
        catch (Exception ex)
        {
            _error = $"Execution failed: {ex.Message}";
        }
        finally
        {
            cell.IsExecuting = false;
            cell.ExecutionId = null;
        }
    }

    private async Task RunAllAsync()
    {
        var cells = _notebook.Cells.Where(c => c.CellType == NotebookCellType.Code).ToList();
        foreach (var c in cells) c.ClearOutput();

        foreach (var cell in cells)
        {
            await ExecuteCellAsync(cell);
            if (cell.Error is not null) break;
        }
    }

    private async Task RunAboveAsync(NotebookCell targetCell)
    {
        var cells = _notebook.Cells
            .Take(_notebook.Cells.IndexOf(targetCell))
            .Where(c => c.CellType == NotebookCellType.Code)
            .ToList();

        foreach (var c in cells) c.ClearOutput();

        foreach (var c in cells)
        {
            await ExecuteCellAsync(c);
            if (c.Error is not null) break;
        }
    }

    private async Task RunBelowAsync(NotebookCell targetCell)
    {
        var cells = _notebook.Cells
            .Skip(_notebook.Cells.IndexOf(targetCell))
            .Where(c => c.CellType == NotebookCellType.Code)
            .ToList();

        foreach (var c in cells) c.ClearOutput();

        foreach (var c in cells)
        {
            await ExecuteCellAsync(c);
            if (c.Error is not null) break;
        }
    }

    private async Task InterruptAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName)) return;
        try { await KernelService.InterruptKernelAsync(_nodeName, _kernelId!); }
        catch (Exception ex) { _error = $"Interrupt failed: {ex.Message}"; }
    }

    private void ClearAllOutputs()
    {
        foreach (var cell in _notebook.Cells)
            cell.ClearOutput();
        _notebook.IsDirty = true;
    }

    private void AddCell(int index, NotebookCellType cellType, NotebookCellLanguage lang = NotebookCellLanguage.Python)
    {
        var cell = new NotebookCell { CellType = cellType, Language = lang };
        if (cellType == NotebookCellType.Markdown)
            cell.IsEditingMarkdown = true;
        _notebook.Cells.Insert(index, cell);
        _notebook.IsDirty = true;
    }

    private void DeleteCell(NotebookCell cell)
    {
        _notebook.Cells.Remove(cell);
        _notebook.IsDirty = true;
    }

    private void ToggleParameterCell(NotebookCell cell)
    {
        bool wasSet = cell.IsParameterCell;
        // Clear the flag on all cells first
        foreach (var c in _notebook.Cells)
            c.IsParameterCell = false;
        // Toggle on the target cell (unless it was already set — then it's now cleared)
        cell.IsParameterCell = !wasSet;
        _notebook.IsDirty = true;
    }

    private void MoveCell(int index, int direction)
    {
        int target = index + direction;
        if (target < 0 || target >= _notebook.Cells.Count) return;
        (_notebook.Cells[index], _notebook.Cells[target]) = (_notebook.Cells[target], _notebook.Cells[index]);
        _notebook.IsDirty = true;
    }

    private string PriorContextFor(int cellIndex)
    {
        return string.Join("\n", _notebook.Cells
            .Take(cellIndex)
            .Where(c => c.CellType == NotebookCellType.Code)
            .Select(c =>
            {
                if (c.Language == NotebookCellLanguage.Sql)
                    return $"import duckdb; duckdb.sql(\"\"\"{c.Source}\"\"\")";
                if (c.CachedExpandedSource is not null)
                    return c.CachedExpandedSource;
                return RunMagicHelper.ReplaceRunLinesWithPass(c.Source);
            }));
    }

    private async Task<IReadOnlyList<RunMagicCompletionItem>> ProvideRunMagicCompletionsAsync(string directoryPath)
    {
        try
        {
            var resolved = await WorkspaceService.ResolvePathAsync(
                directoryPath.EndsWith('/') ? directoryPath : directoryPath + "/",
                _workspaceNotebookFolderId);

            if (resolved?.Listing is null) return [];

            var items = new List<RunMagicCompletionItem>();
            foreach (var f in resolved.Listing.Folders)
                items.Add(new(f.Name + "/", "folder", f.Name + "/"));
            foreach (var n in resolved.Listing.Notebooks)
                items.Add(new(n.Title, "notebook", n.Title));
            foreach (var q in resolved.Listing.Queries)
                items.Add(new(q.Title, "query", q.Title));
            return items;
        }
        catch
        {
            return [];
        }
    }

    private async Task OpenFileDialogAsync()
    {
        await JS.InvokeVoidAsync("clickElement", _fileInput.Element);
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs args)
    {
        try
        {
            using var stream = args.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            _notebook = NotebookSerializer.Deserialize(json);
            _notebook.IsDirty = false;
        }
        catch (Exception ex)
        {
            _error = $"Failed to open file: {ex.Message}";
        }
    }

    private async Task SaveToWorkspaceAsync()
    {
        if (!_workspaceNotebookId.HasValue) return;
        try
        {
            var json = NotebookSerializer.Serialize(_notebook);
            await WorkspaceService.UpdateNotebookAsync(_workspaceNotebookId.Value,
                new UpdateNotebookRequest(_notebook.Title, json, _workspaceNotebookFolderId));
            try { await CatalogService.UpdateWorkspaceItemCatalogsAsync(_workspaceNotebookId.Value, _selectedCatalogNames.ToList()); }
            catch (Exception ex) { _error = $"Notebook saved but failed to save catalog selection: {ex.Message}"; }
            _notebook.IsDirty = false;
        }
        catch (Exception ex)
        {
            _error = $"Failed to save to workspace: {ex.Message}";
        }
    }

    // ── Folder picker (first-time save) ───────────────────────────────

    private Task OpenFolderPickerAsync()
    {
        _showFolderPicker = true;
        return Task.CompletedTask;
    }

    private async Task ConfirmSaveToFolderAsync(Guid? folderId)
    {
        _showFolderPicker = false;
        try
        {
            var json = NotebookSerializer.Serialize(_notebook);
            var summary = await WorkspaceService.CreateNotebookAsync(
                new CreateNotebookRequest(_notebook.Title, json, folderId));
            _workspaceNotebookId = summary.Id;
            _workspaceNotebookFolderId = folderId;

            if (_selectedCatalogNames.Any())
            {
                try { await CatalogService.UpdateWorkspaceItemCatalogsAsync(summary.Id, _selectedCatalogNames.ToList()); }
                catch (Exception ex) { _error = $"Notebook saved but failed to save catalog selection: {ex.Message}"; }
            }

            if (folderId is not null)
            {
                var ancestors = await WorkspaceService.GetFolderAncestorsAsync(folderId.Value);
                _breadcrumbs = [(null, "Workspace"), ..ancestors.Select(f => ((Guid?)f.Id, f.Name))];
            }
            else
            {
                _breadcrumbs = [(null, "Workspace")];
            }

            _notebook.IsDirty = false;
            Navigation.NavigateTo($"/notebook/{_workspaceNotebookId}", replace: true);
        }
        catch (Exception ex)
        {
            _error = $"Failed to save to workspace: {ex.Message}";
        }
    }

    private async Task ExportFileAsync()
    {
        try
        {
            var json = NotebookSerializer.Serialize(_notebook);
            var filename = (_notebook.Title.Trim().Length > 0 ? _notebook.Title.Trim() : "notebook") + ".ipynb";
            await JS.InvokeVoidAsync("downloadFile", filename, json);
        }
        catch (Exception ex)
        {
            _error = $"Failed to export: {ex.Message}";
        }
    }

    // ── Catalog management ───────────────────────────────────────────

    private Task OnCatalogSelectionChanged(IEnumerable<CatalogDto> selectedItems)
    {
        _notebook.IsDirty = true;
        return _catalog.OnSelectionChangedAsync(selectedItems, _workspaceNotebookId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_connectCts is not null)
        {
            await _connectCts.CancelAsync();
            // _connectCts is disposed by ConnectAsync's finally block
        }
        await StopKernelPollingAsync();
        if (HasKernel && !string.IsNullOrEmpty(_nodeName))
        {
            try { await KernelService.DeleteKernelAsync(_nodeName, _kernelId!); }
            catch { /* best effort */ }
        }
    }

    private static string StatusTagColor(KernelStatus status) => status switch
    {
        KernelStatus.Idle                                 => "success",
        KernelStatus.Busy                                 => "warning",
        KernelStatus.Starting or KernelStatus.Restarting => "processing",
        KernelStatus.Dead                                 => "error",
        _                                                 => "default"
    };

    private static string NodeStateTagColor(NodeState state) => state switch
    {
        NodeState.Running => "success",
        NodeState.Failure => "error",
        _                 => "warning",
    };
}

