@page "/notebook"

@using DuckHouse.Ui.Client.Notebook
@using DuckHouse.Core.Kernels
@using DuckHouse.Core.Nodes
@using DuckHouse.Ui.Shared.Kernels
@inject IKernelService KernelService
@inject INodeService NodeService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Notebook — DuckHouse</PageTitle>

<Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap; gap: 8px;">
    <Space Align="SpaceAlign.End" Size="SpaceSize.Middle">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.FileText" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">
                @if (_editingTitle)
                {
                    <Input Style="width: 20ch; font-size: inherit;"
                           @bind-Value="_editingTitleValue"
                           OnPressEnter="@(_ => CommitTitleEdit())"
                           OnBlur="@(_ => CommitTitleEdit())" />
                }
                else
                {
                    <span style="cursor: pointer;" @onclick="StartEditTitle">
                        @_notebook.Title@(_notebook.IsDirty ? " *" : "")
                    </span>
                }
            </h2>
        </SpaceItem>
    </Space>

    @* File toolbar *@
    <Space Size="SpaceSize.Small" Style="flex-wrap: wrap;">
        <SpaceItem>
            <Button OnClick="OpenFileDialogAsync" Icon="@IconType.Outline.FolderOpen">
                Open
            </Button>
            <InputFile @ref="_fileInput" style="display:none;" accept=".ipynb" OnChange="OnFileSelectedAsync" />
        </SpaceItem>
        <SpaceItem>
            <Button Disabled="@(!_notebook.IsDirty)" Icon="@IconType.Outline.Save" OnClick="SaveAsync">
                Save
            </Button>
        </SpaceItem>
        <SpaceItem><Divider Type="DividerType.Vertical" /></SpaceItem>
        <SpaceItem>
            @if (AnyExecuting)
            {
                <Button Disabled="@(!HasKernel || !AnyExecuting)"
                        Icon="@IconType.Outline.Loading"
                        OnClick="InterruptAsync">
                    Interrupt
                </Button>
            }
            else
            {
                <Button Type="ButtonType.Primary"
                        Disabled="@(!HasKernel)"
                        Icon="@IconType.Outline.PlayCircle"
                        OnClick="RunAllAsync">
                    Run all
                </Button>
            }
        </SpaceItem>
        <SpaceItem>
            <Button Disabled="@(!_notebook.Cells.Any())"
                    Icon="@IconType.Outline.Clear"
                    OnClick="ClearAllOutputs">
                Clear outputs
            </Button>
        </SpaceItem>
    </Space>
</Flex>

@* Kernel connection toolbar *@
<Space Align="SpaceAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap;" Size="SpaceSize.Small">
    <SpaceItem>
        <Icon Type="@IconType.Outline.CloudServer" />
    </SpaceItem>
    <SpaceItem>
        <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">Node:</Text>
    </SpaceItem>
    @if (_loadingNodes)
    {
        <SpaceItem><Spin Size="SpinSize.Small" /></SpaceItem>
    }
    else
    {
        <SpaceItem>
            <SimpleSelect Value="@(_nodeName ?? string.Empty)"
                          OnSelectedItemChanged="@((string v) => _nodeName = string.IsNullOrEmpty(v) ? null : v)"
                          Placeholder="— select node —"
                          Disabled="@HasKernel"
                          AllowClear
                          Style="min-width: 150px;">
                <SelectOptions>
                    @foreach (var node in _nodes.Where(n => n.State == NodeState.Running))
                    {
                        <SimpleSelectOption Value="@node.Name" Label="@node.Name" />
                    }
                </SelectOptions>
            </SimpleSelect>
        </SpaceItem>
    }

    @if (!HasKernel)
    {
        <SpaceItem>
            <Button Type="ButtonType.Primary" Size="ButtonSize.Small"
                    Disabled="@(string.IsNullOrEmpty(_nodeName) || _connecting)"
                    Loading="_connecting"
                    Icon="@IconType.Outline.Api"
                    OnClick="ConnectAsync">
                Connect
            </Button>
        </SpaceItem>
    }
    else
    {
        <SpaceItem><Tag Color="@StatusTagColor(_kernel!.Status)">@_kernel!.Status</Tag></SpaceItem>
        <SpaceItem>
            <Button Size="ButtonSize.Small"
                    Disabled="_disconnecting"
                    Loading="_disconnecting"
                    Icon="@IconType.Outline.Disconnect"
                    OnClick="DisconnectAsync">
                Disconnect
            </Button>
        </SpaceItem>
    }
</Space>

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
}

@* Cell list *@
<AddCellBar OnAddPython="() => AddCell(0, NotebookCellType.Code, NotebookCellLanguage.Python)"
            OnAddSql="() => AddCell(0, NotebookCellType.Code, NotebookCellLanguage.Sql)"
            OnAddMarkdown="() => AddCell(0, NotebookCellType.Markdown)" />

@for (int ci = 0; ci < _notebook.Cells.Count; ci++)
{
    var cell = _notebook.Cells[ci];
    var index = ci; // capture for closure
    <NotebookCellView Cell="cell"
                      NodeName="@_nodeName"
                      KernelId="@_kernelId"
                      CanMoveUp="@(index > 0)"
                      CanMoveDown="@(index < _notebook.Cells.Count - 1)"
                      PriorContext="@(() => PriorContextFor(index))"
                      OnExecute="@(() => _ = ExecuteCellAsync(cell))"
                      OnRunAbove="@(() => _ = RunAboveAsync(cell))"
                      OnRunBelow="@(() => _ = RunBelowAsync(cell))"
                      OnInterrupt="InterruptAsync"
                      OnDelete="@(() => DeleteCell(cell))"
                      OnMoveUp="@(() => MoveCell(index, -1))"
                      OnMoveDown="@(() => MoveCell(index, 1))"
                      OnCellChanged="@(() => _notebook.IsDirty = true)" />
    <AddCellBar OnAddPython="() => AddCell(index + 1, NotebookCellType.Code, NotebookCellLanguage.Python)"
                OnAddSql="() => AddCell(index + 1, NotebookCellType.Code, NotebookCellLanguage.Sql)"
                OnAddMarkdown="() => AddCell(index + 1, NotebookCellType.Markdown)" />
}

@if (_notebook.Cells.Count == 0)
{
    <div style="font-style: italic; font-size: 0.875rem; text-align: center; padding: 32px 0;">
        <Text Type="TextElementType.Secondary">No cells yet — use the <strong>+</strong> buttons above to add your first cell.</Text>
    </div>
}

@code {
    private NotebookDocument _notebook = new();
    private string? _nodeName;
    private string? _kernelId;
    private KernelInfo? _kernel;
    private IReadOnlyList<NodeInfo> _nodes = [];
    private bool _loadingNodes;
    private bool _connecting;
    private bool _disconnecting;
    private string? _error;
    private bool _editingTitle;
    private string _editingTitleValue = "";
    private InputFile _fileInput = default!;
    private CancellationTokenSource? _kernelPollingCts;

    private bool HasKernel => !string.IsNullOrEmpty(_kernelId);
    private bool AnyExecuting => _notebook.Cells.Any(c => c.IsExecuting);

    private void StartEditTitle()
    {
        _editingTitleValue = _notebook.Title;
        _editingTitle = true;
    }

    private void CommitTitleEdit()
    {
        _notebook.Title = string.IsNullOrWhiteSpace(_editingTitleValue) ? "Untitled" : _editingTitleValue;
        _notebook.IsDirty = true;
        _editingTitle = false;
    }

    protected override async Task OnInitializedAsync()
    {
        _loadingNodes = true;
        try { _nodes = await NodeService.GetNodesAsync(); }
        catch (Exception ex) { _error = $"Failed to load nodes: {ex.Message}"; }
        finally { _loadingNodes = false; }
    }

    private async Task ConnectAsync()
    {
        if (string.IsNullOrEmpty(_nodeName)) return;
        _connecting = true;
        _error = null;
        try
        {
            var kernel = await KernelService.CreateKernelAsync(_nodeName);
            _kernelId = kernel.Id;
            _kernel = kernel;
            _kernelPollingCts = new CancellationTokenSource();
            _ = PollKernelStatusAsync(_kernelPollingCts.Token);
        }
        catch (Exception ex)
        {
            _error = $"Failed to create kernel: {ex.Message}";
        }
        finally
        {
            _connecting = false;
        }
        StateHasChanged();
    }

    private async Task DisconnectAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName)) return;
        _disconnecting = true;
        _error = null;
        try
        {
            await StopKernelPollingAsync();
            await KernelService.DeleteKernelAsync(_nodeName, _kernelId!);
            _kernelId = null;
            _kernel = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to disconnect: {ex.Message}";
        }
        finally
        {
            _disconnecting = false;
        }
    }

    private async Task PollKernelStatusAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (AnyExecuting || string.IsNullOrEmpty(_kernelId) || string.IsNullOrEmpty(_nodeName))
                    continue;
                try
                {
                    _kernel = await KernelService.GetKernelAsync(_nodeName, _kernelId, cancellationToken);
                    await InvokeAsync(StateHasChanged);
                }
                catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _kernelId = null;
                    _kernel = null;
                    _error = "The kernel was evicted, likely due to inactivity. Please reconnect.";
                    await InvokeAsync(StateHasChanged);
                    break;
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch { /* ignore transient errors — will retry on next tick */ }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task StopKernelPollingAsync()
    {
        if (_kernelPollingCts is not null)
        {
            await _kernelPollingCts.CancelAsync();
            _kernelPollingCts.Dispose();
            _kernelPollingCts = null;
        }
    }

    private async Task ExecuteCellAsync(NotebookCell cell)
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName) || cell.IsExecuting) return;

        cell.ClearOutput();
        cell.IsExecuting = true;
        _error = null;
        if (_kernel is not null)
            _kernel = _kernel with { Status = KernelStatus.Busy };

        string codeToRun = cell.Language == NotebookCellLanguage.Sql
            ? $"import duckdb; duckdb.sql(\"\"\"{cell.Source}\"\"\")"
            : cell.Source;

        try
        {
            var handle = await KernelService.StartExecuteAsync(
                _nodeName, _kernelId!, new ExecuteKernelRequest(codeToRun));
            cell.ExecutionId = handle.ExecutionId;

            PollExecutionResponse poll;
            do
            {
                await Task.Delay(1000);
                poll = await KernelService.PollExecutionAsync(_nodeName, _kernelId!, handle.ExecutionId);
                StateHasChanged();
            } while (!poll.IsComplete);

            var result = poll.Result!;
            cell.Outputs = result.Outputs.ToList();
            cell.Error = result.Error;
            cell.ExecutionCount = result.ExecutionCount;
            cell.DurationMs = result.DurationMs;
            _kernel = await KernelService.GetKernelAsync(_nodeName, _kernelId!);
            _notebook.IsDirty = true;
        }
        catch (Exception ex)
        {
            _error = $"Execution failed: {ex.Message}";
        }
        finally
        {
            cell.IsExecuting = false;
            cell.ExecutionId = null;
        }
    }

    private async Task RunAllAsync()
    {
        var cells = _notebook.Cells.Where(c => c.CellType == NotebookCellType.Code).ToList();
        foreach (var c in cells) c.ClearOutput();

        foreach (var cell in cells)
        {
            await ExecuteCellAsync(cell);
            if (cell.Error is not null) break;
        }
    }

    private async Task RunAboveAsync(NotebookCell targetCell)
    {
        var cells = _notebook.Cells
            .Take(_notebook.Cells.IndexOf(targetCell))
            .Where(c => c.CellType == NotebookCellType.Code)
            .ToList();

        foreach (var c in cells) c.ClearOutput();

        foreach (var c in cells)
        {
            await ExecuteCellAsync(c);
            if (c.Error is not null) break;
        }
    }

    private async Task RunBelowAsync(NotebookCell targetCell)
    {
        var cells = _notebook.Cells
            .Skip(_notebook.Cells.IndexOf(targetCell))
            .Where(c => c.CellType == NotebookCellType.Code)
            .ToList();

        foreach (var c in cells) c.ClearOutput();

        foreach (var c in cells)
        {
            await ExecuteCellAsync(c);
            if (c.Error is not null) break;
        }
    }

    private async Task InterruptAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName)) return;
        try { await KernelService.InterruptKernelAsync(_nodeName, _kernelId!); }
        catch (Exception ex) { _error = $"Interrupt failed: {ex.Message}"; }
    }

    private void ClearAllOutputs()
    {
        foreach (var cell in _notebook.Cells)
            cell.ClearOutput();
        _notebook.IsDirty = true;
    }

    private void AddCell(int index, NotebookCellType cellType, NotebookCellLanguage lang = NotebookCellLanguage.Python)
    {
        var cell = new NotebookCell { CellType = cellType, Language = lang };
        if (cellType == NotebookCellType.Markdown)
            cell.IsEditingMarkdown = true;
        _notebook.Cells.Insert(index, cell);
        _notebook.IsDirty = true;
    }

    private void DeleteCell(NotebookCell cell)
    {
        _notebook.Cells.Remove(cell);
        _notebook.IsDirty = true;
    }

    private void MoveCell(int index, int direction)
    {
        int target = index + direction;
        if (target < 0 || target >= _notebook.Cells.Count) return;
        (_notebook.Cells[index], _notebook.Cells[target]) = (_notebook.Cells[target], _notebook.Cells[index]);
        _notebook.IsDirty = true;
    }

    private string PriorContextFor(int cellIndex)
    {
        return string.Join("\n", _notebook.Cells
            .Take(cellIndex)
            .Where(c => c.CellType == NotebookCellType.Code)
            .Select(c => c.Language == NotebookCellLanguage.Sql
                ? $"import duckdb; duckdb.sql(\"\"\"{c.Source}\"\"\")"
                : c.Source));
    }

    private async Task OpenFileDialogAsync()
    {
        await JS.InvokeVoidAsync("clickElement", _fileInput.Element);
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs args)
    {
        try
        {
            using var stream = args.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            _notebook = NotebookSerializer.Deserialize(json);
            _notebook.IsDirty = false;
        }
        catch (Exception ex)
        {
            _error = $"Failed to open file: {ex.Message}";
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            var json = NotebookSerializer.Serialize(_notebook);
            var filename = (_notebook.Title.Trim().Length > 0 ? _notebook.Title.Trim() : "notebook") + ".ipynb";
            await JS.InvokeVoidAsync("downloadFile", filename, json);
            _notebook.IsDirty = false;
        }
        catch (Exception ex)
        {
            _error = $"Failed to save: {ex.Message}";
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopKernelPollingAsync();
        if (HasKernel && !string.IsNullOrEmpty(_nodeName))
        {
            try { await KernelService.DeleteKernelAsync(_nodeName, _kernelId!); }
            catch { /* best effort */ }
        }
    }

    private static string StatusTagColor(KernelStatus status) => status switch
    {
        KernelStatus.Idle                                 => "success",
        KernelStatus.Busy                                 => "warning",
        KernelStatus.Starting or KernelStatus.Restarting => "processing",
        KernelStatus.Dead                                 => "error",
        _                                                 => "default"
    };
}

