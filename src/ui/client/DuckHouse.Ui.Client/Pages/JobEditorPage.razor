@page "/jobs/{Id:guid}"
@attribute [Authorize(Policy = AuthPolicy.JobRead)]

@using DuckHouse.Ui.Shared.Orchestration
@using DuckHouse.Ui.Client.Validation
@using DuckHouse.Core.Orchestration
@using System.ComponentModel.DataAnnotations
@inject IJobService JobService
@inject IRecentItemsService RecentItemsService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IMessageService MessageService

<PageTitle>@(_job?.Name ?? "Job Editor") — DuckHouse</PageTitle>
<NavigationLock ConfirmExternalNavigation="@_isDirty"
                OnBeforeInternalNavigation="ConfirmInternalNavigationAsync" />

@if (!string.IsNullOrEmpty(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
           Style="margin-bottom: 16px;" />
}

<Spin Spinning="_loading">
    @if (_job is not null)
    {
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 16px; flex-wrap: wrap; gap: 8px;">
            <Space Align="SpaceAlign.Center" Size="SpaceSize.Small">
                <SpaceItem>
                    <Button OnClick="@(() => Navigation.NavigateTo("/jobs"))">
                        <Icon Type="@IconType.Outline.ArrowLeft" /> Back
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <h2 style="margin: 0;">@_job.Name</h2>
                </SpaceItem>
                <SpaceItem>
                    @if (_job.IsEnabled)
                    {
                        <Tag Color="@("green")">Enabled</Tag>
                    }
                    else
                    {
                        <Tag>Disabled</Tag>
                    }
                </SpaceItem>
            </Space>
            <Space>
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" OnClick="() => _showTriggerModal = true">
                        <Icon Type="@IconType.Outline.PlayCircle" /> Run
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button OnClick="ExportYamlAsync">
                        <Icon Type="@IconType.Outline.Download" /> Export YAML
                    </Button>
                </SpaceItem>
            </Space>
        </Flex>

        <Tabs DefaultActiveKey="settings">
            <TabPane Key="settings" Tab="Settings">
                <div style="max-width: 600px; margin-top: 16px;">
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <div>
                            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Name</label>
                            <Input @bind-Value="_editName" OnChange="@((string _) => _isDirty = true)" />
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Description</label>
                            <TextArea @bind-Value="_editDescription" Rows="3" OnChange="@((string _) => _isDirty = true)" />
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Max Concurrent Runs</label>
                            <AntDesign.InputNumber @bind-Value="_editMaxConcurrent" Min="1" Max="100" OnChange="@((int _) => _isDirty = true)" />
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Enabled</label>
                            <Switch @bind-Checked="_editEnabled" OnChange="@((bool _) => _isDirty = true)" />
                        </div>
                        <div>
                            <Button Type="@ButtonType.Primary" OnClick="SaveAsync" Disabled="!_isDirty">
                                <Icon Type="@IconType.Outline.Save" /> Save
                            </Button>
                        </div>
                    </div>
                </div>
            </TabPane>

            <TabPane Key="tasks" Tab="@($"Tasks ({_editTasks.Count})")">
                <div style="margin-top: 16px;">
                    <div style="margin-bottom: 8px;">
                        <Button Size="@ButtonSize.Small" OnClick="StartAddTask">
                            <Icon Type="@IconType.Outline.Plus" /> Add task
                        </Button>
                    </div>
                    <Table TItem="EditableTask" DataSource="_editTasks" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                        <PropertyColumn Property="c => c.Name" Title="Name" />
                        <PropertyColumn Property="c => c.TaskType" Title="Type">
                            <Tag Color="@GetTaskTypeColor(context.TaskType)">@context.TaskType</Tag>
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.NodePoolRef" Title="Node pool">
                            @(context.NodePoolRef ?? "—")
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.MaxRetries" Title="Retries" />
                        <PropertyColumn Property="c => c.Dependencies" Title="Dependencies">
                            @if (context.Dependencies.Count > 0)
                            {
                                @foreach (var dep in context.Dependencies)
                                {
                                    <Tag>@dep.TaskName (@dep.Condition)</Tag>
                                }
                            }
                            else
                            {
                                <span style="color: #999;">None</span>
                            }
                        </PropertyColumn>
                        <ActionColumn Title="Actions">
                            <Space>
                                <SpaceItem>
                                    <Tooltip Title="Edit">
                                        <Button Size="@ButtonSize.Small" OnClick="() => StartEditTask(context)">
                                            <Icon Type="@IconType.Outline.Edit" />
                                        </Button>
                                    </Tooltip>
                                </SpaceItem>
                                <SpaceItem>
                                    <Tooltip Title="Delete">
                                        <Popconfirm Title="Delete this task?" OnConfirm="() => DeleteTask(context)">
                                            <Button Danger Size="@ButtonSize.Small">
                                                <Icon Type="@IconType.Outline.Delete" />
                                            </Button>
                                        </Popconfirm>
                                    </Tooltip>
                                </SpaceItem>
                            </Space>
                        </ActionColumn>
                    </Table>
                </div>
            </TabPane>

            <TabPane Key="parameters" Tab="@($"Parameters ({_editParams.Count})")">
                <div style="margin-top: 16px;">
                    <div style="margin-bottom: 8px;">
                        <Button Size="@ButtonSize.Small" OnClick="StartAddParameter">
                            <Icon Type="@IconType.Outline.Plus" /> Add parameter
                        </Button>
                    </div>
                    <Table TItem="EditableParameter" DataSource="_editParams" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                        <PropertyColumn Property="c => c.Name" Title="Name" />
                        <PropertyColumn Property="c => c.DefaultValue" Title="Default">
                            @(context.DefaultValue ?? "—")
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.IsRequired" Title="Required">
                            @if (context.IsRequired)
                            {
                                <Tag Color="@("red")">Required</Tag>
                            }
                            else
                            {
                                <Tag>Optional</Tag>
                            }
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.Description" Title="Description">
                            @(context.Description ?? "—")
                        </PropertyColumn>
                        <ActionColumn Title="Actions">
                            <Space>
                                <SpaceItem>
                                    <Tooltip Title="Edit">
                                        <Button Size="@ButtonSize.Small" OnClick="() => StartEditParameter(context)">
                                            <Icon Type="@IconType.Outline.Edit" />
                                        </Button>
                                    </Tooltip>
                                </SpaceItem>
                                <SpaceItem>
                                    <Tooltip Title="Delete">
                                        <Popconfirm Title="Delete this parameter?" OnConfirm="() => DeleteParameter(context)">
                                            <Button Danger Size="@ButtonSize.Small">
                                                <Icon Type="@IconType.Outline.Delete" />
                                            </Button>
                                        </Popconfirm>
                                    </Tooltip>
                                </SpaceItem>
                            </Space>
                        </ActionColumn>
                    </Table>
                </div>
            </TabPane>

            <TabPane Key="schedules" Tab="@($"Schedules ({_job.Schedules.Count})")">
                <div style="margin-top: 16px;">
                    <div style="margin-bottom: 8px;">
                        <Button Size="@ButtonSize.Small" OnClick="StartAddSchedule">
                            <Icon Type="@IconType.Outline.Plus" /> Add schedule
                        </Button>
                    </div>
                    <Table TItem="ScheduleDto" DataSource="_job.Schedules" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                        <PropertyColumn Property="c => c.CronExpression" Title="Cron Expression">
                            <code>@context.CronExpression</code>
                            @{
                                var desc = ValidationHelper.GetCronDescription(context.CronExpression);
                            }
                            @if (!string.IsNullOrWhiteSpace(desc))
                            {
                                <div style="color: #888; font-size: 11px; margin-top: 2px;">@desc</div>
                            }
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.IsEnabled" Title="Enabled">
                            <Switch Value="@context.IsEnabled" OnChange="@(async val => await ToggleScheduleEnabledAsync(context, val))" />
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.NextFireTime" Title="Next Run">
                            @(context.NextFireTime?.ToString("yyyy-MM-dd HH:mm zzz") ?? "—")
                        </PropertyColumn>
                        <ActionColumn Title="Actions">
                            <Tooltip Title="Edit">
                                <Button Size="@ButtonSize.Small" OnClick="() => StartEditSchedule(context)">
                                    <Icon Type="@IconType.Outline.Edit" />
                                </Button>
                            </Tooltip>
                            <Tooltip Title="Delete">
                                <Popconfirm Title="Delete this schedule?" OnConfirm="() => DeleteScheduleAsync(context)">
                                    <Button Danger Size="@ButtonSize.Small">
                                        <Icon Type="@IconType.Outline.Delete" />
                                    </Button>
                                </Popconfirm>
                            </Tooltip>
                        </ActionColumn>
                    </Table>
                </div>
            </TabPane>

            <TabPane Key="runs" Tab="Runs">
                <div style="margin-top: 16px;">
                    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 8px;">
                        <span style="color: #999; font-size: 12px;">Showing last 50 runs, newest first.</span>
                        <Button OnClick="RefreshRunsAsync" Loading="_runsLoading">
                            <Icon Type="@IconType.Outline.Reload" /> Refresh
                        </Button>
                    </Flex>
                    <Table TItem="JobRunSummary" DataSource="_runs" Size="@TableSize.Small" Loading="_runsLoading" PageSize="int.MaxValue" PaginationPosition="none">
                        <PropertyColumn Property="c => c.Status" Title="Status">
                            <a @onclick="@(() => Navigation.NavigateTo($"/runs/{context.Id}"))"
                               @onclick:preventDefault style="cursor: pointer;">
                                <Tag Color="@GetStatusColor(context.Status)">@context.Status</Tag>
                            </a>
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.Trigger" Title="Trigger">
                            @context.Trigger
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.Parameters" Title="Parameters">
                            @if (context.Parameters is { Count: > 0 })
                            {
                                <Popover ContentTemplate="@ParametersContent(context.Parameters)" Trigger="@(new AntDesign.Trigger[] { AntDesign.Trigger.Click })">
                                    <Tag Style="cursor:pointer;">@context.Parameters.Count param(s)</Tag>
                                </Popover>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.CreatedAt" Title="Started">
                            @context.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                        </PropertyColumn>
                        <PropertyColumn Property="c => c.CompletedAt" Title="Completed">
                            @(context.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")
                        </PropertyColumn>
                    </Table>
                </div>
            </TabPane>
        </Tabs>

        <Drawer Closable="true" @bind-Visible="_showScheduleModal" Placement="DrawerPlacement.Right"
               Width="480" Title="@(_editingScheduleId.HasValue ? "Edit schedule" : "Add schedule")"
               OnClose="() => _showScheduleModal = false"
               BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
            <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
                <Form Model="@_scheduleForm" Layout="FormLayout.Vertical" ValidateOnChange="true">
                    <FormItem Label="Cron Expression" Rules="@_cronRules">
                        <Input @bind-Value="context.Cron"
                               BindOnInput
                               OnPressEnter="@(async _ => await ConfirmSchedule())"
                               Placeholder="0 0 6 * * ?" />
                    </FormItem>
                    @if (ValidationHelper.ValidateCronExpression(_scheduleForm.Cron) is null && !string.IsNullOrWhiteSpace(_scheduleForm.Cron))
                    {
                        <div style="color: #888; font-size: 12px; margin-top: -8px;">@ValidationHelper.GetCronDescription(_scheduleForm.Cron)</div>
                    }
                    <FormItem Label="Time Zone">
                        <Select TItem="TimeZoneDto"
                                TItemValue="string"
                                DataSource="_timeZones"
                                @bind-Value="context.TimeZone"
                                LabelName="@nameof(TimeZoneDto.DisplayName)"
                                ValueName="@nameof(TimeZoneDto.Id)"
                                Placeholder="UTC"
                                AllowClear
                                ShowSearch
                                Style="width: 100%;" />
                    </FormItem>
                    <div>
                        <label style="display: block; margin-bottom: 8px; font-weight: 500;">Parameter Overrides</label>
                        @foreach (var (param, index) in _scheduleForm.Parameters.Select((p, i) => (p, i)))
                        {
                            var idx = index;
                            <div style="display: flex; gap: 8px; margin-bottom: 8px; align-items: center;">
                                <Input @bind-Value="param.Key" Placeholder="Key" Style="flex: 1;"
                                       BindOnInput />
                                <Input @bind-Value="param.Value" Placeholder="Value" Style="flex: 1;"
                                       BindOnInput />
                                <Button Danger Size="@ButtonSize.Small" OnClick="() => _scheduleForm.Parameters.RemoveAt(idx)">
                                    <Icon Type="@IconType.Outline.Delete" />
                                </Button>
                            </div>
                        }
                        <Button Size="@ButtonSize.Small" OnClick="() => _scheduleForm.Parameters.Add(new())">
                            <Icon Type="@IconType.Outline.Plus" /> Add override
                        </Button>
                        @{
                            var missingRequired = GetMissingRequiredScheduleParams();
                        }
                        @if (missingRequired.Count > 0)
                        {
                            <div style="color: #ff4d4f; font-size: 12px; margin-top: 8px;">
                                Required parameter(s) with no default value must be overridden: <strong>@string.Join(", ", missingRequired)</strong>
                            </div>
                        }
                    </div>
                </Form>
            </div>
            <div class="drawer-footer">
                <Button OnClick="() => _showScheduleModal = false">Cancel</Button>
                <Button Type="@ButtonType.Primary" OnClick="ConfirmSchedule"
                        Disabled="@(string.IsNullOrWhiteSpace(_scheduleForm.Cron) || ValidationHelper.ValidateCronExpression(_scheduleForm.Cron) is not null || GetMissingRequiredScheduleParams().Count > 0)">Save</Button>
            </div>
        </Drawer>

        <Drawer Closable="true" @bind-Visible="_showExportModal" Placement="DrawerPlacement.Right"
               Width="560" Title="@("Export YAML")"
               OnClose="() => _showExportModal = false"
               BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
            <div style="flex: 1; overflow-y: auto; padding: 24px;">
                <pre style="font-size: 13px; white-space: pre-wrap; margin: 0;">@_exportYaml</pre>
            </div>
        </Drawer>

        <TaskEditorModal @bind-Visible="_showTaskDrawer"
                         Task="_taskBeingEdited"
                         OnSave="OnTaskSaved"
                         OtherTaskNames="_otherTaskNames"
                         CurrentJobId="Id" />

        <ParameterEditorModal @bind-Visible="_showParamModal"
                              Parameter="_paramBeingEdited"
                              ExistingParameters="_editParams"
                              OnSave="OnParameterSaved" />

        <TriggerJobModal @bind-Visible="_showTriggerModal"
                         JobId="Id"
                         OnConfirm="TriggerConfirmedAsync" />
    }
</Spin>

@code {
    [Parameter] public Guid Id { get; set; }

    private JobDetail? _job;
    private IReadOnlyList<JobRunSummary> _runs = [];
    private bool _loading = true;
    private bool _runsLoading;
    private string? _error;
    private bool _isDirty;

    // Settings edit state
    private string _editName = "";
    private string? _editDescription;
    private int _editMaxConcurrent = 1;
    private bool _editEnabled = true;

    // Task & parameter mutable state
    private List<EditableTask> _editTasks = [];
    private List<EditableParameter> _editParams = [];

    // Task editor state
    private bool _showTaskDrawer;
    private EditableTask? _taskBeingEdited;
    private int _taskEditIndex = -1;
    private List<string> _otherTaskNames = [];

    // Parameter editor state
    private bool _showParamModal;
    private EditableParameter? _paramBeingEdited;
    private int _paramEditIndex = -1;

    // Schedule modal state
    private bool _showScheduleModal;
    private Guid? _editingScheduleId;
    private ScheduleFormModel _scheduleForm = new();
    private List<TimeZoneDto> _timeZones = [];

    private static readonly FormValidationRule[] _cronRules =
    [
        new() { Required = true, Message = "Cron expression is required." },
        new() { Validator = ctx =>
            ValidationHelper.ValidateCronExpression(ctx.Value?.ToString()) is { } err
                ? new ValidationResult(err, [ctx.FieldName]) : null }
    ];

    // Trigger modal state
    private bool _showTriggerModal;

    // Export modal state
    private bool _showExportModal;
    private string _exportYaml = "";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _job = await JobService.GetJobAsync(Id);
            if (_job is not null)
            {
                _ = RecentItemsService.RecordVisitAsync(Id, _job.Name, "Job");
                _editName = _job.Name;
                _editDescription = _job.Description;
                _editMaxConcurrent = _job.MaxConcurrentRuns;
                _editEnabled = _job.IsEnabled;

                _editTasks = _job.Tasks.Select(t => new EditableTask
                {
                    Name = t.Name,
                    TaskType = t.TaskType,
                    MaxRetries = t.MaxRetries,
                    RetryInterval = t.RetryInterval.ToString(),
                    Timeout = t.Timeout?.ToString(),
                    NotebookId = t.NotebookId,
                    QueryId = t.QueryId,
                    SubJobId = t.SubJobId,
                    NodePoolRef = t.NodePoolRef,
                    Parameters = t.Parameters?.Select(kv => new EditableTaskParameter { Key = kv.Key, Value = kv.Value }).ToList() ?? [],
                    Dependencies = t.Dependencies.Select(d => new EditableDependency { TaskName = d.DependsOnTaskName, Condition = d.Condition }).ToList(),
                }).ToList();

                _editParams = _job.Parameters.Select(p => new EditableParameter
                {
                    Name = p.Name,
                    DefaultValue = p.DefaultValue,
                    IsRequired = p.IsRequired,
                    Description = p.Description,
                }).ToList();

                _isDirty = false;

                await RefreshRunsAsync();
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load job: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshRunsAsync()
    {
        _runsLoading = true;
        StateHasChanged();
        try
        {
            _runs = await JobService.GetRunsAsync(Id, 50);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load runs: {ex.Message}";
        }
        finally
        {
            _runsLoading = false;
        }
    }

    private string? ValidateTasksBeforeSave()
    {
        var taskNames = _editTasks.Select(t => t.Name.Trim()).ToList();
        if (taskNames.Any(string.IsNullOrWhiteSpace))
            return "All tasks must have a name.";
        if (taskNames.Distinct(StringComparer.OrdinalIgnoreCase).Count() != taskNames.Count)
            return "Task names must be unique (case-insensitive).";

        foreach (var t in _editTasks)
        {
            if (t.TaskType == TaskType.Notebook && t.NotebookId is null)
                return $"Task '{t.Name}': a notebook must be selected.";
            if (t.TaskType == TaskType.SqlQuery && t.QueryId is null)
                return $"Task '{t.Name}': a query must be selected.";
            if (t.TaskType == TaskType.SubJob && t.SubJobId is null)
                return $"Task '{t.Name}': a sub-job must be selected.";
        }

        var nameSet = new HashSet<string>(taskNames, StringComparer.OrdinalIgnoreCase);
        foreach (var t in _editTasks)
        {
            foreach (var dep in t.Dependencies)
            {
                if (string.Equals(dep.TaskName, t.Name, StringComparison.OrdinalIgnoreCase))
                    return $"Task '{t.Name}' cannot depend on itself.";
                if (!nameSet.Contains(dep.TaskName))
                    return $"Task '{t.Name}' depends on unknown task '{dep.TaskName}'.";
            }
        }

        return null;
    }

    private string? ValidateParametersBeforeSave()
    {
        var paramNames = _editParams.Select(p => p.Name.Trim()).ToList();
        if (paramNames.Any(string.IsNullOrWhiteSpace))
            return "All parameters must have a name.";
        if (paramNames.Distinct(StringComparer.OrdinalIgnoreCase).Count() != paramNames.Count)
            return "Parameter names must be unique (case-insensitive).";

        return null;
    }

    private async Task SaveAsync()
    {
        try
        {
            await JobService.UpdateJobAsync(Id, new UpdateJobRequest(
                _editName, _editDescription, _job!.FolderId, _editMaxConcurrent, _editEnabled,
                null, null));
            _error = null;
            await LoadAsync();
            MessageService.Success("Job updated");
        }
        catch (Exception ex)
        {
            _error = $"Failed to save: {ex.Message}";
        }
    }

    private async Task SaveTasksAsync()
    {
        var validationError = ValidateTasksBeforeSave();
        if (validationError is not null)
        {
            _error = validationError;
            return;
        }

        try
        {
            var tasks = _editTasks.Select(t => new UpdateTaskRequest(
                t.Name,
                t.TaskType,
                t.MaxRetries,
                TimeSpan.TryParse(t.RetryInterval, out var ri) ? ri : TimeSpan.FromSeconds(30),
                string.IsNullOrWhiteSpace(t.Timeout) ? null : TimeSpan.TryParse(t.Timeout, out var to) ? to : null,
                t.NotebookId,
                t.QueryId,
                t.SubJobId,
                t.NodePoolRef,
                t.Parameters.Count > 0 ? t.Parameters.ToDictionary(p => p.Key, p => p.Value) : null,
                t.Dependencies.Select(d => new UpdateDependencyRequest(d.TaskName, d.Condition)).ToList()
            )).ToList();

            await JobService.UpdateJobAsync(Id, new UpdateJobRequest(
                _job!.Name, _job.Description, _job.FolderId, _job.MaxConcurrentRuns, _job.IsEnabled,
                tasks, null));
            _error = null;
            await RefreshJobAsync();
            MessageService.Success("Job updated");
        }
        catch (Exception ex)
        {
            _error = $"Failed to save tasks: {ex.Message}";
        }
    }

    private async Task SaveParametersAsync()
    {
        var validationError = ValidateParametersBeforeSave();
        if (validationError is not null)
        {
            _error = validationError;
            return;
        }

        try
        {
            var parameters = _editParams.Select(p => new UpdateParameterRequest(
                p.Name, p.DefaultValue, p.IsRequired, p.Description
            )).ToList();

            await JobService.UpdateJobAsync(Id, new UpdateJobRequest(
                _job!.Name, _job.Description, _job.FolderId, _job.MaxConcurrentRuns, _job.IsEnabled,
                null, parameters));
            _error = null;
            await RefreshJobAsync();
            MessageService.Success("Job updated");
        }
        catch (Exception ex)
        {
            _error = $"Failed to save parameters: {ex.Message}";
        }
    }

    /// <summary>
    /// Silent refresh: reloads _job and rebuilds _editTasks/_editParams without resetting
    /// the Settings tab edit state (_editName, _editDescription, etc.) or _isDirty.
    /// </summary>
    private async Task RefreshJobAsync()
    {
        try
        {
            var fresh = await JobService.GetJobAsync(Id);
            if (fresh is null) return;

            _job = fresh;

            _editTasks = _job.Tasks.Select(t => new EditableTask
            {
                Name = t.Name,
                TaskType = t.TaskType,
                MaxRetries = t.MaxRetries,
                RetryInterval = t.RetryInterval.ToString(),
                Timeout = t.Timeout?.ToString(),
                NotebookId = t.NotebookId,
                QueryId = t.QueryId,
                SubJobId = t.SubJobId,
                NodePoolRef = t.NodePoolRef,
                Parameters = t.Parameters?.Select(kv => new EditableTaskParameter { Key = kv.Key, Value = kv.Value }).ToList() ?? [],
                Dependencies = t.Dependencies.Select(d => new EditableDependency { TaskName = d.DependsOnTaskName, Condition = d.Condition }).ToList(),
            }).ToList();

            _editParams = _job.Parameters.Select(p => new EditableParameter
            {
                Name = p.Name,
                DefaultValue = p.DefaultValue,
                IsRequired = p.IsRequired,
                Description = p.Description,
            }).ToList();
        }
        catch
        {
            // Refresh failure is non-critical; the save already succeeded.
        }
    }

    // --- Task editor ---

    private void StartAddTask()
    {
        _taskBeingEdited = null;
        _taskEditIndex = -1;
        _otherTaskNames = _editTasks.Select(t => t.Name).ToList();
        _showTaskDrawer = true;
    }

    private void StartEditTask(EditableTask task)
    {
        _taskEditIndex = _editTasks.IndexOf(task);
        _taskBeingEdited = task;
        _otherTaskNames = _editTasks.Where(t => t != task).Select(t => t.Name).ToList();
        _showTaskDrawer = true;
    }

    private async Task OnTaskSaved(EditableTask task)
    {
        if (_taskEditIndex >= 0 && _taskEditIndex < _editTasks.Count)
        {
            _editTasks[_taskEditIndex] = task;
        }
        else
        {
            _editTasks.Add(task);
        }
        _showTaskDrawer = false;
        await SaveTasksAsync();
    }

    private async Task DeleteTask(EditableTask task)
    {
        _editTasks.Remove(task);
        await SaveTasksAsync();
    }

    // --- Parameter editor ---

    private void StartAddParameter()
    {
        _paramBeingEdited = null;
        _paramEditIndex = -1;
        _showParamModal = true;
    }

    private void StartEditParameter(EditableParameter param)
    {
        _paramEditIndex = _editParams.IndexOf(param);
        _paramBeingEdited = param;
        _showParamModal = true;
    }

    private async Task OnParameterSaved(EditableParameter param)
    {
        if (_paramEditIndex >= 0 && _paramEditIndex < _editParams.Count)
        {
            _editParams[_paramEditIndex] = param;
        }
        else
        {
            _editParams.Add(param);
        }
        _showParamModal = false;
        await SaveParametersAsync();
    }

    private async Task DeleteParameter(EditableParameter param)
    {
        _editParams.Remove(param);
        await SaveParametersAsync();
    }

    // --- Other actions ---

    private async Task TriggerConfirmedAsync(Dictionary<string, string>? parameters)
    {
        try
        {
            var request = parameters?.Count > 0 ? new TriggerJobRequest(parameters) : null;
            await JobService.TriggerJobAsync(Id, request);
            await RefreshJobAsync();
            await RefreshRunsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to trigger: {ex.Message}";
        }
    }

    private async Task TriggerAsync()
    {
        try
        {
            await JobService.TriggerJobAsync(Id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to trigger: {ex.Message}";
        }
    }

    private async Task ExportYamlAsync()
    {
        try
        {
            _exportYaml = await JobService.ExportJobAsync(Id);
            _showExportModal = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to export YAML: {ex.Message}";
        }
    }

    private async Task StartAddSchedule()
    {
        await LoadTimeZonesAsync();
        _editingScheduleId = null;
        _scheduleForm = new ScheduleFormModel
        {
            Parameters = _editParams
                .Where(p => p.IsRequired && p.DefaultValue is null)
                .Select(p => new EditableTaskParameter { Key = p.Name, Value = "" })
                .ToList()
        };
        _showScheduleModal = true;
    }

    private async Task StartEditSchedule(ScheduleDto schedule)
    {
        await LoadTimeZonesAsync();
        _editingScheduleId = schedule.Id;
        _scheduleForm = new ScheduleFormModel
        {
            Cron = schedule.CronExpression,
            TimeZone = schedule.TimeZone,
            Parameters = schedule.Parameters is { Count: > 0 }
                ? schedule.Parameters.Select(kv => new EditableTaskParameter { Key = kv.Key, Value = kv.Value }).ToList()
                : [],
        };
        _showScheduleModal = true;
    }

    private async Task LoadTimeZonesAsync()
    {
        if (_timeZones.Count > 0) return;
        try
        {
            _timeZones = (await JobService.GetTimeZonesAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load time zones: {ex.Message}";
        }
    }

    private List<string> GetMissingRequiredScheduleParams()
    {
        return _editParams
            .Where(p => p.IsRequired && p.DefaultValue is null)
            .Where(p => !_scheduleForm.Parameters.Any(sp =>
                string.Equals(sp.Key?.Trim(), p.Name, StringComparison.OrdinalIgnoreCase)
                && !string.IsNullOrWhiteSpace(sp.Value)))
            .Select(p => p.Name)
            .ToList();
    }

    private async Task ConfirmSchedule()
    {
        if (string.IsNullOrWhiteSpace(_scheduleForm.Cron)) return;
        try
        {
            var parameters = _scheduleForm.Parameters.Count > 0
                ? _scheduleForm.Parameters
                    .Where(p => !string.IsNullOrWhiteSpace(p.Key))
                    .ToDictionary(p => p.Key, p => p.Value)
                : null;
            var tz = string.IsNullOrWhiteSpace(_scheduleForm.TimeZone) ? null : _scheduleForm.TimeZone.Trim();

            if (_editingScheduleId.HasValue)
            {
                await JobService.UpdateScheduleAsync(Id, _editingScheduleId.Value,
                    new UpdateScheduleRequest(_scheduleForm.Cron.Trim(), true, tz, parameters?.Count > 0 ? parameters : null));
            }
            else
            {
                await JobService.CreateScheduleAsync(Id,
                    new CreateScheduleRequest(_scheduleForm.Cron.Trim(), true, tz, parameters?.Count > 0 ? parameters : null));
            }
            _showScheduleModal = false;
            await RefreshJobAsync();
            MessageService.Success("Job updated");
        }
        catch (Exception ex)
        {
            _error = $"Failed to save schedule: {ex.Message}";
        }
    }

    private async Task ToggleScheduleEnabledAsync(ScheduleDto schedule, bool enabled)
    {
        try
        {
            await JobService.UpdateScheduleAsync(Id, schedule.Id,
                new UpdateScheduleRequest(schedule.CronExpression, enabled, schedule.TimeZone, schedule.Parameters));
            await RefreshJobAsync();
            MessageService.Success("Job updated");
        }
        catch (Exception ex)
        {
            _error = $"Failed to update schedule: {ex.Message}";
        }
    }

    private async Task DeleteScheduleAsync(ScheduleDto schedule)
    {
        try
        {
            await JobService.DeleteScheduleAsync(Id, schedule.Id);
            await RefreshJobAsync();
            MessageService.Success("Job updated");
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete schedule: {ex.Message}";
        }
    }

    private static string GetTaskTypeColor(TaskType taskType) => taskType switch
    {
        TaskType.Notebook => "blue",
        TaskType.SqlQuery => "purple",
        TaskType.SubJob => "orange",
        _ => "default",
    };

    private static string GetStatusColor(JobRunStatus status) => status switch
    {
        JobRunStatus.Succeeded => "green",
        JobRunStatus.Failed => "red",
        JobRunStatus.Running => "blue",
        JobRunStatus.Cancelled => "orange",
        _ => "default",
    };

    private static RenderFragment ParametersContent(Dictionary<string, string> parameters) =>
        @<div style="font-family: monospace; font-size: 12px; min-width: 160px;">
            @foreach (var kv in parameters)
            {
                <div><strong>@kv.Key</strong> = @kv.Value</div>
            }
        </div>;

    private async Task ConfirmInternalNavigationAsync(LocationChangingContext ctx)
    {
        if (!_isDirty) return;
        var confirmed = await JS.InvokeAsync<bool>("confirm", "You have unsaved changes. Are you sure you want to leave?");
        if (!confirmed)
            ctx.PreventNavigation();
    }
}
