@page "/nodes/{Name}/kernels/{KernelId}"
@attribute [Authorize(Policy = AuthPolicy.NodePoolOperate)]

@using DuckHouse.Core.Kernels
@using DuckHouse.Ui.Shared.Kernels
@using System.Text.RegularExpressions
@inject IKernelService KernelService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Kernel session — DuckHouse</PageTitle>

<Breadcrumb Style="margin-bottom: 12px;">
    <BreadcrumbItem Href="/nodes">Nodes</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/nodes/{Name}/kernels")">@Name</BreadcrumbItem>
    <BreadcrumbItem>@ShortId</BreadcrumbItem>
</Breadcrumb>

<Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 12px;">
    <Space Align="SpaceAlign.End" Size="SpaceSize.Small">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.Code" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">Kernel Session</h2>
        </SpaceItem>
        @if (_kernel is not null)
        {
            <SpaceItem>
                <Tag Color="@StatusTagColor(_kernel.Status)">@_kernel.Status</Tag>
            </SpaceItem>
        }
    </Space>
    <Space>
        @if (_executing)
        {
            <SpaceItem>
                <Button Size="ButtonSize.Small"
                        Loading="_actionBusy" Disabled="_actionBusy"
                        Icon="@IconType.Outline.PauseCircle"
                        OnClick="InterruptAsync">
                    Interrupt
                </Button>
            </SpaceItem>
        }
        <SpaceItem>
            <Button Type="ButtonType.Primary" Size="ButtonSize.Small"
                    Loading="_actionBusy" Disabled="@(_actionBusy || _executing)"
                    Icon="@IconType.Outline.Sync"
                    OnClick="RestartAsync">
                Restart
            </Button>
        </SpaceItem>
        <SpaceItem>
            <Popconfirm Title="@($"Are you sure you want to delete kernel '{ShortId}'? The session history will be lost.")"
                        OkText="Delete"
                        CancelText="Cancel"
                        OkType="ButtonType.Primary"
                        OkButtonProps="new ButtonProps { Danger = true }"
                        OnConfirm="DeleteAsync">
                <Button Danger Type="ButtonType.Primary" Size="ButtonSize.Small"
                        Loading="_actionBusy" Disabled="_actionBusy"
                        Icon="@IconType.Outline.Delete">
                    Delete...
                </Button>
            </Popconfirm>
        </SpaceItem>
    </Space>
</Flex>

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
}

@if (_loading)
{
    <Flex Justify="@("center")" Style="padding: 40px 0;">
        <Spin />
    </Flex>
}
else if (_kernelNotFound)
{
    <Alert Type="AlertType.Warning" ShowIcon="true"
           Message="@($"Kernel {KernelId} was not found on node {Name}.")" />
}
else
{
    <div style="margin-bottom: 12px;">
        @if (_history.Count == 0)
        {
            <p style="font-style: italic; font-size: 0.875rem;"><Text Type="TextElementType.Secondary">No executions yet.</Text></p>
        }
        @foreach (var entry in _history)
        {
            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [@(entry.ExecutionCount?.ToString() ?? " ")]:</span>
                <CodeCell Value="@entry.Code" ReadOnly="true" Class="editor-fill" />
            </div>

            @foreach (var output in entry.Result.Outputs)
            {
                @if (output.Type == "stream")
                {
                    bool isStderr = output.Name == "stderr";
                    <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                        <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                        @if (isStderr)
                        {
                            <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid var(--ant-color-warning); padding-left: 8px;"><Text Type="TextElementType.Warning">@output.Text</Text></pre>
                        }
                        else
                        {
                            <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid var(--ant-color-border); padding-left: 8px;">@output.Text</pre>
                        }
                    </div>
                }
                else if (output.Type is "execute_result" or "display_data")
                {
                    string outLabel = $"Out[{output.ExecutionCount ?? entry.ExecutionCount}]:";

                    @if (output.Data is not null
                         && output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                         && DataFrameOutput.TryParse(dfRaw) is { } dfOutput)
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                            <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                            <div style="flex: 1 1 0%; border-left: 3px solid; padding-left: 8px; min-width: 0;">
                                <DataFrameView Data="dfOutput" />
                            </div>
                        </div>
                    }
                    else
                    {
                        string? htmlText = GetDataText(output.Data, "text/html");
                        string? plainText = GetDataText(output.Data, "text/plain") ?? output.Text;

                        @if (htmlText is not null)
                        {
                            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                                <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                                <div style="flex: 1 1 0%; border-left: 3px solid; padding-left: 8px; font-size: 0.875rem;">@((MarkupString)htmlText)</div>
                            </div>
                        }
                        else if (plainText is not null)
                        {
                            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                                <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">@outLabel</span>
                                <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; flex: 1 1 0%; border-left: 3px solid; padding-left: 8px;">@plainText</pre>
                            </div>
                        }
                    }
                }
            }

            @if (entry.Result.Error is { } err)
            {
                <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                    <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                    <div style="flex: 1 1 0%; border-left: 3px solid; padding-left: 8px; border-radius: 0 4px 4px 0; padding: 8px 8px 8px 12px;">
                        <Text Type="TextElementType.Danger" Strong Style="display: block; font-size: 0.875rem; margin-bottom: 4px;">@err.Ename: @err.Evalue</Text>
                        <pre class="kernel-pre" style="font-family: monospace; font-size: 0.875rem; margin: 0;"><Text Type="TextElementType.Danger">@string.Join("\n", err.Traceback.Select(StripAnsi))</Text></pre>
                    </div>
                </div>
            }

            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <ExecutionTimer DurationMs="entry.Result.DurationMs" />
                    @if (ExtractRowCount(entry.Result) is { } rowCount)
                    {
                        bool atCap = rowCount == DataFrameOutput.RowCap;
                        <span><Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">· @rowCount.ToString("N0")@(atCap ? "+" : "") rows</Text></span>
                    }
                </div>
            </div>

            <Divider Style="margin: 8px 0; opacity: 0.4;" />
        }

        @if (_executingCode is not null)
        {
            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                <span style="font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                <CodeCell Value="@_executingCode" ReadOnly="true" Class="editor-fill" />
            </div>
            <div style="display: flex; gap: 8px; margin-bottom: 4px; align-items: flex-start;">
                <span style="visibility: hidden; font-family: monospace; font-size: 0.875rem; white-space: nowrap; padding-top: 4px;">In [ ]:</span>
                <Space Align="SpaceAlign.Center">
                    <SpaceItem><ExecutionTimer IsRunning="true" /></SpaceItem>
                    <SpaceItem>
                        <Button Size="ButtonSize.Small"
                                Loading="_actionBusy" Disabled="_actionBusy"
                                Icon="@IconType.Outline.PauseCircle"
                                OnClick="InterruptAsync">
                            Interrupt
                        </Button>
                    </SpaceItem>
                </Space>
            </div>
        }
    </div>

    <KernelCodeCell @bind-Value="_code"
                    NodeName="@Name"
                    KernelId="@KernelId"
                    Height="160"
                    ReadOnly="@(_isDead || _executing)"
                    OnExecute="ExecuteAsync"
                    PriorContext="@(() => string.Join("\n", _history.Select(h => h.Code)))"
                    Class="editor-cell-mb2" />
    <Space Align="SpaceAlign.Center">
        <SpaceItem>
            <Button Type="ButtonType.Primary"
                    Loading="_executing"
                    Disabled="@(_executing || _isDead || string.IsNullOrWhiteSpace(_code))"
                    Icon="@IconType.Outline.PlayCircle"
                    OnClick="ExecuteAsync">
                Run
            </Button>
        </SpaceItem>
        <SpaceItem><Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">or Ctrl+Enter</Text></SpaceItem>
        @if (_isDead)
        {
            <SpaceItem><Tag Color='("error")'>Kernel is dead — restart to continue</Tag></SpaceItem>
        }
    </Space>
}

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string KernelId { get; set; } = "";

    private record HistoryEntry(int? ExecutionCount, string Code, ExecutionResult Result);

    private KernelInfo? _kernel;
    private List<HistoryEntry> _history = [];
    private bool _loading = true;
    private bool _kernelNotFound;
    private string? _error;
    private string _code = "";
    private bool _executing;
    private string? _executingCode;
    private bool _actionBusy;
    private readonly CancellationTokenSource _pollingCts = new();

    private string ShortId => KernelId.Length > 8 ? KernelId[..8] + "…" : KernelId;
    private bool _isDead => _kernel?.Status == KernelStatus.Dead;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _kernel = await KernelService.GetKernelAsync(Name, KernelId);
            _ = PollKernelStatusAsync(_pollingCts.Token);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _kernelNotFound = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load kernel: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PollKernelStatusAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_executing || _actionBusy) continue;
                try
                {
                    _kernel = await KernelService.GetKernelAsync(Name, KernelId, cancellationToken);
                    await InvokeAsync(StateHasChanged);
                }
                catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _kernel = _kernel is not null ? _kernel with { Status = KernelStatus.Dead } : null;
                    _error = "The kernel was evicted, likely due to inactivity.";
                    await InvokeAsync(StateHasChanged);
                    break;
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch { /* ignore transient errors — will retry on next tick */ }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task ExecuteAsync()
    {
        if (string.IsNullOrWhiteSpace(_code) || _isDead) return;

        _executing = true;
        _error = null;
        var codeToRun = _code;
        _code = "";
        _executingCode = codeToRun;
        if (_kernel is not null)
            _kernel = _kernel with { Status = KernelStatus.Busy };
        try
        {
            var handle = await KernelService.StartExecuteAsync(Name, KernelId, new ExecuteKernelRequest(codeToRun));

            // Poll every second until the execution completes.
            PollExecutionResponse poll;
            do
            {
                await Task.Delay(1000);
                poll = await KernelService.PollExecutionAsync(Name, KernelId, handle.ExecutionId);
                StateHasChanged(); // keep the running timer ticking
            } while (!poll.IsComplete);

            var result = poll.Result!;
            _history.Add(new HistoryEntry(result.ExecutionCount, codeToRun, result));
            _kernel = await KernelService.GetKernelAsync(Name, KernelId);
        }
        catch (Exception ex)
        {
            _code = codeToRun;
            _error = $"Execution failed: {ex.Message}";
        }
        finally
        {
            _executingCode = null;
            _executing = false;
        }
    }

    private async Task RestartAsync()
    {
        _actionBusy = true;
        _error = null;
        try
        {
            _kernel = await KernelService.RestartKernelAsync(Name, KernelId);
            _history.Clear();
        }
        catch (Exception ex)
        {
            _error = $"Failed to restart kernel: {ex.Message}";
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private async Task InterruptAsync()
    {
        _actionBusy = true;
        _error = null;
        try
        {
            await KernelService.InterruptKernelAsync(Name, KernelId);
            _kernel = await KernelService.GetKernelAsync(Name, KernelId);
        }
        catch (Exception ex)
        {
            _error = $"Failed to interrupt kernel: {ex.Message}";
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private async Task DeleteAsync()
    {
        _actionBusy = true;
        _error = null;
        try
        {
            await KernelService.DeleteKernelAsync(Name, KernelId);
            Navigation.NavigateTo($"nodes/{Name}/kernels");
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete kernel: {ex.Message}";
            _actionBusy = false;
        }
    }

    private static string? GetDataText(Dictionary<string, object>? data, string mimeType)
    {
        if (data?.TryGetValue(mimeType, out var value) != true) return null;
        return value?.ToString();
    }

    private static int? ExtractRowCount(ExecutionResult result)
    {
        foreach (var output in result.Outputs)
        {
            if (output.Type is not ("execute_result" or "display_data")) continue;

            // Prefer structured data — avoids regex and correctly returns 10 000 when cap was hit
            if (output.Data is not null
                && output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                && DataFrameOutput.TryParse(dfRaw) is { } df)
                return df.TotalRows;

            // Pandas plain-text: "[100 rows x 5 columns]" (actual row count, even when truncated)
            string? plainText = GetDataText(output.Data, "text/plain") ?? output.Text;
            if (plainText is not null)
            {
                var m = Regex.Match(plainText, @"\[(\d[\d,]*)\s+rows?\s+[x×]");
                if (m.Success && int.TryParse(m.Groups[1].Value.Replace(",", ""), out int n))
                    return n;
            }

            // Fallback: count <tr> elements inside <tbody> in HTML output
            string? html = GetDataText(output.Data, "text/html");
            if (html is not null)
            {
                var tbody = Regex.Match(html, @"<tbody[^>]*>(.*?)</tbody>", RegexOptions.Singleline);
                if (tbody.Success)
                {
                    int rows = Regex.Matches(tbody.Groups[1].Value, @"<tr[^>]*>").Count;
                    if (rows > 0) return rows;
                }
            }
        }
        return null;
    }

    private static string StripAnsi(string text) =>
        Regex.Replace(text, @"\x1B\[[0-9;]*[a-zA-Z]", "");

    private static string StatusTagColor(KernelStatus status) => status switch
    {
        KernelStatus.Idle                                     => "success",
        KernelStatus.Busy                                     => "warning",
        KernelStatus.Starting or KernelStatus.Restarting     => "processing",
        KernelStatus.Dead                                     => "error",
        _                                                     => "default"
    };

    public async ValueTask DisposeAsync()
    {
        await _pollingCts.CancelAsync();
        _pollingCts.Dispose();
    }
}

