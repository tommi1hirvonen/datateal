@page "/runs/{RunId:guid}/tasks/{TaskRunId:guid}/notebook"

@using DuckHouse.Ui.Shared.Orchestration
@inject IJobService JobService
@inject NavigationManager Navigation

<PageTitle>Notebook Output — DuckHouse</PageTitle>

<div style="padding: 24px;">
    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 16px; flex-wrap: wrap; gap: 8px;">
        <Space Align="SpaceAlign.Center" Size="SpaceSize.Small">
            <SpaceItem>
                <Button OnClick="@(() => Navigation.NavigateTo($"/runs/{RunId}"))">
                    <Icon Type="@IconType.Outline.ArrowLeft" /> Back to Run
                </Button>
            </SpaceItem>
            <SpaceItem>
                <h2 style="margin: 0;">Notebook Output</h2>
            </SpaceItem>
        </Space>
        @if (_hasRunningCells)
        {
            <Button OnClick="RefreshAsync">
                <Icon Type="@IconType.Outline.Reload" /> Refresh
            </Button>
        }
    </Flex>

    @if (!string.IsNullOrEmpty(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
               Style="margin-bottom: 16px;" />
    }

    <Spin Spinning="_loading">
        @foreach (var cell in _cells)
        {
            <div style="margin-bottom: 16px; border: 1px solid #d9d9d9; border-radius: 4px; overflow: hidden;">
                @* Cell header *@
                <div style="display: flex; justify-content: space-between; align-items: center;
                            padding: 4px 12px; background: #fafafa; border-bottom: 1px solid #d9d9d9; font-size: 12px;">
                    <Space>
                        <SpaceItem>
                            <Tag Color="@GetCellStatusColor(cell.Status)" Style="margin: 0;">@cell.Status</Tag>
                        </SpaceItem>
                        @if (cell.Language is not null)
                        {
                            <SpaceItem>
                                <span style="color: #888;">@cell.Language</span>
                            </SpaceItem>
                        }
                    </Space>
                    <Space>
                        @if (cell.ExecutionCount.HasValue)
                        {
                            <SpaceItem>
                                <span style="color: #888;">[@cell.ExecutionCount]</span>
                            </SpaceItem>
                        }
                        @if (cell.DurationMs.HasValue)
                        {
                            <SpaceItem>
                                <span style="color: #888;">@($"{cell.DurationMs.Value:F0}ms")</span>
                            </SpaceItem>
                        }
                    </Space>
                </div>

                @* Cell source *@
                <pre style="margin: 0; padding: 12px; background: #f5f5f5; font-size: 13px;
                            font-family: 'Cascadia Code', 'Consolas', monospace; overflow-x: auto;">@cell.CellSource</pre>

                @* Cell output/error *@
                @if (!string.IsNullOrEmpty(cell.OutputsJson))
                {
                    <div style="padding: 8px 12px; border-top: 1px solid #f0f0f0; font-size: 13px;">
                        <pre style="margin: 0; white-space: pre-wrap; word-break: break-word;">@cell.OutputsJson</pre>
                    </div>
                }
                @if (!string.IsNullOrEmpty(cell.ErrorJson))
                {
                    <div style="padding: 8px 12px; border-top: 1px solid #f0f0f0;
                                background: #fff2f0; color: #ff4d4f; font-size: 13px;">
                        <pre style="margin: 0; white-space: pre-wrap; word-break: break-word;">@cell.ErrorJson</pre>
                    </div>
                }
            </div>
        }

        @if (_cells.Count == 0 && !_loading)
        {
            <Alert Type="@AlertType.Info" Message="No cell outputs available yet." />
        }
    </Spin>
</div>

@code {
    [Parameter] public Guid RunId { get; set; }
    [Parameter] public Guid TaskRunId { get; set; }

    private IReadOnlyList<CellOutputDto> _cells = [];
    private bool _loading = true;
    private bool _hasRunningCells;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _cells = await JobService.GetCellOutputsAsync(RunId, TaskRunId);
            _hasRunningCells = _cells.Any(c => c.Status is "Running" or "Pending");
        }
        catch (Exception ex)
        {
            _error = $"Failed to load cell outputs: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync() => await LoadAsync();

    private static string GetCellStatusColor(string status) => status.ToLowerInvariant() switch
    {
        "succeeded" => "green",
        "failed" => "red",
        "running" => "blue",
        "pending" => "default",
        "skipped" => "default",
        _ => "default",
    };
}
