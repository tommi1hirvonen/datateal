@page "/query"
@page "/query/{Id:guid}"

@using DuckHouse.Core.Kernels
@using DuckHouse.Core.Nodes
@using DuckHouse.Ui.Shared.Kernels
@using DuckHouse.Ui.Shared.Workspace
@using DuckHouse.Ui.Shared.Catalogs
@inject IKernelService KernelService
@inject INodeService NodeService
@inject IWorkspaceService WorkspaceService
@inject ICatalogService CatalogService
@inject NavigationManager Navigation
@implements IAsyncDisposable

@inject IJSRuntime JS

<PageTitle>Query — DuckHouse</PageTitle>

<div class="qp-page">

@* ── Title row ── *@
<Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap; gap: 8px; flex-shrink: 0;">
    <Space Align="SpaceAlign.End" Size="SpaceSize.Middle">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.Code" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">
                @if (_editingTitle)
                {
                    <Input Style="width: 24ch; font-size: inherit;"
                           @bind-Value="_editingTitleValue"
                           OnPressEnter="@(_ => CommitTitleEdit())"
                           OnBlur="@(_ => CommitTitleEdit())" />
                }
                else
                {
                    <span style="cursor: pointer;" @onclick="StartEditTitle">
                        @_title@(_isDirty ? " *" : "")
                    </span>
                }
            </h2>
        </SpaceItem>
    </Space>

    @* File toolbar *@
    <Space Size="SpaceSize.Small" Style="flex-wrap: wrap;">
        <SpaceItem>
            <Button OnClick="@(() => Navigation.NavigateTo("/workspace"))" Icon="@IconType.Outline.FolderOpen">
                Browse workspace
            </Button>
        </SpaceItem>
        @if (_workspaceQueryId.HasValue)
        {
            <SpaceItem>
                <Button Disabled="@(!_isDirty)" Icon="@IconType.Outline.Save" OnClick="SaveToWorkspaceAsync">
                    Save
                </Button>
            </SpaceItem>
        }
        else
        {
            <SpaceItem>
                <Button Disabled="@(!_isDirty)" Icon="@IconType.Outline.CloudUpload" OnClick="OpenFolderPickerAsync">
                    Save to workspace
                </Button>
            </SpaceItem>
        }
    </Space>
</Flex>

@* Workspace breadcrumb *@
@if (_workspaceQueryId.HasValue && _breadcrumbs.Count > 0)
{
    <Breadcrumb Style="margin-bottom: 8px;">
        @foreach (var crumb in _breadcrumbs)
        {
            <BreadcrumbItem>
                <a @onclick="() => NavigateToWorkspace(crumb.Id)" @onclick:preventDefault style="cursor: pointer;">
                    @crumb.Name
                </a>
            </BreadcrumbItem>
        }
        <BreadcrumbItem>@_title</BreadcrumbItem>
    </Breadcrumb>
}

@* Kernel connection bar *@
<Space Align="SpaceAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap;" Size="SpaceSize.Small">
    <SpaceItem>
        <Icon Type="@IconType.Outline.CloudServer" />
    </SpaceItem>
    <SpaceItem>
        <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">Node:</Text>
    </SpaceItem>
    @if (_loadingNodes)
    {
        <SpaceItem><Spin Size="SpinSize.Small" /></SpaceItem>
    }
    else
    {
        <SpaceItem>
            <Select TItemValue="string"
                    TItem="NodeInfo"
                    DataSource="@_nodes.ToList()"
                    @bind-Value="@_nodeName"
                    ItemValue="n => n.Name"
                    ItemLabel="n => n.Name"
                    Placeholder="— select node —"
                    AllowClear
                    Disabled="@(_connecting || HasKernel)"
                    DropdownMatchSelectWidth="false"
                    Style="min-width: 150px;">
                <ItemTemplate>
                    @{ var node = (NodeInfo)context!; }
                    <span>@node.Name</span>
                    <Tag Color="@NodeStateTagColor(node.State)" Style="margin-left: 6px; font-size: 0.75rem;">@node.State</Tag>
                </ItemTemplate>
            </Select>
        </SpaceItem>
    }

    @if (!HasKernel)
    {
        <SpaceItem>
            <Button Type="ButtonType.Primary" Size="ButtonSize.Small"
                    Disabled="@(string.IsNullOrEmpty(_nodeName) || _connecting)"
                    Loading="_connecting"
                    Icon="@IconType.Outline.Api"
                    OnClick="ConnectAsync">
                @(SelectedNode?.State == NodeState.Running ? "Connect" : "Start and connect")
            </Button>
        </SpaceItem>
    }
    else
    {
        <SpaceItem><Tag Color="@StatusTagColor(_kernel!.Status)">@_kernel!.Status</Tag></SpaceItem>
        <SpaceItem>
            <Button Size="ButtonSize.Small"
                    Disabled="_disconnecting"
                    Loading="_disconnecting"
                    Icon="@IconType.Outline.Disconnect"
                    OnClick="DisconnectAsync">
                Disconnect
            </Button>
        </SpaceItem>
    }
</Space>

@* Catalog selector *@
<Space Align="SpaceAlign.Center" Style="margin-bottom: 12px; flex-wrap: wrap;" Size="SpaceSize.Small">
    <SpaceItem>
        <Icon Type="@IconType.Outline.Database" />
    </SpaceItem>
    <SpaceItem>
        <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">Catalogs:</Text>
    </SpaceItem>
    <SpaceItem>
        <Select TItemValue="string"
                TItem="CatalogDto"
                DataSource="@_allCatalogs.ToList()"
                @bind-Values="@_selectedCatalogNames"
                ItemValue="c => c.Name"
                ItemLabel="c => c.Name"
                Placeholder="— select catalogs —"
                AllowClear
                Mode="@SelectMode.Multiple"
                DropdownMatchSelectWidth="false"
                Style="min-width: 200px;"
                OnSelectedItemsChanged="OnCatalogSelectionChanged">
        </Select>
    </SpaceItem>
    @if (_selectedCatalogNames.Any())
    {
        <SpaceItem>
            <Button Size="ButtonSize.Small"
                    OnClick="() => _showCatalogExplorer = !_showCatalogExplorer"
                    Icon="@(_showCatalogExplorer ? IconType.Outline.EyeInvisible : IconType.Outline.Eye)">
                @(_showCatalogExplorer ? "Hide explorer" : "Show explorer")
            </Button>
        </SpaceItem>
    }
    @if (_catalogSetupRunning)
    {
        <SpaceItem>
            <Spin Size="SpinSize.Small" />
        </SpaceItem>
        <SpaceItem>
            <Text Type="TextElementType.Secondary" Style="font-size: 0.8rem;">Attaching catalogs…</Text>
        </SpaceItem>
    }
</Space>

@if (_showCatalogExplorer && _selectedCatalogNames.Any())
{
    <div style="margin-bottom: 12px; border: 1px solid #d9d9d9; border-radius: 6px; max-height: 300px; overflow: auto;">
        <CatalogExplorer CatalogNames="@_selectedCatalogNames.ToList()" />
    </div>
}

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 12px;" />
}

@* ── Split layout ── *@
<div class="qp-split">

    @* Top pane: editor + run toolbar *@
    <div id="qp-top-pane" class="qp-top-pane" style="height: @(_topHeightPx)px;">
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 8px; flex-shrink: 0;">
            <Text Type="TextElementType.Secondary" Strong Style="font-size: 0.875rem;">SQL</Text>
            <Space Size="SpaceSize.Small">
                @if (_isExecuting)
                {
                    <SpaceItem>
                        <ExecutionTimer IsRunning="true" DurationMs="null" />
                    </SpaceItem>
                    <SpaceItem>
                        <Button Size="ButtonSize.Small"
                                Icon="@IconType.Outline.Loading"
                                OnClick="InterruptAsync">
                            Interrupt
                        </Button>
                    </SpaceItem>
                }
                else
                {
                    @if (_lastDurationMs.HasValue)
                    {
                        <SpaceItem>
                            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">
                                <ExecutionTimer IsRunning="false" DurationMs="_lastDurationMs" />
                            </Text>
                        </SpaceItem>
                    }
                    <SpaceItem>
                        <Tooltip Title="@("Ctrl+Enter")">
                            <Button Type="ButtonType.Primary" Size="ButtonSize.Small"
                                    Disabled="@(!HasKernel || string.IsNullOrWhiteSpace(_sql))"
                                    Icon="@IconType.Outline.PlayCircle"
                                    OnClick="RunAsync">
                                @(string.IsNullOrWhiteSpace(_selectedSql) ? "Run all" : "Run selected")
                            </Button>
                        </Tooltip>
                    </SpaceItem>
                }
            </Space>
        </Flex>
        <div style="flex: 1 1 0%; overflow: hidden;">
            <CodeCell Value="@_sql"
                      ValueChanged="OnSqlChanged"
                      OnSelectionChanged="OnSqlSelectionChanged"
                      Language="sql"
                      Height="@_editorHeight"
                      ReadOnly="@_isExecuting"
                      OnExecute="RunAsync" />
        </div>
    </div>

    @* Drag handle *@
    <div id="qp-drag-handle" class="qp-drag-handle">
        <div class="qp-drag-handle-inner"></div>
    </div>

    @* Bottom pane: results *@
    <div class="qp-bottom-pane">
        @if (_isExecuting)
        {
            <Flex Justify="@("center")" Style="padding: 40px 0;"><Spin /></Flex>
        }
        else if (_resultDf is not null)
        {
            <div style="flex-shrink: 0; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">
                    @_resultDf.TotalRows.ToString("N0")@(_resultDf.TotalRows == DataFrameOutput.RowCap ? "+" : "") rows
                </Text>
                @if (_lastExecutedAt.HasValue)
                {
                    <span style="font-size: 0.75rem; opacity: 0.6;">Last run @_lastExecutedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                }
            </div>
            <div style="flex: 1 1 0%; overflow: auto;">
                <DataFrameView Data="_resultDf" Fill="true" />
            </div>
        }
        else if (_resultError is not null)
        {
            <div style="flex: 1 1 0%; overflow: auto;">
                <div class="qp-error-bar">
                    <Text Type="TextElementType.Danger" Strong Style="display: block; font-size: 0.875rem; margin-bottom: 4px;">@_resultError.Ename: @_resultError.Evalue</Text>
                    <pre style="font-family: monospace; font-size: 0.875rem; margin: 0; white-space: pre-wrap;"><Text Type="TextElementType.Danger">@string.Join("\n", _resultError.Traceback.Select(StripAnsi))</Text></pre>
                </div>
            </div>
        }
        else if (_resultText is not null)
        {
            <div style="flex: 1 1 0%; overflow: auto;">
                <pre style="font-family: monospace; font-size: 0.875rem; margin: 0;">@_resultText</pre>
            </div>
        }
        else
        {
            <div style="flex: 1 1 0%; display: flex; align-items: center; justify-content: center; flex-direction: column;">
                <Icon Type="@IconType.Outline.Table" Style="font-size: 40px; opacity: 0.25;" />
                <p style="margin-top: 12px;"><Text Type="TextElementType.Secondary">Run a query to see results here.</Text></p>
            </div>
        }
    </div>
</div>

</div>@* end .qp-page *@

@* Folder picker modal — shown when saving to workspace for the first time *@
<FolderPickerModal Visible="_showFolderPicker"
                   Title="@("Choose folder to save in")"
                   OkText="@("Save here")"
                   OnConfirm="ConfirmSaveToFolderAsync"
                   OnCancel="@(() => _showFolderPicker = false)" />

@code {
    [Parameter] public Guid Id { get; set; }

    private string _title = "Untitled Query";
    private string _sql = "";
    private bool _isDirty;
    private bool _editingTitle;
    private string _editingTitleValue = "";

    private Guid? _workspaceQueryId;
    private Guid? _workspaceQueryFolderId;
    private List<(Guid? Id, string Name)> _breadcrumbs = [];
    private bool _showFolderPicker;

    private string? _nodeName;
    private string? _kernelId;
    private KernelInfo? _kernel;
    private IReadOnlyList<NodeInfo> _nodes = [];
    private bool _loadingNodes;
    private bool _connecting;
    private bool _disconnecting;
    private string? _error;
    private CancellationTokenSource? _kernelPollingCts;

    private bool _isExecuting;
    private double? _lastDurationMs;
    private DateTime? _lastExecutedAt;
    private DataFrameOutput? _resultDf;
    private ErrorInfo? _resultError;
    private string? _resultText;
    private string _selectedSql = "";

    private int _topHeightPx = 300;
    private int _editorHeight => Math.Max(40, _topHeightPx - 56);

    private DotNetObjectReference<QueryPage>? _dotNetRef;

    // Catalogs
    private IReadOnlyList<CatalogDto> _allCatalogs = [];
    private IEnumerable<string> _selectedCatalogNames = [];
    private bool _showCatalogExplorer;
    private bool _catalogSetupRunning;

    private bool HasKernel => !string.IsNullOrEmpty(_kernelId);

    protected override async Task OnInitializedAsync()
    {
        if (Id != Guid.Empty)
        {
            try
            {
                var detail = await WorkspaceService.GetQueryAsync(Id);
                if (detail is not null)
                {
                    _title = detail.Title;
                    _sql = detail.Content;
                    _isDirty = false;
                    _workspaceQueryId = detail.Id;
                    _workspaceQueryFolderId = detail.FolderId;

                    // Restore last execution result if present
                    if (detail.LastResult is { } lr)
                    {
                        _lastDurationMs = lr.DurationMs;
                        _lastExecutedAt = lr.ExecutedAt;
                        _resultDf = lr.DataFrame;
                        _resultText = lr.Text;
                        _resultError = lr.Error;
                    }

                    if (detail.FolderId is not null)
                    {
                        var ancestors = await WorkspaceService.GetFolderAncestorsAsync(detail.FolderId.Value);
                        _breadcrumbs = [(null, "Workspace"), ..ancestors.Select(f => ((Guid?)f.Id, f.Name))];
                    }
                    else
                    {
                        _breadcrumbs = [(null, "Workspace")];
                    }
                }
                else
                {
                    _error = "Query not found in workspace.";
                }
            }
            catch (Exception ex)
            {
                _error = $"Failed to load query: {ex.Message}";
            }
        }
        else
        {
            _title = $"Untitled Query {DateTime.Now:yyyy-MM-dd HH:mm:ss}";
            _isDirty = true;
        }

        _loadingNodes = true;
        try { _nodes = await NodeService.GetNodesAsync(); }
        catch (Exception ex) { _error = $"Failed to load nodes: {ex.Message}"; }
        finally { _loadingNodes = false; }

        // Load available catalogs
        try { _allCatalogs = await CatalogService.GetCatalogsAsync(); }
        catch { /* non-fatal */ }

        // Restore saved catalog selections
        if (_workspaceQueryId.HasValue)
        {
            try
            {
                var savedNames = await CatalogService.GetWorkspaceItemCatalogsAsync(_workspaceQueryId.Value);
                _selectedCatalogNames = savedNames;
            }
            catch { /* non-fatal */ }
        }

        // Restore last-used node preference
        if (_workspaceQueryId.HasValue)
        {
            try
            {
                var storedNode = await JS.InvokeAsync<string>("getItemNodePref", _workspaceQueryId.Value.ToString());
                if (!string.IsNullOrEmpty(storedNode))
                {
                    var match = _nodes.FirstOrDefault(n => n.Name == storedNode);
                    if (match is not null)
                    {
                        _nodeName = match.Name;
                        if (match.State == NodeState.Running)
                            _ = ConnectAsync();
                    }
                }
            }
            catch { /* JS interop failure is non-fatal */ }
        }
    }

    // ── Title editing ─────────────────────────────────────────────────

    private void StartEditTitle()
    {
        _editingTitleValue = _title;
        _editingTitle = true;
    }

    private void CommitTitleEdit()
    {
        var value = string.IsNullOrWhiteSpace(_editingTitleValue) ? "Untitled Query" : _editingTitleValue;
        if (value.Contains('/'))
        {
            _error = "Query title cannot contain '/'.";
            return;
        }
        _title = value;
        _isDirty = true;
        _editingTitle = false;
    }

    private void OnSqlChanged(string value)
    {
        _sql = value;
        _isDirty = true;
    }

    private void OnSqlSelectionChanged(string selected)
    {
        if (_selectedSql == selected) return;
        _selectedSql = selected;
        StateHasChanged();
    }

    // ── Workspace persistence ─────────────────────────────────────────

    private void OpenFolderPickerAsync() => _showFolderPicker = true;

    private async Task ConfirmSaveToFolderAsync(Guid? folderId)
    {
        _showFolderPicker = false;
        try
        {
            var summary = await WorkspaceService.CreateQueryAsync(new CreateQueryRequest(_title, _sql, folderId));
            _workspaceQueryId = summary.Id;
            _workspaceQueryFolderId = folderId;
            _isDirty = false;

            if (folderId is not null)
            {
                var ancestors = await WorkspaceService.GetFolderAncestorsAsync(folderId.Value);
                _breadcrumbs = [(null, "Workspace"), ..ancestors.Select(f => ((Guid?)f.Id, f.Name))];
            }
            else
            {
                _breadcrumbs = [(null, "Workspace")];
            }

            Navigation.NavigateTo($"/query/{summary.Id}", replace: true);
        }
        catch (Exception ex) { _error = $"Failed to save query: {ex.Message}"; }
    }

    private async Task SaveToWorkspaceAsync()
    {
        if (!_workspaceQueryId.HasValue) return;
        try
        {
            await WorkspaceService.UpdateQueryAsync(_workspaceQueryId.Value,
                new UpdateQueryRequest(_title, _sql, _workspaceQueryFolderId));
            _isDirty = false;
        }
        catch (Exception ex) { _error = $"Failed to save query: {ex.Message}"; }
    }

    private void NavigateToWorkspace(Guid? folderId) =>
        Navigation.NavigateTo(folderId is null ? "/workspace" : $"/workspace?folder={folderId}");

    // ── Kernel connection ─────────────────────────────────────────────

    private NodeInfo? SelectedNode => _nodes.FirstOrDefault(n => n.Name == _nodeName);

    private async Task ConnectAsync()
    {
        if (string.IsNullOrEmpty(_nodeName)) return;
        _connecting = true;
        _error = null;
        try
        {
            // Start node first if it isn't already running
            if (SelectedNode?.State != NodeState.Running)
            {
                await NodeService.StartNodeAsync(_nodeName);
                var deadline = DateTime.UtcNow.AddMinutes(10);
                while (DateTime.UtcNow < deadline)
                {
                    await Task.Delay(3000);
                    var updated = await NodeService.GetNodeAsync(_nodeName);
                    if (updated is null) throw new Exception("Node not found.");
                    _nodes = _nodes.Select(n => n.Name == _nodeName ? updated : n).ToList();
                    StateHasChanged();
                    if (updated.State == NodeState.Running) break;
                    if (updated.State == NodeState.Failure) throw new Exception("Node failed to start.");
                }
                if (SelectedNode?.State != NodeState.Running)
                    throw new Exception("Node did not reach Running state in time.");
            }

            var kernel = await KernelService.CreateKernelAsync(_nodeName);
            _kernelId = kernel.Id;
            _kernel = kernel;
            _kernelPollingCts = new CancellationTokenSource();
            _ = PollKernelStatusAsync(_kernelPollingCts.Token);
            if (_workspaceQueryId.HasValue)
                await JS.InvokeVoidAsync("setItemNodePref", _workspaceQueryId.Value.ToString(), _nodeName);

            // Attach catalogs if any are selected
            await SetupCatalogsAsync();
        }
        catch (Exception ex) { _error = $"Failed to connect: {ex.Message}"; }
        finally { _connecting = false; }
        StateHasChanged();
    }

    private async Task DisconnectAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName)) return;
        _disconnecting = true;
        _error = null;
        try
        {
            await StopKernelPollingAsync();
            await KernelService.DeleteKernelAsync(_nodeName, _kernelId!);
            _kernelId = null;
            _kernel = null;
        }
        catch (Exception ex) { _error = $"Failed to disconnect: {ex.Message}"; }
        finally { _disconnecting = false; }
    }

    private async Task PollKernelStatusAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_isExecuting || string.IsNullOrEmpty(_kernelId) || string.IsNullOrEmpty(_nodeName))
                    continue;
                try
                {
                    _kernel = await KernelService.GetKernelAsync(_nodeName, _kernelId, cancellationToken);
                    await InvokeAsync(StateHasChanged);
                }
                catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _kernelId = null;
                    _kernel = null;
                    _error = "The kernel was evicted, likely due to inactivity. Please reconnect.";
                    await InvokeAsync(StateHasChanged);
                    break;
                }
                catch (OperationCanceledException) { break; }
                catch { /* ignore transient errors */ }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task StopKernelPollingAsync()
    {
        if (_kernelPollingCts is not null)
        {
            await _kernelPollingCts.CancelAsync();
            _kernelPollingCts.Dispose();
            _kernelPollingCts = null;
        }
    }

    // ── Execution ─────────────────────────────────────────────────────

    private async Task RunAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName) || _isExecuting || string.IsNullOrWhiteSpace(_sql)) return;

        var sqlToRun = !string.IsNullOrWhiteSpace(_selectedSql) ? _selectedSql : _sql;

        _isExecuting = true;
        _resultDf = null;
        _resultError = null;
        _resultText = null;
        _lastDurationMs = null;
        _lastExecutedAt = null;
        _error = null;

        if (_kernel is not null)
            _kernel = _kernel with { Status = KernelStatus.Busy };

        var codeToRun = $"import duckdb; duckdb.sql(\"\"\"{sqlToRun}\"\"\")";

        try
        {
            var handle = await KernelService.StartExecuteAsync(_nodeName, _kernelId!, new ExecuteKernelRequest(codeToRun));

            PollExecutionResponse poll;
            do
            {
                await Task.Delay(1000);
                poll = await KernelService.PollExecutionAsync(_nodeName, _kernelId!, handle.ExecutionId);
                StateHasChanged();
            } while (!poll.IsComplete);

            var result = poll.Result!;
            _lastDurationMs = result.DurationMs;
            _lastExecutedAt = DateTime.UtcNow;
            _resultError = result.Error;

            // Find the most relevant output
            foreach (var output in result.Outputs)
            {
                if (output.Type is "execute_result" or "display_data" && output.Data is not null)
                {
                    if (output.Data.TryGetValue(DataFrameOutput.MimeType, out var dfRaw)
                        && DataFrameOutput.TryParse(dfRaw) is { } df)
                    {
                        _resultDf = df;
                        break;
                    }
                    if (output.Data.TryGetValue("text/plain", out var plain))
                    {
                        _resultText = plain?.ToString();
                        break;
                    }
                }
                else if (output.Type == "stream" && output.Text is not null)
                {
                    _resultText = (_resultText ?? "") + output.Text;
                }
            }

            _kernel = await KernelService.GetKernelAsync(_nodeName, _kernelId!);

            // Auto-save result to workspace if this query is persisted
            if (_workspaceQueryId.HasValue)
            {
                var status = _resultError is not null ? "Error"
                    : _resultDf is not null || _resultText is not null ? "Success"
                    : "Empty";
                try
                {
                    await WorkspaceService.SaveQueryResultAsync(
                        _workspaceQueryId.Value,
                        new SaveQueryResultRequest(status, _lastDurationMs ?? 0, _resultDf, _resultText, _resultError));
                }
                catch (Exception ex) { _error = $"Result saved locally but failed to persist: {ex.Message}"; }
            }
        }
        catch (Exception ex) { _error = $"Execution failed: {ex.Message}"; }
        finally
        {
            _isExecuting = false;
            StateHasChanged();
        }
    }

    private async Task InterruptAsync()
    {
        if (!HasKernel || string.IsNullOrEmpty(_nodeName)) return;
        try { await KernelService.InterruptKernelAsync(_nodeName, _kernelId!); }
        catch (Exception ex) { _error = $"Interrupt failed: {ex.Message}"; }
    }

    // ── Helpers ───────────────────────────────────────────────────────

    private static string StatusTagColor(KernelStatus status) => status switch
    {
        KernelStatus.Idle => "green",
        KernelStatus.Busy => "blue",
        KernelStatus.Starting => "orange",
        KernelStatus.Dead => "red",
        _ => "default",
    };

    private static string NodeStateTagColor(NodeState state) => state switch
    {
        NodeState.Running => "success",
        NodeState.Stopped => "default",
        NodeState.Failure => "error",
        _ => "warning",
    };

    private static string StripAnsi(string text) =>
        System.Text.RegularExpressions.Regex.Replace(text, @"\x1B\[[0-9;]*[a-zA-Z]", "");

    // ── Catalog management ───────────────────────────────────────────

    private async Task OnCatalogSelectionChanged(IEnumerable<CatalogDto> _)
    {
        if (!_workspaceQueryId.HasValue) return;
        try
        {
            await CatalogService.UpdateWorkspaceItemCatalogsAsync(
                _workspaceQueryId.Value, _selectedCatalogNames.ToList());
        }
        catch (Exception ex) { _error = $"Failed to save catalog selection: {ex.Message}"; }
    }

    private async Task SetupCatalogsAsync()
    {
        var names = _selectedCatalogNames.ToList();
        if (names.Count == 0 || !HasKernel || string.IsNullOrEmpty(_nodeName)) return;

        _catalogSetupRunning = true;
        StateHasChanged();

        try
        {
            var resolved = await CatalogService.ResolveCatalogsAsync(names);
            if (resolved.Count == 0) return;

            var script = CatalogSetupGenerator.GenerateSetupScript(resolved, isLinux: true);
            var handle = await KernelService.StartExecuteAsync(
                _nodeName, _kernelId!, new ExecuteKernelRequest(script));

            PollExecutionResponse poll;
            do
            {
                await Task.Delay(1000);
                poll = await KernelService.PollExecutionAsync(_nodeName, _kernelId!, handle.ExecutionId);
            } while (!poll.IsComplete);

            if (poll.Result?.Error is not null)
            {
                _error = $"Catalog setup failed: {poll.Result.Error.Evalue}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Catalog setup failed: {ex.Message}";
        }
        finally
        {
            _catalogSetupRunning = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initQueryPageSplitter", "qp-top-pane", "qp-drag-handle", _dotNetRef);
        }
    }

    [JSInvokable]
    public void OnSplitterDragEnd(double height)
    {
        _topHeightPx = Math.Max(80, (int)height);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await StopKernelPollingAsync();
        if (HasKernel && !string.IsNullOrEmpty(_nodeName))
        {
            try { await KernelService.DeleteKernelAsync(_nodeName, _kernelId!); }
            catch { /* best effort */ }
        }
    }
}
