@page "/nodes"
@attribute [Authorize(Policy = AuthPolicy.NodePoolOperate)]

@using DuckHouse.Core.Nodes
@inject INodeService NodeService

<PageTitle>Active nodes — DuckHouse</PageTitle>

<Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;" Gap="FlexGap.Small">
    <Space Align="SpaceAlign.End" Size="SpaceSize.Middle">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.CloudServer" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">Active nodes</h2>
        </SpaceItem>
    </Space>
    <Space>
        <SpaceItem>
            <Button OnClick="LoadNodesAsync"
                    Disabled="@(_loading || _busy is not null)"
                    Icon=@IconType.Outline.Reload>
                Refresh
            </Button>
        </SpaceItem>
    </Space>
</Flex>

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
}

@if (_loading)
{
    <Flex Justify="@("center")" Style="padding: 40px 0;">
        <Spin />
    </Flex>
}
else if (_nodes.Count == 0)
{
    <p><Text Type="TextElementType.Secondary">No active nodes.</Text></p>
}
else
{
    <Table TItem="NodeInfo" DataSource="@_nodes" Bordered PageSize="int.MaxValue" PaginationPosition="none">
        <PropertyColumn Property="n => n.Name" Title="Name">
            <span style="font-weight: 600;">@context.Name</span>
        </PropertyColumn>
        <PropertyColumn Property="n => n.State" Title="State">
            <Tag Color="@StateTagColor(context.State)">@context.State</Tag>
        </PropertyColumn>
        <PropertyColumn Property="n => n.VmSize" Title="VM size">
            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@(context.VmSize ?? "—")</Text>
        </PropertyColumn>
        <PropertyColumn Property="n => n.KernelIdleTimeout" Title="Kernel idle">
            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@FormatDuration(context.KernelIdleTimeout)</Text>
        </PropertyColumn>
        <PropertyColumn Property="n => n.NodeIdleTimeout" Title="Node idle">
            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@FormatDuration(context.NodeIdleTimeout)</Text>
        </PropertyColumn>
        <ActionColumn Title="Actions">
            <Space>
                <SpaceItem>
                    <Button Size="ButtonSize.Small"
                            Disabled="@(context.State != NodeState.Running)"
                            Icon="@IconType.Outline.Interaction"
                            OnClick="@(() => Navigation.NavigateTo($"nodes/{context.Name}/kernels"))">
                        Kernels
                    </Button>
                </SpaceItem>
                @{
                    var nodeName = context.Name;
                    var nodeBusy = _busy == nodeName;
                }
                <SpaceItem>
                    <Popconfirm Title="@($"Are you sure you want to remove '{context.Name}'?")"
                                OkText="Remove"
                                CancelText="Cancel"
                                OkType="ButtonType.Primary"
                                OkButtonProps="new ButtonProps { Danger = true }"
                                OnConfirm="@(() => RemoveNodeAsync(context.Name))">
                        <Button Size="ButtonSize.Small" Danger Type="ButtonType.Primary"
                                Loading="@nodeBusy" Disabled="@(nodeBusy || (_busy is not null && _busy != nodeName))"
                                Icon="@IconType.Outline.Delete">
                            Remove...
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
}

@code {
    @inject NavigationManager Navigation

    private List<NodeInfo> _nodes = [];
    private bool _loading = true;
    private string? _error;
    private string? _busy;

    protected override async Task OnInitializedAsync() => await LoadNodesAsync();

    private async Task LoadNodesAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _nodes = [.. await NodeService.GetNodesAsync()];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load nodes: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RemoveNodeAsync(string name)
    {
        _busy = name;
        _error = null;
        try
        {
            await NodeService.RemoveNodeAsync(name);
            _nodes.RemoveAll(n => n.Name == name);
        }
        catch (Exception ex)
        {
            _error = $"Failed to remove node '{name}': {ex.Message}";
        }
        finally
        {
            _busy = null;
        }
    }

    private static string StateTagColor(NodeState state) => state switch
    {
        NodeState.Running => "success",
        NodeState.Failure => "error",
        _ => "warning"
    };

    private static string FormatDuration(TimeSpan? ts)
    {
        if (ts is null) return "—";
        var t = ts.Value;
        if (t.TotalHours >= 1)
        {
            var h = (int)t.TotalHours;
            var m = t.Minutes;
            return m > 0 ? $"{h} h {m} min" : $"{h} h";
        }
        return $"{(int)t.TotalMinutes} min";
    }
}
