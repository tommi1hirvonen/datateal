@page "/nodes"

@using DuckHouse.Core.Nodes
@inject INodeService NodeService

<PageTitle>Nodes — DuckHouse</PageTitle>

<Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;" Gap="FlexGap.Small">
    <Space Align="SpaceAlign.End" Size="SpaceSize.Middle">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.CloudServer" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">Nodes</h2>
        </SpaceItem>
    </Space>
    <Space>
        <SpaceItem>
            <Button OnClick="LoadNodesAsync"
                    Disabled="@(_loading || _busy is not null)"
                    Icon=@IconType.Outline.Reload>
                Refresh
            </Button>
        </SpaceItem>
        <SpaceItem>
            <Button Type="ButtonType.Primary"
                    Icon="@IconType.Outline.Plus"
                    OnClick="OpenCreateDrawer">
                New node
            </Button>
        </SpaceItem>
    </Space>
</Flex>

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
}

@if (_loading)
{
    <Flex Justify="@("center")" Style="padding: 40px 0;">
        <Spin />
    </Flex>
}
else if (_nodes.Count == 0)
{
    <p><Text Type="TextElementType.Secondary">No nodes yet. Create one to get started.</Text></p>
}
else
{
    <Table TItem="NodeInfo" DataSource="@_nodes" Bordered PageSize="int.MaxValue" PaginationPosition="none">
        <PropertyColumn Property="n => n.Name" Title="Name">
            <span style="font-weight: 600;">@context.Name</span>
        </PropertyColumn>
        <PropertyColumn Property="n => n.State" Title="State">
            <Tag Color="@StateTagColor(context.State)">@context.State</Tag>
        </PropertyColumn>
        <PropertyColumn Property="n => n.VmSize" Title="VM Size">
            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@(context.VmSize ?? "—")</Text>
        </PropertyColumn>
        <PropertyColumn Property="n => n.KernelIdleTimeout" Title="Kernel Idle">
            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@FormatDuration(context.KernelIdleTimeout)</Text>
        </PropertyColumn>
        <PropertyColumn Property="n => n.NodeIdleTimeout" Title="Node Idle">
            <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@FormatDuration(context.NodeIdleTimeout)</Text>
        </PropertyColumn>
        <ActionColumn Title="Actions">
            <Space>
                <SpaceItem>
                    <Button Size="ButtonSize.Small"
                            Disabled="@(context.State != NodeState.Running)"
                            Icon="@IconType.Outline.Code"
                            OnClick="@(() => Navigation.NavigateTo($"nodes/{context.Name}/kernels"))">
                        Kernels
                    </Button>
                </SpaceItem>
                @if (context.State is NodeState.Stopped)
                {
                    var name = context.Name;
                    <SpaceItem>
                        <Button Size="ButtonSize.Small" Type="ButtonType.Primary"
                                Loading="@(_busy == name)" Disabled="@(_busy == name)"
                                Icon="@IconType.Outline.PlayCircle"
                                OnClick="@(() => StartNodeAsync(name))">
                            Start
                        </Button>
                    </SpaceItem>
                }
                @if (context.State is NodeState.Running)
                {
                    var name = context.Name;
                    <SpaceItem>
                        <Button Size="ButtonSize.Small"
                                Loading="@(_busy == name)" Disabled="@(_busy == name)"
                                Icon="@IconType.Outline.PauseCircle"
                                OnClick="@(() => StopNodeAsync(name))">
                            Stop
                        </Button>
                    </SpaceItem>
                }
                @{
                    var nodeName = context.Name;
                    var nodeBusy = _busy == nodeName;
                }
                <SpaceItem>
                    <Popconfirm Title="@($"Are you sure you want to remove '{context.Name}'?")"
                                OkText="Remove"
                                CancelText="Cancel"
                                OkType="ButtonType.Primary"
                                OkButtonProps="new ButtonProps { Danger = true }"
                                OnConfirm="@(() => RemoveNodeAsync(context.Name))">
                        <Button Size="ButtonSize.Small" Danger Type="ButtonType.Primary"
                                Loading="@nodeBusy" Disabled="@(nodeBusy || (_busy is not null && _busy != nodeName))"
                                Icon="@IconType.Outline.Delete">
                            Remove...
                        </Button>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
}

<Drawer @bind-Visible="_createOpen" Title='("New node")' Placement="DrawerPlacement.Right" Width="440" OnClose="CloseCreateDrawer">
    <div style="margin-bottom: 16px;">
        <label style="display: block; font-weight: 600; margin-bottom: 4px;">Name</label>
        <Input @bind-Value="_createName" Placeholder="my-node" />
    </div>
    <div style="margin-bottom: 16px;">
        <label style="display: block; font-weight: 600; margin-bottom: 4px;">VM Size</label>
        <Input @bind-Value="_createVmSize" Placeholder="Standard_D2as_v5" />
    </div>
    <div style="margin-bottom: 4px;">
        <label style="display: block; font-weight: 600; margin-bottom: 4px;">
            Kernel Idle Timeout
            <Text Type="TextElementType.Secondary" Style="font-weight: normal; margin-left: 4px;">(minutes)</Text>
        </label>
        <AntDesign.InputNumber TValue="int?" @bind-Value="_createKernelIdleMinutes" Min="1" Style="width: 100%;" Placeholder="Default" />
        <Text Type="TextElementType.Secondary" Style="font-size: 0.8rem;">How long a kernel can be idle before it is deleted. Leave blank to use the server default.</Text>
    </div>
    <div style="margin-bottom: 16px; margin-top: 12px;">
        <label style="display: block; font-weight: 600; margin-bottom: 4px;">
            Node Idle Timeout
            <Text Type="TextElementType.Secondary" Style="font-weight: normal; margin-left: 4px;">(minutes)</Text>
        </label>
        <AntDesign.InputNumber TValue="int?" @bind-Value="_createNodeIdleMinutes" Min="1" Style="width: 100%;" Placeholder="Default" />
        <Text Type="TextElementType.Secondary" Style="font-size: 0.8rem;">How long a node with no kernels can be idle before it is stopped. Leave blank to use the server default.</Text>
    </div>
    @if (_createError is not null)
    {
        <Alert Type="AlertType.Error" Message="@_createError" ShowIcon="true" Style="margin-bottom: 16px;" />
    }
    <Space>
        <SpaceItem>
            <Button OnClick="CloseCreateDrawer">Cancel</Button>
        </SpaceItem>
        <SpaceItem>
            <Button Type="ButtonType.Primary" Loading="_creating"
                    Disabled="@(string.IsNullOrWhiteSpace(_createName) || string.IsNullOrWhiteSpace(_createVmSize))"
                    Icon="@IconType.Outline.Plus"
                    OnClick="CreateNodeAsync">
                Create
            </Button>
        </SpaceItem>
    </Space>
</Drawer>

@code {
    @inject NavigationManager Navigation

    private List<NodeInfo> _nodes = [];
    private bool _loading = true;
    private string? _error;
    private string? _busy;

    private bool _createOpen;
    private string _createName = "";
    private string _createVmSize = "";
    private int? _createKernelIdleMinutes;
    private int? _createNodeIdleMinutes;
    private bool _creating;
    private string? _createError;

    protected override async Task OnInitializedAsync() => await LoadNodesAsync();

    private async Task LoadNodesAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _nodes = [.. await NodeService.GetNodesAsync()];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load nodes: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenCreateDrawer()
    {
        _createName = "";
        _createVmSize = "";
        _createKernelIdleMinutes = null;
        _createNodeIdleMinutes = null;
        _createError = null;
        _createOpen = true;
    }

    private void CloseCreateDrawer() => _createOpen = false;

    private async Task CreateNodeAsync()
    {
        _createError = null;
        _creating = true;
        try
        {
            var request = new DuckHouse.Ui.Shared.Nodes.CreateNodeRequest(
                _createName.Trim(),
                _createVmSize.Trim(),
                _createKernelIdleMinutes is > 0 ? TimeSpan.FromMinutes(_createKernelIdleMinutes.Value) : null,
                _createNodeIdleMinutes is > 0 ? TimeSpan.FromMinutes(_createNodeIdleMinutes.Value) : null);
            var node = await NodeService.CreateNodeAsync(request);
            _nodes.Add(node);
            _createOpen = false;
        }
        catch (Exception ex)
        {
            _createError = $"Failed to create node: {ex.Message}";
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task StartNodeAsync(string name) =>
        await RunActionAsync(name, NodeService.StartNodeAsync, "start");

    private async Task StopNodeAsync(string name) =>
        await RunActionAsync(name, NodeService.StopNodeAsync, "stop");

    private async Task RemoveNodeAsync(string name) =>
        await RunActionAsync(name, NodeService.RemoveNodeAsync, "remove");

    private async Task RunActionAsync(string name, Func<string, CancellationToken, Task> action, string verb)
    {
        _busy = name;
        _error = null;
        try
        {
            await action(name, CancellationToken.None);
            var updated = await NodeService.GetNodeAsync(name);
            if (updated is not null)
            {
                var idx = _nodes.FindIndex(n => n.Name == name);
                if (idx >= 0) _nodes[idx] = updated;
            }
            else
            {
                _nodes.RemoveAll(n => n.Name == name);
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to {verb} node '{name}': {ex.Message}";
        }
        finally
        {
            _busy = null;
        }
    }

    private static string StateTagColor(NodeState state) => state switch
    {
        NodeState.Running => "success",
        NodeState.Stopped => "default",
        NodeState.Failure => "error",
        _ => "warning"
    };

    private static string FormatDuration(TimeSpan? ts)
    {
        if (ts is null) return "—";
        var t = ts.Value;
        if (t.TotalHours >= 1)
        {
            var h = (int)t.TotalHours;
            var m = t.Minutes;
            return m > 0 ? $"{h} h {m} min" : $"{h} h";
        }
        return $"{(int)t.TotalMinutes} min";
    }
}
