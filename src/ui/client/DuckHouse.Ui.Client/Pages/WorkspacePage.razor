@page "/workspace"

@using DuckHouse.Ui.Shared.Workspace
@inject IWorkspaceService WorkspaceService
@inject NavigationManager Navigation

<PageTitle>Workspace — DuckHouse</PageTitle>

<Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 16px; flex-wrap: wrap; gap: 8px;">
    <Space Align="SpaceAlign.Center" Size="SpaceSize.Small">
        <SpaceItem>
            <Icon Height="24px" Width="24px" Type="@IconType.Outline.FolderOpen" />
        </SpaceItem>
        <SpaceItem>
            <h2 style="margin: 0;">Workspace</h2>
        </SpaceItem>
    </Space>
    <Space Size="SpaceSize.Small">
        <SpaceItem>
            <Button Icon="@IconType.Outline.FolderAdd" OnClick="StartNewFolder">New folder</Button>
        </SpaceItem>
        <SpaceItem>
            <Button Icon="@IconType.Outline.FileAdd" OnClick="StartNewNotebook">New notebook</Button>
        </SpaceItem>
        <SpaceItem>
            <Button Icon="@IconType.Outline.Code" OnClick="StartNewQuery">New query</Button>
        </SpaceItem>
    </Space>
</Flex>

@* Breadcrumb *@
<Breadcrumb Style="margin-bottom: 16px;">
    @foreach (var (crumb, index) in _breadcrumbs.Select((c, i) => (c, i)))
    {
        if (index < _breadcrumbs.Count - 1)
        {
            <BreadcrumbItem>
                <a @onclick="() => NavigateToCrumb(index)" @onclick:preventDefault style="cursor: pointer;">
                    @(crumb.Name)
                </a>
            </BreadcrumbItem>
        }
        else
        {
            <BreadcrumbItem>@crumb.Name</BreadcrumbItem>
        }
    }
</Breadcrumb>

@if (_error is not null)
{
    <Alert Type="AlertType.Error" Message="@_error" Closable ShowIcon="true"
           OnClose="@(() => _error = null)" Style="margin-bottom: 16px;" />
}

@if (_loading)
{
    <Flex Justify="@("center")" Style="padding: 40px 0;"><Spin /></Flex>
}
else
{
    @* Inline new-folder row *@
    @if (_addingFolder)
    {
        <Flex Align="FlexAlign.Center" Gap="FlexGap.Small" Style="margin-bottom: 12px;">
            <Icon Type="@IconType.Outline.Folder" Style="color: #faad14;" />
            <Input @ref="_newFolderInput"
                   @bind-Value="_newFolderName"
                   Placeholder="Folder name"
                   Style="width: 220px;"
                   OnPressEnter="@(_ => ConfirmNewFolderAsync())" />
            <Button Size="ButtonSize.Small" Type="ButtonType.Primary" OnClick="ConfirmNewFolderAsync"
                    Disabled="@(string.IsNullOrWhiteSpace(_newFolderName) || _newFolderName.Contains('/'))">Create</Button>
            <Button Size="ButtonSize.Small" OnClick="CancelNewFolder">Cancel</Button>
        </Flex>
        @if (_newFolderName.Contains('/'))
        {
            <span style="font-size: 0.75rem; color: #ff4d4f; margin-bottom: 8px; display: block;">Folder name cannot contain '/'.</span>
        }
    }

    @* Combined folders + notebooks + queries table *@
    @if (_items.Count > 0 || _addingFolder)
    {
        <Table TItem="WorkspaceItem" DataSource="_items" Bordered="false"
               PageSize="int.MaxValue" PaginationPosition="none" Size="TableSize.Small">
            <PropertyColumn Property="i => i.Name" Title="Name">
                @if (context.IsFolder)
                {
                    <a @onclick="() => OpenFolder(context.Folder!)" @onclick:preventDefault style="cursor: pointer; font-weight: 500;">
                        <Icon Type="@IconType.Outline.Folder" Style="color: #faad14; margin-right: 6px;" />
                        @context.Name
                    </a>
                }
                else if (context.Notebook is not null)
                {
                    <a @onclick="() => OpenNotebook(context.Notebook!)" @onclick:preventDefault style="cursor: pointer; font-weight: 500;">
                        <Icon Type="@IconType.Outline.FileText" Style="margin-right: 6px; color: #1677ff;" />
                        @context.Name
                    </a>
                }
                else
                {
                    <a @onclick="() => OpenQuery(context.Query!)" @onclick:preventDefault style="cursor: pointer; font-weight: 500;">
                        <Icon Type="@IconType.Outline.Code" Style="margin-right: 6px; color: #52c41a;" />
                        @context.Name
                    </a>
                }
            </PropertyColumn>
            <PropertyColumn Property="i => i.ItemTypeLabel" Title="Type" Width="110">
                @if (context.IsFolder)
                {
                    <Tag>Folder</Tag>
                }
                else if (context.Notebook is not null)
                {
                    <Tag Color="@("blue")">Notebook</Tag>
                }
                else
                {
                    <Tag Color="@("green")">Query</Tag>
                }
            </PropertyColumn>
            <PropertyColumn Property="i => i.Date" Title="Date" Width="160">
                <Text Type="TextElementType.Secondary" Style="font-size: 0.85rem;">@FormatDate(context.Date)</Text>
            </PropertyColumn>
            <ActionColumn Title="" Width="130">
                @if (context.IsFolder)
                {
                    <Space Size="SpaceSize.Small">
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.FolderOpen"
                                    OnClick="() => StartMoveFolder(context.Folder!)">Move</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.Edit"
                                    OnClick="() => StartRenameFolder(context.Folder!)">Rename</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Popconfirm Title="Delete this folder and all its contents?"
                                        OnConfirm="@(() => DeleteFolderAsync(context.Folder!))"
                                        OkText="@("Delete")" OkType="ButtonType.Primary"
                                        OkButtonProps="new ButtonProps { Danger = true }"
                                        CancelText="Cancel">
                                <Button Size="ButtonSize.Small" Danger Icon="@IconType.Outline.Delete">Delete</Button>
                            </Popconfirm>
                        </SpaceItem>
                    </Space>
                }
                else if (context.Notebook is not null)
                {
                    <Space Size="SpaceSize.Small">
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.FolderOpen"
                                    OnClick="() => StartMoveNotebook(context.Notebook!)">Move</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.Edit"
                                    OnClick="() => StartRenameNotebook(context.Notebook!)">Rename</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.Copy"
                                    OnClick="() => CloneNotebookAsync(context.Notebook!)">Clone</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Popconfirm Title="Delete this notebook?"
                                        OnConfirm="@(() => DeleteNotebookAsync(context.Notebook!))"
                                        OkText="@("Delete")" OkType="ButtonType.Primary"
                                        OkButtonProps="new ButtonProps { Danger = true }"
                                        CancelText="Cancel">
                                <Button Size="ButtonSize.Small" Danger Icon="@IconType.Outline.Delete">Delete</Button>
                            </Popconfirm>
                        </SpaceItem>
                    </Space>
                }
                else
                {
                    <Space Size="SpaceSize.Small">
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.FolderOpen"
                                    OnClick="() => StartMoveQuery(context.Query!)">Move</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.Edit"
                                    OnClick="() => StartRenameQuery(context.Query!)">Rename</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Size="ButtonSize.Small" Icon="@IconType.Outline.Copy"
                                    OnClick="() => CloneQueryAsync(context.Query!)">Clone</Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Popconfirm Title="Delete this query?"
                                        OnConfirm="@(() => DeleteQueryAsync(context.Query!))"
                                        OkText="@("Delete")" OkType="ButtonType.Primary"
                                        OkButtonProps="new ButtonProps { Danger = true }"
                                        CancelText="Cancel">
                                <Button Size="ButtonSize.Small" Danger Icon="@IconType.Outline.Delete">Delete</Button>
                            </Popconfirm>
                        </SpaceItem>
                    </Space>
                }
            </ActionColumn>
        </Table>
    }

    @if (_items.Count == 0 && !_addingFolder)
    {
        <div style="text-align: center; padding: 40px 0;">
            <Icon Type="@IconType.Outline.Inbox" Style="font-size: 48px; color: #d9d9d9;" />
            <p style="margin-top: 12px;"><Text Type="TextElementType.Secondary">This folder is empty. Create a folder, notebook, or query to get started.</Text></p>
        </div>
    }
}

@* Rename folder modal *@
<Modal Title="@("Rename folder")"
       Visible="_renameFolderTarget is not null"
       OnOk="ConfirmRenameFolderAsync"
       OnCancel="CancelRenameFolder"
       OkText="@("Rename")"
       OkButtonProps="@(new ButtonProps { Disabled = string.IsNullOrWhiteSpace(_renameFolderName) || _renameFolderName.Contains('/') })">
    <Input @bind-Value="_renameFolderName" Placeholder="Folder name" />
    @if (_renameFolderName.Contains('/'))
    {
        <span style="font-size: 0.75rem; color: #ff4d4f; margin-top: 4px; display: block;">Folder name cannot contain '/'.</span>
    }
</Modal>

@* Rename notebook modal *@
<Modal Title="@("Rename notebook")"
       Visible="_renameNotebookTarget is not null"
       OnOk="ConfirmRenameNotebookAsync"
       OnCancel="CancelRenameNotebook"
       OkText="@("Rename")"
       OkButtonProps="@(new ButtonProps { Disabled = string.IsNullOrWhiteSpace(_renameNotebookName) || _renameNotebookName.Contains('/') })">
    <Input @bind-Value="_renameNotebookName" Placeholder="Notebook title" />
    @if (_renameNotebookName.Contains('/'))
    {
        <span style="font-size: 0.75rem; color: #ff4d4f; margin-top: 4px; display: block;">Notebook title cannot contain '/'.</span>
    }
</Modal>

@* Rename query modal *@
<Modal Title="@("Rename query")"
       Visible="_renameQueryTarget is not null"
       OnOk="ConfirmRenameQueryAsync"
       OnCancel="CancelRenameQuery"
       OkText="@("Rename")"
       OkButtonProps="@(new ButtonProps { Disabled = string.IsNullOrWhiteSpace(_renameQueryName) || _renameQueryName.Contains('/') })">
    <Input @bind-Value="_renameQueryName" Placeholder="Query title" />
    @if (_renameQueryName.Contains('/'))
    {
        <span style="font-size: 0.75rem; color: #ff4d4f; margin-top: 4px; display: block;">Query title cannot contain '/'.</span>
    }
</Modal>

@* Move folder picker *@
<FolderPickerModal Visible="_moveFolderTarget is not null"
                   Title="@("Move folder to…")"
                   OkText="@("Move here")"
                   ExcludeId="_moveFolderTarget?.Id"
                   OnConfirm="ConfirmMoveFolderAsync"
                   OnCancel="@(() => _moveFolderTarget = null)" />

@* Move notebook folder picker *@
<FolderPickerModal Visible="_moveNotebookTarget is not null"
                   Title="@("Move notebook to folder")"
                   OkText="@("Move here")"
                   OnConfirm="ConfirmMoveNotebookAsync"
                   OnCancel="@(() => _moveNotebookTarget = null)" />

@* Move query folder picker *@
<FolderPickerModal Visible="_moveQueryTarget is not null"
                   Title="@("Move query to folder")"
                   OkText="@("Move here")"
                   OnConfirm="ConfirmMoveQueryAsync"
                   OnCancel="@(() => _moveQueryTarget = null)" />

@code {
    [Parameter, SupplyParameterFromQuery(Name = "folder")]
    public Guid? Folder { get; set; }

    private sealed record WorkspaceItem(FolderSummary? Folder, NotebookSummary? Notebook, QuerySummary? Query)
    {
        public bool IsFolder => Folder is not null;
        public string Name => Folder?.Name ?? Notebook?.Title ?? Query!.Title;
        public string ItemTypeLabel => IsFolder ? "Folder" : Notebook is not null ? "Notebook" : "Query";
        public DateTime Date => Folder?.CreatedAt ?? Notebook?.UpdatedAt ?? Query!.UpdatedAt;
    }

    private WorkspaceListing _listing = new([], [], []);
    private List<WorkspaceItem> _items = [];
    private List<(Guid? Id, string Name)> _breadcrumbs = [(null, "Workspace")];
    private Guid? _lastLoadedFolder = Guid.Empty; // sentinel — differs from null (root)
    private bool _loading;
    private string? _error;

    // New folder
    private bool _addingFolder;
    private string _newFolderName = "";
    private AntDesign.Input<string>? _newFolderInput;

    // Rename folder
    private FolderSummary? _renameFolderTarget;
    private string _renameFolderName = "";

    // Rename notebook
    private NotebookSummary? _renameNotebookTarget;
    private string _renameNotebookName = "";

    // Rename query
    private QuerySummary? _renameQueryTarget;
    private string _renameQueryName = "";

    // Move folder
    private FolderSummary? _moveFolderTarget;

    // Move notebook
    private NotebookSummary? _moveNotebookTarget;

    // Move query
    private QuerySummary? _moveQueryTarget;

    protected override async Task OnParametersSetAsync()
    {
        if (Folder == _lastLoadedFolder) return;
        _lastLoadedFolder = Folder;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            if (Folder is null)
            {
                _breadcrumbs = [(null, "Workspace")];
                _listing = await WorkspaceService.GetRootAsync();
            }
            else
            {
                var ancestors = await WorkspaceService.GetFolderAncestorsAsync(Folder.Value);
                _breadcrumbs = [(null, "Workspace"), ..ancestors.Select(f => ((Guid?)f.Id, f.Name))];
                _listing = await WorkspaceService.GetFolderAsync(Folder.Value);
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load workspace: {ex.Message}";
        }
        finally
        {
            _items = [
                .._listing.Folders.Select(f => new WorkspaceItem(f, null, null))
                                  .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase),
                .._listing.Notebooks.Select(n => new WorkspaceItem(null, n, null))
                    .Concat(_listing.Queries.Select(q => new WorkspaceItem(null, null, q)))
                    .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase),
            ];
            _loading = false;
        }
    }

    private void OpenFolder(FolderSummary folder) =>
        Navigation.NavigateTo($"/workspace?folder={folder.Id}");

    private void NavigateToCrumb(int index)
    {
        var crumb = _breadcrumbs[index];
        Navigation.NavigateTo(crumb.Id is null ? "/workspace" : $"/workspace?folder={crumb.Id}");
    }

    private void OpenNotebook(NotebookSummary notebook) =>
        Navigation.NavigateTo($"/notebook/{notebook.Id}");

    private void OpenQuery(QuerySummary query) =>
        Navigation.NavigateTo($"/query/{query.Id}");

    // ── New Folder ────────────────────────────────────────────────────

    private void StartNewFolder()
    {
        _newFolderName = "";
        _addingFolder = true;
    }

    private async Task ConfirmNewFolderAsync()
    {
        var name = _newFolderName.Trim();
        if (string.IsNullOrEmpty(name)) { CancelNewFolder(); return; }
        try
        {
            await WorkspaceService.CreateFolderAsync(new CreateFolderRequest(name, Folder));
            _addingFolder = false;
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to create folder: {ex.Message}"; }
    }

    private void CancelNewFolder()
    {
        _addingFolder = false;
        _newFolderName = "";
    }

    // ── New Notebook ──────────────────────────────────────────────────

    private void StartNewNotebook() => Navigation.NavigateTo("/notebook");

    // ── New Query ─────────────────────────────────────────────────────

    private void StartNewQuery() => Navigation.NavigateTo("/query");

    // ── Rename Folder ─────────────────────────────────────────────────

    private void StartRenameFolder(FolderSummary folder)
    {
        _renameFolderTarget = folder;
        _renameFolderName = folder.Name;
    }

    private async Task ConfirmRenameFolderAsync()
    {
        if (_renameFolderTarget is null) return;
        var name = _renameFolderName.Trim();
        if (string.IsNullOrEmpty(name)) { CancelRenameFolder(); return; }
        try
        {
            await WorkspaceService.UpdateFolderAsync(_renameFolderTarget.Id,
                new UpdateFolderRequest(name, _renameFolderTarget.ParentId));
            _renameFolderTarget = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to rename folder: {ex.Message}"; }
    }

    private void CancelRenameFolder() => _renameFolderTarget = null;

    // ── Move Folder ───────────────────────────────────────────────────

    private void StartMoveFolder(FolderSummary folder) => _moveFolderTarget = folder;

    private async Task ConfirmMoveFolderAsync(Guid? folderId)
    {
        if (_moveFolderTarget is null) return;
        var target = _moveFolderTarget;
        _moveFolderTarget = null;
        try
        {
            await WorkspaceService.UpdateFolderAsync(target.Id, new UpdateFolderRequest(target.Name, folderId));
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to move folder: {ex.Message}"; }
    }

    // ── Rename Notebook ───────────────────────────────────────────────

    private void StartRenameNotebook(NotebookSummary notebook)
    {
        _renameNotebookTarget = notebook;
        _renameNotebookName = notebook.Title;
    }

    private async Task ConfirmRenameNotebookAsync()
    {
        if (_renameNotebookTarget is null) return;
        var title = _renameNotebookName.Trim();
        if (string.IsNullOrEmpty(title)) { CancelRenameNotebook(); return; }
        try
        {
            // Content is preserved — fetch current content first so we don't overwrite it with empty
            var detail = await WorkspaceService.GetNotebookAsync(_renameNotebookTarget.Id);
            if (detail is not null)
            {
                await WorkspaceService.UpdateNotebookAsync(_renameNotebookTarget.Id,
                    new UpdateNotebookRequest(title, detail.Content, _renameNotebookTarget.FolderId));
            }
            _renameNotebookTarget = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to rename notebook: {ex.Message}"; }
    }

    private void CancelRenameNotebook() => _renameNotebookTarget = null;

    // ── Move Notebook ─────────────────────────────────────────────────

    private void StartMoveNotebook(NotebookSummary notebook) => _moveNotebookTarget = notebook;

    private async Task ConfirmMoveNotebookAsync(Guid? folderId)
    {
        if (_moveNotebookTarget is null) return;
        var target = _moveNotebookTarget;
        _moveNotebookTarget = null;
        try
        {
            var detail = await WorkspaceService.GetNotebookAsync(target.Id);
            if (detail is not null)
                await WorkspaceService.UpdateNotebookAsync(target.Id,
                    new UpdateNotebookRequest(target.Title, detail.Content, folderId));
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to move notebook: {ex.Message}"; }
    }

    // ── Clone Notebook ────────────────────────────────────────────────

    private async Task CloneNotebookAsync(NotebookSummary notebook)
    {
        try
        {
            var detail = await WorkspaceService.GetNotebookAsync(notebook.Id);
            if (detail is not null)
                await WorkspaceService.CreateNotebookAsync(
                    new CreateNotebookRequest($"{notebook.Title} - Copy", detail.Content, notebook.FolderId));
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to clone notebook: {ex.Message}"; }
    }

    private async Task CloneQueryAsync(QuerySummary query)
    {
        try
        {
            var detail = await WorkspaceService.GetQueryAsync(query.Id);
            if (detail is not null)
                await WorkspaceService.CreateQueryAsync(
                    new CreateQueryRequest($"{query.Title} - Copy", detail.Content, query.FolderId));
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to clone query: {ex.Message}"; }
    }

    // ── Rename Query ──────────────────────────────────────────────────

    private void StartRenameQuery(QuerySummary query)
    {
        _renameQueryTarget = query;
        _renameQueryName = query.Title;
    }

    private async Task ConfirmRenameQueryAsync()
    {
        if (_renameQueryTarget is null) return;
        var title = _renameQueryName.Trim();
        if (string.IsNullOrEmpty(title)) { CancelRenameQuery(); return; }
        try
        {
            var detail = await WorkspaceService.GetQueryAsync(_renameQueryTarget.Id);
            if (detail is not null)
            {
                await WorkspaceService.UpdateQueryAsync(_renameQueryTarget.Id,
                    new UpdateQueryRequest(title, detail.Content, _renameQueryTarget.FolderId));
            }
            _renameQueryTarget = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to rename query: {ex.Message}"; }
    }

    private void CancelRenameQuery() => _renameQueryTarget = null;

    // ── Move Query ────────────────────────────────────────────────────

    private void StartMoveQuery(QuerySummary query) => _moveQueryTarget = query;

    private async Task ConfirmMoveQueryAsync(Guid? folderId)
    {
        if (_moveQueryTarget is null) return;
        var target = _moveQueryTarget;
        _moveQueryTarget = null;
        try
        {
            var detail = await WorkspaceService.GetQueryAsync(target.Id);
            if (detail is not null)
                await WorkspaceService.UpdateQueryAsync(target.Id,
                    new UpdateQueryRequest(target.Title, detail.Content, folderId));
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to move query: {ex.Message}"; }
    }

    // ── Delete ────────────────────────────────────────────────────────

    private async Task DeleteFolderAsync(FolderSummary folder)
    {
        try
        {
            await WorkspaceService.DeleteFolderAsync(folder.Id);
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to delete folder: {ex.Message}"; }
    }

    private async Task DeleteNotebookAsync(NotebookSummary notebook)
    {
        try
        {
            await WorkspaceService.DeleteNotebookAsync(notebook.Id);
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to delete notebook: {ex.Message}"; }
    }

    private async Task DeleteQueryAsync(QuerySummary query)
    {
        try
        {
            await WorkspaceService.DeleteQueryAsync(query.Id);
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed to delete query: {ex.Message}"; }
    }

    // ── Helpers ───────────────────────────────────────────────────────

    private static string FormatDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        return diff.TotalSeconds < 60  ? "just now"
             : diff.TotalMinutes < 60  ? $"{(int)diff.TotalMinutes}m ago"
             : diff.TotalHours < 24    ? $"{(int)diff.TotalHours}h ago"
             : diff.TotalDays < 7      ? $"{(int)diff.TotalDays}d ago"
             : dt.ToLocalTime().ToString("yyyy-MM-dd");
    }
}
