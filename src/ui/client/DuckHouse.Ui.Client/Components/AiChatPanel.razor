@using DuckHouse.Ui.Shared.Ai
@using System.Text.RegularExpressions
@using Markdig
@inject IAiAssistantService AiAssistantService
@inject IAiSettingsService AiSettingsService
@inject IAiCredentialService AiCredentialService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="ai-sidebar @(Visible ? "ai-sidebar--open" : "")">
@if (_hasBeenOpened)
{
    @* ── Sidebar header ── *@
    <div class="ai-sidebar-header">
        <div class="ai-sidebar-title">
            <Icon Type="@IconType.Outline.Robot" />
            <span>AI Assistant@(ContextLabel is not null ? $" — {ContextLabel}" : "")</span>
        </div>
        <Space Size="SpaceSize.Small">
            @if (_messages.Count > 0)
            {
                <SpaceItem>
                    <Tooltip Title="Clear chat">
                        <button class="cp-collapse-btn" @onclick="ClearAsync">
                            <Icon Type="@IconType.Outline.Delete" />
                        </button>
                    </Tooltip>
                </SpaceItem>
            }
            <SpaceItem>
                <Tooltip Title="AI settings">
                    <button class="cp-collapse-btn" @onclick="@(() => Navigation.NavigateTo("/settings#ai"))">
                        <Icon Type="@IconType.Outline.Setting" />
                    </button>
                </Tooltip>
            </SpaceItem>
            <SpaceItem>
                <Tooltip Title="Close AI assistant">
                    <button class="cp-collapse-btn" @onclick="CloseAsync">
                        <Icon Type="@IconType.Outline.RightCircle" />
                    </button>
                </Tooltip>
            </SpaceItem>
        </Space>
    </div>

    @* ── Config / no-key notice ── *@
    @if (_settingsLoaded && _noApiKey)
    {
        <div style="padding: 12px 16px; min-width: 380px;">
            <Alert Type="AlertType.Warning"
                   ShowIcon="true"
                   Message="Azure OpenAI not configured."
                   Description="Go to Settings to add your endpoint and API key." />
            <div style="margin-top: 8px;">
                <Button Size="ButtonSize.Small" OnClick="@(() => Navigation.NavigateTo("/settings#ai"))">Open Settings</Button>
            </div>
        </div>
    }
    else if (_settingsLoaded)
    {
        <div class="ai-sidebar-config">
            <span>@ProviderLabel</span>
            <span style="color: #d9d9d9;">·</span>
            <span>@_model</span>
        </div>
    }

    @* ── Message list ── *@
    <div class="ai-sidebar-messages" id="ai-messages">
        @foreach (var msg in _messages)
        {
            @if (msg.Role == "user")
            {
                <div style="display: flex; justify-content: flex-end;">
                    <div class="ai-user-bubble">@msg.Content</div>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 6px;">
                    @foreach (var segment in ParseMessageSegments(msg.Content))
                    {
                        @if (segment.IsCode)
                        {
                            <div style="background: #1d1d1d; border-radius: 6px; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(segment.Language))
                                {
                                    <div style="padding: 4px 10px; font-size: 0.7rem; color: #8c8c8c; border-bottom: 1px solid #2d2d2d; display: flex; justify-content: space-between; align-items: center;">
                                        <span>@segment.Language</span>
                                        @if (OnApplyCode.HasDelegate)
                                        {
                                            <Button Size="ButtonSize.Small"
                                                    Type="ButtonType.Primary"
                                                    OnClick="@(() => OnApplyCode.InvokeAsync(segment.Content))">
                                                Apply
                                            </Button>
                                        }
                                    </div>
                                }
                                else if (OnApplyCode.HasDelegate)
                                {
                                    <div style="padding: 4px 10px; font-size: 0.7rem; color: #8c8c8c; border-bottom: 1px solid #2d2d2d; display: flex; justify-content: flex-end;">
                                        <Button Size="ButtonSize.Small"
                                                Type="ButtonType.Primary"
                                                OnClick="@(() => OnApplyCode.InvokeAsync(segment.Content))">
                                            Apply
                                        </Button>
                                    </div>
                                }
                                <pre style="margin: 0; padding: 10px; font-size: 0.8125rem; overflow-x: auto; color: #d4d4d4; white-space: pre; word-break: normal;"><code>@segment.Content</code></pre>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(segment.Content))
                        {
                            <div class="ai-md-text">@((MarkupString)HtmlSanitizeHelper.Sanitize(Markdig.Markdown.ToHtml(segment.Content, _mdPipeline)))</div>
                        }
                    }
                </div>
            }
        }

        @* Streaming indicator *@
        @if (_isStreaming)
        {
            @if (!string.IsNullOrEmpty(_streamingText))
            {
                <div style="display: flex; flex-direction: column; gap: 6px;">
                    @foreach (var segment in ParseMessageSegments(_streamingText))
                    {
                        @if (segment.IsCode)
                        {
                            <div style="background: #1d1d1d; border-radius: 6px; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(segment.Language))
                                {
                                    <div style="padding: 4px 10px; font-size: 0.7rem; color: #8c8c8c; border-bottom: 1px solid #2d2d2d;">@segment.Language</div>
                                }
                                <pre style="margin: 0; padding: 10px; font-size: 0.8125rem; overflow-x: auto; color: #d4d4d4;"><code>@segment.Content</code></pre>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(segment.Content))
                        {
                            <div class="ai-md-text">@((MarkupString)HtmlSanitizeHelper.Sanitize(Markdig.Markdown.ToHtml(segment.Content, _mdPipeline)))</div>
                        }
                    }
                    <div style="display: flex; align-items: center; gap: 4px; color: #8c8c8c; font-size: 0.75rem;">
                        <Icon Type="@IconType.Outline.Loading" />
                    </div>
                </div>
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 6px; color: #8c8c8c; font-size: 0.875rem;">
                    <Icon Type="@IconType.Outline.Loading" />
                    <span>Thinking…</span>
                </div>
            }
        }

        @if (_error is not null)
        {
            <Alert Type="AlertType.Error" Message="@_error" Closable OnClose="@(() => _error = null)" />
        }
    </div>

    @* ── Agent proposals panel (outside the message scroll area so it's always visible) ── *@
    @if (_pendingProposals is { Count: > 0 })
    {
        var acceptedCount = _pendingProposals.Count(p => p.Accepted);
        <div class="ai-proposals-panel">
            <div class="ai-proposals-header">
                <span>Proposed Changes (@_pendingProposals.Count change@(_pendingProposals.Count == 1 ? "" : "s"))</span>
                <Space Size="SpaceSize.Small">
                    <SpaceItem>
                        <button class="cp-collapse-btn" @onclick="@(() => { foreach (var p in _pendingProposals) p.Accepted = true; })" title="Select all">All</button>
                    </SpaceItem>
                    <SpaceItem>
                        <button class="cp-collapse-btn" @onclick="@(() => { foreach (var p in _pendingProposals) p.Accepted = false; })" title="Deselect all">None</button>
                    </SpaceItem>
                </Space>
            </div>
            <div class="ai-proposals-items">
            @foreach (var entry in _pendingProposals)
            {
                <div class="ai-proposal-item">
                    <div class="ai-proposal-item-header" @onclick="@(() => entry.Expanded = !entry.Expanded)">
                        <Checkbox Value="@entry.Accepted" ValueChanged="@(v => entry.Accepted = v)" @onclick:stopPropagation />
                        <span class="ai-proposal-cell-label">@ProposalLabel(entry.Proposal)</span>
                        <span class="ai-proposal-explanation">@entry.Proposal.Explanation</span>
                        @if (entry.Proposal.Operation != CellProposalOperation.Remove)
                        {
                            <Icon Type="@(entry.Expanded ? IconType.Outline.Up : IconType.Outline.Down)" Style="flex-shrink:0; color:#8c8c8c;" />
                        }
                    </div>
                    @if (entry.Expanded && entry.Proposal.Operation != CellProposalOperation.Remove)
                    {
                        <div class="ai-proposal-preview">
                            <pre><code>@entry.Proposal.NewContent</code></pre>
                        </div>
                    }
                </div>
            }
            </div>
            <div class="ai-proposals-footer">
                <Button Size="ButtonSize.Small" OnClick="@(() => _pendingProposals = null)">Discard</Button>
                <Button Type="ButtonType.Primary"
                        Size="ButtonSize.Small"
                        Disabled="@(acceptedCount == 0)"
                        OnClick="ApplyProposalsAsync">
                    Apply @(acceptedCount > 0 ? acceptedCount : "") Accepted
                </Button>
            </div>
        </div>
    }

    @* ── Input area ── *@
    <div class="ai-sidebar-input">
        <div @oninput="@((e) => _input = e.Value?.ToString() ?? "")">
            <TextArea @bind-Value="_input"
                      Rows="3"
                      MaxRows="8"
                      AutoSize="true"
                      Placeholder="@InputPlaceholder"
                      Disabled="@(_isStreaming || _noApiKey)"
                      OnPressEnter="@OnTextAreaKeyDown"
                      Style="resize: none; margin-bottom: 8px;" />
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-top: 8px;">
            @if (ContextType == AiContextType.Notebook)
            {
                <div style="display: flex; align-items: center; gap: 6px;">
                    <span style="font-size: 0.75rem; color: #8c8c8c; flex-shrink: 0;">Mode:</span>
                    <Select TItem="string" TItemValue="string"
                            Value="@(_agentMode ? "Agent" : "Ask")"
                            ValueChanged="@(v => { _agentMode = v == "Agent"; _pendingProposals = null; })"
                            Style="width: 90px; font-size: 0.75rem;">
                        <SelectOptions>
                            <SelectOption TItemValue="string" TItem="string" Value="@("Ask")" Label="Ask" />
                            <SelectOption TItemValue="string" TItem="string" Value="@("Agent")" Label="Agent" />
                        </SelectOptions>
                    </Select>
                </div>
            }
            else
            {
                <span></span>
            }
            @if (_isStreaming)
            {
                <Button Icon="@IconType.Outline.Stop" OnClick="CancelAsync">Cancel</Button>
            }
            else
            {
                <Button Type="ButtonType.Primary"
                        Disabled="@(string.IsNullOrWhiteSpace(_input) || _noApiKey)"
                        Icon="@IconType.Outline.Send"
                        OnClick="SendAsync">
                    Send
                </Button>
            }
        </div>
    </div>
}
</div>

@code {
    private record MessageSegment(string Content, bool IsCode, string Language = "");

    [Parameter, EditorRequired] public bool Visible { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public AiContextType ContextType { get; set; } = AiContextType.NotebookCell;
    [Parameter] public string? ContextLabel { get; set; }
    [Parameter] public IReadOnlyList<Guid> CatalogIds { get; set; } = [];
    /// <summary>Lazily returns the full notebook JSON when called (for notebook/cell context).</summary>
    [Parameter] public Func<string?>? GetNotebookJson { get; set; }
    /// <summary>Lazily returns the index of the focused cell (for cell context; -1 for notebook-level).</summary>
    [Parameter] public Func<int>? GetFocusedCellIndex { get; set; }
    /// <summary>Lazily returns the SQL query content (for query context).</summary>
    [Parameter] public Func<string?>? GetQueryContent { get; set; }
    /// <summary>Called when the user clicks the Apply button on a code block. Receives the code text.</summary>
    [Parameter] public EventCallback<string> OnApplyCode { get; set; }
    /// <summary>Called in Agent mode when the user accepts proposals. Receives the list of accepted proposals.</summary>
    [Parameter] public EventCallback<IReadOnlyList<CellProposal>> OnApplyCellChanges { get; set; }

    private readonly List<AiChatMessage> _messages = [];
    private string _input = "";
    private bool _isStreaming;
    private string _streamingText = "";
    private CancellationTokenSource? _streamCts;
    private string? _error;

    // Agent mode state
    private bool _agentMode;
    private List<ProposalEntry>? _pendingProposals;

    private sealed class ProposalEntry
    {
        public required CellProposal Proposal { get; init; }
        public bool Accepted { get; set; } = true;
        public bool Expanded { get; set; }
    }

    private AiProviderType _provider = AiProviderType.AzureOpenAI;
    private string _model = "";
    private string _endpoint = "";
    private bool _noApiKey;
    private bool _settingsLoaded;
    private bool _wasVisible;
    // Keep content rendered after first open so the close animation isn't jarring
    private bool _hasBeenOpened;

    private string ProviderLabel => "Azure OpenAI";

    private string InputPlaceholder => _noApiKey
        ? "Configure Azure OpenAI in Settings first"
        : "Ask the AI…  (Shift+Enter for new line, Enter to send)";

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !_wasVisible)
        {
            _wasVisible = true;
            _hasBeenOpened = true;
            await LoadSettingsAsync();
        }
        else if (!Visible)
        {
            _wasVisible = false;
        }
    }

    private async Task LoadSettingsAsync()
    {
        _settingsLoaded = false;
        _model = await AiSettingsService.GetModelAsync();
        _endpoint = await AiSettingsService.GetEndpointAsync();
        _noApiKey = !await AiCredentialService.HasApiKeyAsync(_provider.ToString())
                    || string.IsNullOrWhiteSpace(_endpoint);
        _settingsLoaded = true;
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_input) || _isStreaming)
            return;

        var userMessage = _input.Trim();
        _input = "";
        _messages.Add(new AiChatMessage("user", userMessage));
        _isStreaming = true;
        _streamingText = "";
        _error = null;
        _pendingProposals = null;
        StateHasChanged();

        var apiKey = await AiCredentialService.GetApiKeyAsync(_provider.ToString()) ?? "";
        if (string.IsNullOrEmpty(apiKey))
        {
            _noApiKey = true;
            _isStreaming = false;
            _messages.RemoveAt(_messages.Count - 1);
            StateHasChanged();
            return;
        }

        var request = new AiChatRequest(
            Provider: _provider,
            ApiKey: apiKey,
            Endpoint: _endpoint,
            Model: _model,
            ContextType: ContextType,
            Messages: _messages.ToList(),
            NotebookJson: GetNotebookJson?.Invoke(),
            FocusedCellIndex: GetFocusedCellIndex?.Invoke() ?? -1,
            QueryContent: GetQueryContent?.Invoke(),
            CatalogIds: CatalogIds,
            Mode: _agentMode ? AiMode.Agent : AiMode.Ask
        );

        _streamCts = new CancellationTokenSource();

        try
        {
            if (_agentMode)
            {
                await AiAssistantService.StreamAgentChatAsync(
                    request,
                    onChunk: chunk =>
                    {
                        _streamingText += chunk;
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    onProposals: proposals =>
                    {
                        _pendingProposals = proposals
                            .Select(p => new ProposalEntry { Proposal = p })
                            .ToList();
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    onComplete: () =>
                    {
                        if (!string.IsNullOrEmpty(_streamingText))
                            _messages.Add(new AiChatMessage("assistant", _streamingText));
                        _streamingText = "";
                        _isStreaming = false;
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    onError: err =>
                    {
                        _error = err;
                        _streamingText = "";
                        _isStreaming = false;
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    ct: _streamCts.Token
                );
            }
            else
            {
                await AiAssistantService.StreamChatAsync(
                    request,
                    onChunk: chunk =>
                    {
                        _streamingText += chunk;
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    onComplete: () =>
                    {
                        _messages.Add(new AiChatMessage("assistant", _streamingText));
                        _streamingText = "";
                        _isStreaming = false;
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    onError: err =>
                    {
                        _error = err;
                        _streamingText = "";
                        _isStreaming = false;
                        StateHasChanged();
                        return Task.CompletedTask;
                    },
                    ct: _streamCts.Token
                );
            }
        }
        catch (OperationCanceledException)
        {
            if (!string.IsNullOrEmpty(_streamingText))
                _messages.Add(new AiChatMessage("assistant", _streamingText + "\n\n*(cancelled)*"));
            _streamingText = "";
            _isStreaming = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
            _streamingText = "";
            _isStreaming = false;
            StateHasChanged();
        }
        finally
        {
            _streamCts?.Dispose();
            _streamCts = null;
        }
    }

    private async Task ApplyProposalsAsync()
    {
        if (_pendingProposals is null) return;
        var accepted = _pendingProposals
            .Where(p => p.Accepted)
            .Select(p => p.Proposal)
            .ToList();
        if (accepted.Count > 0 && OnApplyCellChanges.HasDelegate)
            await OnApplyCellChanges.InvokeAsync(accepted);
        _pendingProposals = null;
        StateHasChanged();
    }

    private async Task CancelAsync()
    {
        if (_streamCts is not null)
            await _streamCts.CancelAsync();
    }

    private Task ClearAsync()
    {
        _messages.Clear();
        _streamingText = "";
        _error = null;
        _pendingProposals = null;
        return Task.CompletedTask;
    }

    private Task CloseAsync()
    {
        return VisibleChanged.InvokeAsync(false);
    }

    private async Task OnTextAreaKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private static string ProposalLabel(CellProposal p) => p.Operation switch
    {
        CellProposalOperation.Insert when p.CellIndex == -1 => $"Insert at start ({p.Language ?? "python"})",
        CellProposalOperation.Insert => $"Insert after Cell {p.CellIndex + 1} ({p.Language ?? "python"})",
        CellProposalOperation.Remove => $"Remove Cell {p.CellIndex + 1}",
        _ => $"Edit Cell {p.CellIndex + 1}",
    };

    private static readonly Regex CodeBlockRegex = new(
        @"```(\w*)\n?([\s\S]*?)```",
        RegexOptions.Compiled);

    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private static List<MessageSegment> ParseMessageSegments(string text)
    {
        var segments = new List<MessageSegment>();
        int lastIndex = 0;

        foreach (Match match in CodeBlockRegex.Matches(text))
        {
            if (match.Index > lastIndex)
                segments.Add(new MessageSegment(text[lastIndex..match.Index], false));

            segments.Add(new MessageSegment(match.Groups[2].Value.TrimEnd('\n'), true, match.Groups[1].Value));
            lastIndex = match.Index + match.Length;
        }

        if (lastIndex < text.Length)
            segments.Add(new MessageSegment(text[lastIndex..], false));

        return segments;
    }

    public async ValueTask DisposeAsync()
    {
        if (_streamCts is not null)
        {
            await _streamCts.CancelAsync();
            _streamCts.Dispose();
        }
    }
}
