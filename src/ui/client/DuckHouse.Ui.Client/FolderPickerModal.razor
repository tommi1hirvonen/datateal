@using DuckHouse.Ui.Shared.Workspace
@inject IWorkspaceService WorkspaceService

<Modal Title="@Title"
       Visible="Visible"
       OnOk="ConfirmAsync"
       OnCancel="OnCancel"
       OkText="@OkText"
       Width="480">
    <Breadcrumb Style="margin-bottom: 12px;">
        @foreach (var (crumb, index) in _breadcrumbs.Select((c, i) => (c, i)))
        {
            if (index < _breadcrumbs.Count - 1)
            {
                <BreadcrumbItem>
                    <a @onclick="() => NavigateToCrumbAsync(index)" @onclick:preventDefault style="cursor: pointer;">
                        @crumb.Name
                    </a>
                </BreadcrumbItem>
            }
            else
            {
                <BreadcrumbItem>@crumb.Name</BreadcrumbItem>
            }
        }
    </Breadcrumb>
    @if (_loading)
    {
        <Flex Justify="@("center")" Style="padding: 20px 0;"><Spin /></Flex>
    }
    else if (_folders.Count == 0)
    {
        <span style="color: rgba(0,0,0,.45); font-style: italic;">No subfolders here.</span>
    }
    else
    {
        @foreach (var folder in _folders)
        {
            var f = folder;
            <div @onclick="() => NavigateToFolderAsync(f)"
                 style="padding: 7px 10px; cursor: pointer; border-radius: 6px; display: flex; align-items: center; gap: 8px;"
                 @onmouseenter="@(_ => _hoveredId = f.Id)" @onmouseleave="@(_ => _hoveredId = null)"
                 class="@(_hoveredId == f.Id ? "picker-row-hover" : "picker-row")">
                <Icon Type="@IconType.Outline.Folder" Style="color: #faad14;" />
                <span>@f.Name</span>
                <Icon Type="@IconType.Outline.Right" Style="margin-left: auto; color: #bbb; font-size: 0.75rem;" />
            </div>
        }
    }
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Choose folder";
    [Parameter] public string OkText { get; set; } = "Select";
    [Parameter] public Guid? ExcludeId { get; set; }
    [Parameter] public EventCallback<Guid?> OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool _prevVisible;
    private bool _loading;
    private Guid? _currentFolderId;
    private List<(Guid? Id, string Name)> _breadcrumbs = [(null, "Workspace")];
    private List<FolderSummary> _folders = [];
    private Guid? _hoveredId;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !_prevVisible)
        {
            _currentFolderId = null;
            _breadcrumbs = [(null, "Workspace")];
            await LoadFoldersAsync();
        }
        _prevVisible = Visible;
    }

    private async Task LoadFoldersAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var listing = _currentFolderId.HasValue
                ? await WorkspaceService.GetFolderAsync(_currentFolderId.Value)
                : await WorkspaceService.GetRootAsync();
            _folders = listing.Folders.Where(f => f.Id != ExcludeId).ToList();
        }
        finally { _loading = false; }
    }

    private async Task NavigateToFolderAsync(FolderSummary folder)
    {
        _currentFolderId = folder.Id;
        _breadcrumbs.Add(((Guid?)folder.Id, folder.Name));
        await LoadFoldersAsync();
    }

    private async Task NavigateToCrumbAsync(int index)
    {
        _breadcrumbs = _breadcrumbs.Take(index + 1).ToList();
        _currentFolderId = _breadcrumbs[^1].Id;
        await LoadFoldersAsync();
    }

    private async Task ConfirmAsync() => await OnConfirm.InvokeAsync(_currentFolderId);
}
