@inject NavigationManager Navigation
@inject IJobService JobService
@using DuckHouse.Ui.Shared.Orchestration

<Menu @ref="_menu"
      Mode="MenuMode.Vertical"
      Theme="MenuTheme.Dark"
      SelectedKeys="@_selectedKeys"
      Style="border-right: none;">
    <div class="navmenu-brand" style="height: 32px; margin: 16px; display: flex; align-items: center;">
        <span style="font-size: 22px; font-weight: 600; color: #ddd;">
            @if (_menu?.InlineCollapsed is null or false)
            {
                <text>DuckHouse</text>
            }
        </span>
    </div>
    <SubMenu Key="new" TitleTemplate="@_newTitle">
        <AuthorizeView Policy="@AuthPolicy.WorkspaceRead">
            <MenuItem Key="new-notebook" RouterLink="/notebook" RouterMatch="NavLinkMatch.All">
                <Icon Type="@IconType.Outline.FileText" />
                <span>Notebook</span>
            </MenuItem>
        </AuthorizeView>
        <AuthorizeView Policy="@AuthPolicy.WorkspaceRead">
            <MenuItem Key="new-query" RouterLink="/query" RouterMatch="NavLinkMatch.All">
                <Icon Type="@IconType.Outline.Code" />
                <span>SQL query</span>
            </MenuItem>
        </AuthorizeView>
        <AuthorizeView Policy="@AuthPolicy.JobManage">
            <MenuItem Key="new-job" OnClick="StartCreateJob">
                <Icon Type="@IconType.Outline.Partition" />
                <span>Job</span>
            </MenuItem>
        </AuthorizeView>
    </SubMenu>
    <MenuItem Key="home" RouterLink="/" RouterMatch="NavLinkMatch.All">
        <Icon Type="@IconType.Outline.Home" />
        <span>Home</span>
    </MenuItem>
    <AuthorizeView Policy="@AuthPolicy.WorkspaceRead">
        <MenuItem Key="notebook" RouterLink="/workspace" RouterMatch="NavLinkMatch.Prefix">
            <Icon Type="@IconType.Outline.FolderOpen" />
            <span>Workspace</span>
        </MenuItem>
    </AuthorizeView>
    <AuthorizeView Policy="@AuthPolicy.JobRead">
        <MenuItem Key="jobs" RouterLink="/jobs" RouterMatch="NavLinkMatch.Prefix">
            <Icon Type="@IconType.Outline.Partition" />
            <span>Jobs</span>
        </MenuItem>
    </AuthorizeView>
    <MenuItem Key="catalogs" RouterLink="/catalogs" RouterMatch="NavLinkMatch.Prefix">
        <Icon Type="@IconType.Outline.Database" />
        <span>Catalogs</span>
    </MenuItem>
    <AuthorizeView Policy="@AuthPolicy.NodePoolOperate">
        <MenuItem Key="node-pools" RouterLink="/node-pools" RouterMatch="NavLinkMatch.Prefix">
            <Icon Type="@IconType.Outline.Cluster" />
            <span>Node pools</span>
        </MenuItem>
    </AuthorizeView>
    <AuthorizeView Policy="@AuthPolicy.NodePoolOperate">
        <MenuItem Key="nodes" RouterLink="/nodes" RouterMatch="NavLinkMatch.Prefix">
            <Icon Type="@IconType.Outline.CloudServer" />
            <span>Active nodes</span>
        </MenuItem>
    </AuthorizeView>
    <AuthorizeView Policy="@AuthPolicy.EnvironmentManage">
        <MenuItem Key="environment" RouterLink="/environment" RouterMatch="NavLinkMatch.Prefix">
            <Icon Type="@IconType.Outline.Tool" />
            <span>Environment</span>
        </MenuItem>
    </AuthorizeView>
    <MenuItem Key="settings" RouterLink="/settings" RouterMatch="NavLinkMatch.Prefix">
        <Icon Type="@IconType.Outline.Setting" />
        <span>Settings</span>
    </MenuItem>
    <AuthorizeView Policy="@AuthPolicy.Admin">
        <MenuItem Key="users" RouterLink="/users" RouterMatch="NavLinkMatch.Prefix">
            <Icon Type="@IconType.Outline.Team" />
            <span>Users</span>
        </MenuItem>
    </AuthorizeView>
</Menu>

<Drawer Closable="true" @bind-Visible="_showCreateJobModal" Placement="DrawerPlacement.Right"
        Width="480" Title="@("New job")"
        OnClose="() => _showCreateJobModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <Form Model="@_jobForm" Layout="FormLayout.Vertical">
            <FormItem Label="Name">
                <Input @bind-Value="context.Name" Placeholder="My job"
                       BindOnInput
                       Class="@(JobNameDisplayError is not null ? "ant-input-status-error" : "")"
                       OnPressEnter="@(async _ => await ConfirmCreateJobAsync())" />
                @if (JobNameDisplayError is not null)
                {
                    <div class="ant-form-item-explain-error">@JobNameDisplayError</div>
                }
            </FormItem>
            <FormItem Label="Description">
                <TextArea @bind-Value="context.Description" Placeholder="Optional description" Rows="3"
                          BindOnInput />
            </FormItem>
            @if (_createJobError is not null)
            {
                <Alert Type="@AlertType.Error" Message="@_createJobError" ShowIcon="true" />
            }
        </Form>
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showCreateJobModal = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmCreateJobAsync"
                Disabled="@(GetJobNameError() is not null || _creatingJob)"
                Loading="@_creatingJob">Create</Button>
    </div>
</Drawer>

@code {
    private Menu? _menu;
    private string[] _selectedKeys = [];

    private readonly RenderFragment _newTitle =
        @<span>
            <Icon Type="@IconType.Outline.Plus" />
            <span>New</span>
        </span>;

    // New job modal state
    private bool _showCreateJobModal;
    private CreateJobFormModel _jobForm = new();
    private bool _creatingJob;
    private string? _createJobError;
    private bool _jobNameSubmitAttempted;
    private IReadOnlyList<JobSummary> _existingJobs = [];

    private string? JobNameDisplayError =>
        (_jobNameSubmitAttempted || !string.IsNullOrEmpty(_jobForm.Name)) ? GetJobNameError() : null;

    private string? GetJobNameError()
    {
        if (string.IsNullOrEmpty(_jobForm.Name)) return "Name is required.";
        var trimmed = _jobForm.Name.Trim();
        if (_existingJobs.Any(j => j.Name.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
            return "A job with this name already exists.";
        return null;
    }

    private static readonly FormValidationRule[] _jobNameRules =
    [
        new() { Required = true, Message = "Name is required." }
    ];

    private async Task StartCreateJob()
    {
        _jobForm = new CreateJobFormModel();
        _createJobError = null;
        _jobNameSubmitAttempted = false;
        try { _existingJobs = await JobService.GetJobsAsync(); } catch { /* non-fatal */ }
        _showCreateJobModal = true;
    }

    private async Task ConfirmCreateJobAsync()
    {
        _jobNameSubmitAttempted = true;
        if (GetJobNameError() is not null) return;
        _creatingJob = true;
        _createJobError = null;
        try
        {
            var job = await JobService.CreateJobAsync(
                new CreateJobRequest(_jobForm.Name.Trim(), _jobForm.Description?.Trim(), null, 1));
            _showCreateJobModal = false;
            Navigation.NavigateTo($"/jobs/{job.Id}");
        }
        catch (Exception ex)
        {
            _createJobError = $"Failed to create job: {ex.Message}";
        }
        finally
        {
            _creatingJob = false;
        }
    }

    protected override void OnInitialized() => UpdateSelectedKey();

    protected override void OnParametersSet() => UpdateSelectedKey();

    private void UpdateSelectedKey()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        _selectedKeys = path switch
        {
            "" or "/" => ["home"],
            _ when path.StartsWith("/nodes") => ["nodes"],
            _ when path.StartsWith("/workspace") => ["notebook"],
            _ when path.StartsWith("/notebook") => ["notebook"],
            _ when path.StartsWith("/query") => ["notebook"],
            _ when path.StartsWith("/jobs") => ["jobs"],
            _ when path.StartsWith("/runs") => ["jobs"],
            _ when path.StartsWith("/node-pools") => ["node-pools"],
            _ when path.StartsWith("/environment") => ["environment"],
            _ when path.StartsWith("/catalogs") => ["catalogs"],
            _ when path.StartsWith("/settings") => ["settings"],
            _ when path.StartsWith("/users") => ["users"],
            _ => []
        };
    }
}
