@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<AntContainer />

<Layout Style="min-height: 100vh;">
    <Sider Collapsible>
        <NavMenu />
    </Sider>
    <Layout Class="site-layout">
        <Header Class="site-header" Style="padding: 0 24px; display: flex; justify-content: flex-end; align-items: center;">
            <WorkspaceSwitcher />
            <LoginDisplay />
        </Header>
        <Content Style="padding: 24px; overflow: auto;">
            @Body
        </Content>
    </Layout>
</Layout>

<div id="blazor-error-ui">
    <Alert Closable Type="AlertType.Error">
        An error has occurred. This app may no longer respond until reloaded.
        <a href="javascript:location.reload()">Reload</a>
    </Alert>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("removeWasmLoadingOverlay");
            }
            catch
            {
                // JS interop may fail if the overlay was already removed by the fallback timer.
            }
        }
    }
}