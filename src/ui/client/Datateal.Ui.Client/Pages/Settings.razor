@page "/settings"
@attribute [Authorize]
@using Datateal.Ui.Client.Services
@using Datateal.Ui.Shared.Ai
@inject IThemeService ThemeService
@inject IAiSettingsService AiSettingsService
@inject IAiCredentialService AiCredentialService

<PageTitle>Settings — Datateal</PageTitle>

<div style="margin-bottom: 24px;">
    <h2 style="margin: 0;">Settings</h2>
</div>

<div style="display: flex; flex-direction: column; gap: 24px; max-width: 520px;">

<Card id="appearance">
    <p style="font-size: 0.875rem; margin-bottom: 12px;"><Text Type="TextElementType.Secondary" Strong>Appearance</Text></p>

    <p style="font-size: 0.875rem; font-weight: 600; margin-bottom: 8px;">Theme</p>
    <Segmented TValue="AppTheme"
               Value="_theme"
               ValueChanged="SetThemeAsync"
               Options="_themeOptions" />
    @if (_theme == AppTheme.Auto)
    {
        <p style="font-size: 0.75rem; margin-top: 8px;">
            <Text Type="TextElementType.Secondary">Follows your system or browser color scheme preference.</Text>
        </p>
    }
</Card>

<Card id="ai">
    <p style="font-size: 0.875rem; margin-bottom: 16px;"><Text Type="TextElementType.Secondary" Strong>AI Assistant</Text></p>
    <p style="font-size: 0.75rem; margin-bottom: 16px;">
        <Text Type="TextElementType.Secondary">Azure OpenAI — your credentials are stored locally in encrypted form and only forwarded to Azure during AI requests.</Text>
    </p>

    <p style="font-size: 0.875rem; font-weight: 600; margin-bottom: 8px;">Endpoint</p>
    <Input @bind-Value="_aiEndpoint"
           @bind-Value:after="SaveEndpointAsync"
           Placeholder="https://&lt;your-resource&gt;.openai.azure.com/"
           Style="max-width: 400px;" />

    <p style="font-size: 0.875rem; font-weight: 600; margin-top: 16px; margin-bottom: 8px;">Deployment name</p>
    <Input @bind-Value="_aiModel"
           @bind-Value:after="SaveModelAsync"
           Placeholder="e.g. gpt-4o"
           Style="max-width: 320px;" />

    <p style="font-size: 0.875rem; font-weight: 600; margin-top: 16px; margin-bottom: 8px;">API Key</p>
    <p style="font-size: 0.75rem; margin-bottom: 8px;">
        <Text Type="TextElementType.Secondary">
            Stored in your browser using AES-256 encryption.
        </Text>
    </p>
    @if (_hasApiKey)
    {
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
            <Tag Color="@("green")"><Icon Type="@IconType.Outline.CheckCircle" /> Key stored</Tag>
            <Button Size="ButtonSize.Small" Danger OnClick="RemoveApiKeyAsync">Remove</Button>
        </div>
    }
    else
    {
        <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
            <InputPassword @bind-Value="_newApiKey"
                           Placeholder="Paste your Azure OpenAI API key"
                           Style="max-width: 320px;" />
            <Button Type="ButtonType.Primary"
                    Size="ButtonSize.Small"
                    Disabled="@string.IsNullOrWhiteSpace(_newApiKey)"
                    OnClick="SaveApiKeyAsync">
                Save
            </Button>
        </div>
    }
</Card>

</div>

@code {
    private AppTheme _theme = AppTheme.Auto;

    private readonly SegmentedOption<AppTheme>[] _themeOptions =
    [
        new() { Value = AppTheme.Light, Label = "☀ Light" },
        new() { Value = AppTheme.Dark,  Label = "☽ Dark" },
        new() { Value = AppTheme.Auto,  Label = "⊙ Auto" },
    ];

    private string _aiModel = "";
    private string _aiEndpoint = "";
    private bool _hasApiKey;
    private string _newApiKey = "";

    private const string AiProviderKey = "AzureOpenAI";

    protected override async Task OnInitializedAsync()
    {
        _theme = await ThemeService.GetThemeAsync();
        _aiModel = await AiSettingsService.GetModelAsync();
        _aiEndpoint = await AiSettingsService.GetEndpointAsync();
        _hasApiKey = await AiCredentialService.HasApiKeyAsync(AiProviderKey);
    }

    private async Task SetThemeAsync(AppTheme theme)
    {
        _theme = theme;
        await ThemeService.SetThemeAsync(theme);
    }

    private async Task SaveModelAsync()
    {
        await AiSettingsService.SetModelAsync(_aiModel);
    }

    private async Task SaveEndpointAsync()
    {
        await AiSettingsService.SetEndpointAsync(_aiEndpoint.Trim());
        _aiEndpoint = _aiEndpoint.Trim();
    }

    private async Task SaveApiKeyAsync()
    {
        if (string.IsNullOrWhiteSpace(_newApiKey))
            return;
        await AiCredentialService.SetApiKeyAsync(AiProviderKey, _newApiKey.Trim());
        _hasApiKey = true;
        _newApiKey = "";
    }

    private async Task RemoveApiKeyAsync()
    {
        await AiCredentialService.RemoveApiKeyAsync(AiProviderKey);
        _hasApiKey = false;
    }
}

