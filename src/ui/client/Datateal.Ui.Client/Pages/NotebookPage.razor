    private Task OnCatalogSelectionChanged(IEnumerable<CatalogDto> selectedItems)
    {
        _notebook.IsDirty = true;
        return _catalog.OnSelectionChangedAsync(selectedItems);
    }

    private async Task ConfirmInternalNavigationAsync(LocationChangingContext ctx)
    {
        if (!_notebook.IsDirty) return;
        var confirmed = await JS.InvokeAsync<bool>("confirm", "You have unsaved changes. Are you sure you want to leave?");
        if (!confirmed)
            ctx.PreventNavigation();
    }

    public async ValueTask DisposeAsync()
    {
        if (_connectCts is not null)
        {
            await _connectCts.CancelAsync();
            // _connectCts is disposed by ConnectAsync's finally block
        }
        await StopKernelPollingAsync();
        if (HasKernel && !string.IsNullOrEmpty(_nodeName))
        {
            try { await KernelService.DeleteKernelAsync(_nodeName, _kernelId!); }
            catch { /* best effort */ }
        }
    }

    private static string StatusTagColor(KernelStatus status) => status switch
    {
        KernelStatus.Idle                                 => "success",
        KernelStatus.Busy                                 => "warning",
        KernelStatus.Starting or KernelStatus.Restarting => "processing",
        KernelStatus.Dead                                 => "error",
        _                                                 => "default"
    };

    private static string NodeStateTagColor(NodeState state) => state switch
    {
        NodeState.Running => "success",
        NodeState.Failure => "error",
        _                 => "warning",
    };
}

