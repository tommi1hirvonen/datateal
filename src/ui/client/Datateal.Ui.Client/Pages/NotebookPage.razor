    private Task ApplyAiCodeAsync(string code)
    {
        if (_aiFocusedCell is not null)
        {
            _aiFocusedCell.Source = code;
            _notebook.IsDirty = true;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task ApplyAiCellChangesAsync(IReadOnlyList<CellProposal> proposals)
    {
        var removed = proposals
            .Where(p => p.Operation == CellProposalOperation.Remove)
            .Select(p => p.CellIndex)
            .ToHashSet();

        var inserts = proposals
            .Where(p => p.Operation == CellProposalOperation.Insert)
            .GroupBy(p => p.CellIndex)
            .ToDictionary(g => g.Key, g => g.ToList());

        // Apply edits in-place before rebuilding the list
        foreach (var p in proposals.Where(p => p.Operation == CellProposalOperation.Edit))
        {
            if (p.CellIndex >= 0 && p.CellIndex < _notebook.Cells.Count && p.NewContent is not null)
                _notebook.Cells[p.CellIndex].Source = p.NewContent;
        }

        // Rebuild the cell list — handles removals and insertions relative to original indices
        var newCells = new List<NotebookCell>();

        // Inserts before all cells (afterCellIndex == -1)
        if (inserts.TryGetValue(-1, out var beforeAll))
            foreach (var p in beforeAll)
                newCells.Add(CreateCellFromProposal(p));

        for (int i = 0; i < _notebook.Cells.Count; i++)
        {
            if (!removed.Contains(i))
                newCells.Add(_notebook.Cells[i]);

            if (inserts.TryGetValue(i, out var afterThis))
                foreach (var p in afterThis)
                    newCells.Add(CreateCellFromProposal(p));
        }

        // Append any inserts that reference indices beyond the original notebook length
        // (the AI may use sequential indices when proposing multiple consecutive inserts)
        foreach (var key in inserts.Keys.Where(k => k >= _notebook.Cells.Count).OrderBy(k => k))
            foreach (var p in inserts[key])
                newCells.Add(CreateCellFromProposal(p));

        _notebook.Cells.Clear();
        _notebook.Cells.AddRange(newCells);
        _notebook.IsDirty = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static NotebookCell CreateCellFromProposal(CellProposal p)
    {
        var (cellType, lang) = p.Language?.ToLowerInvariant() switch
        {
            "sql" => (NotebookCellType.Code, NotebookCellLanguage.Sql),
            "markdown" or "md" => (NotebookCellType.Markdown, NotebookCellLanguage.Python),
            _ => (NotebookCellType.Code, NotebookCellLanguage.Python),
        };
        var cell = new NotebookCell { CellType = cellType, Language = lang, Source = p.NewContent ?? "" };
        if (cellType == NotebookCellType.Markdown)
            cell.IsEditingMarkdown = true;
        return cell;
    }

    private async Task<string> PriorContextForAsync(int cellIndex)
    {
        var parts = new List<string>();
        foreach (var c in _notebook.Cells.Take(cellIndex).Where(c => c.CellType == NotebookCellType.Code))
        {
            if (c.Language == NotebookCellLanguage.Sql)
            {
                // Use WrapSql so the context mirrors actual execution: _sqldf is assigned,
                // the SQL is properly escaped, and Jedi can infer _sqldf as pd.DataFrame.
                parts.Add(SqlCodeGenerator.WrapSql(c.Source));
            }
            else if (c.CachedExpandedSource is not null)
            {
                parts.Add(c.CachedExpandedSource);
            }
            else if (RunMagicHelper.HasRunLines(c.Source))
            {
                // Eagerly expand %run references so Jedi can see their definitions
                try
                {
                    var expanded = await RunMagicHelper.ExpandAsync(
                        c.Source, _workspaceNotebookFolderId, WorkspaceService);
                    parts.Add(expanded);
                }
                catch
                {
                    parts.Add(RunMagicHelper.ReplaceRunLinesWithPass(c.Source));
                }
            }
            else
            {
                parts.Add(RunMagicHelper.ReplaceRunLinesWithPass(c.Source));
            }
        }
        return string.Join("\n", parts);
    }

    private async Task<IReadOnlyList<RunMagicCompletionItem>> ProvideRunMagicCompletionsAsync(string directoryPath)
    {
        try
        {
            var resolved = await WorkspaceService.ResolvePathAsync(
                directoryPath.EndsWith('/') ? directoryPath : directoryPath + "/",
                _workspaceNotebookFolderId);

            if (resolved?.Listing is null) return [];

            var items = new List<RunMagicCompletionItem>();
            foreach (var f in resolved.Listing.Folders)
                items.Add(new(f.Name + "/", "folder", f.Name + "/"));
            foreach (var n in resolved.Listing.Items.Where(i => i.ItemType == Datateal.Core.Workspace.WorkspaceItemType.Notebook))
                items.Add(new(n.Title, "notebook", n.Title));
            foreach (var q in resolved.Listing.Items.Where(i => i.ItemType == Datateal.Core.Workspace.WorkspaceItemType.Query))
                items.Add(new(q.Title, "query", q.Title));
            return items;
        }
        catch
        {
            return [];
        }
    }

    private async Task OpenFileDialogAsync()
    {
        await JS.InvokeVoidAsync("clickElement", _fileInput.Element);
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs args)
    {
        try
        {
            using var stream = args.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            _notebook = NotebookSerializer.Deserialize(json);
            _notebook.Title = System.IO.Path.GetFileNameWithoutExtension(args.File.Name);
            // Mark dirty so "Save to workspace" is enabled — a local file has never been saved to the workspace.
            // Clear all workspace-bound state so the user is prompted to pick a location rather than
            // silently overwriting whatever notebook was open before. Kernel connection is left intact
            // because it is independent of which notebook is loaded.
            _notebook.IsDirty = true;
            _workspaceNotebookId = null;
            _workspaceNotebookFolderId = null;
            _breadcrumbs = [];
            _error = null;
            _warning = null;
            _editingTitle = false;
            _editingTitleValue = "";
            _showFolderPicker = false;

            if (_notebook.AttachedCatalogs.Count > 0)
            {
                var knownNames = _allCatalogs.Select(c => c.Name).ToHashSet();
                var valid = _notebook.AttachedCatalogs.Where(n => knownNames.Contains(n)).ToList();
                var missing = _notebook.AttachedCatalogs.Where(n => !knownNames.Contains(n)).ToList();
                _selectedCatalogNames = valid;
                if (missing.Count > 0)
                    _warning = $"The following catalog(s) from this notebook are not available in this environment and were skipped: {string.Join(", ", missing)}.";
            }
            else
            {
                _selectedCatalogNames = [];
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to open file: {ex.Message}";
        }
    }

    private async Task SaveToWorkspaceAsync()
    {
        if (!_workspaceNotebookId.HasValue) return;
        try
        {
            var json = NotebookSerializer.Serialize(_notebook);
            await WorkspaceService.UpdateNotebookAsync(_workspaceNotebookId.Value,
                new UpdateNotebookRequest(_notebook.Title, json, _workspaceNotebookFolderId));
            try { await CatalogService.UpdateWorkspaceItemCatalogsAsync(_workspaceNotebookId.Value, _selectedCatalogNames.ToList()); }
            catch (Exception ex) { _error = $"Notebook saved but failed to save catalog selection: {ex.Message}"; }
            _ = RecentItemsService.UpdateNameAsync(_workspaceNotebookId.Value, _notebook.Title);
            _notebook.IsDirty = false;
        }
        catch (Exception ex)
        {
            _error = $"Failed to save to workspace: {ex.Message}";
        }
    }

    // ── Folder picker (first-time save) ───────────────────────────────

    private Task OpenFolderPickerAsync()
    {
        _showFolderPicker = true;
        return Task.CompletedTask;
    }

    private async Task ConfirmSaveToFolderAsync(Guid? folderId)
    {
        _showFolderPicker = false;
        try
        {
            var json = NotebookSerializer.Serialize(_notebook);
            var summary = await WorkspaceService.CreateNotebookAsync(
                new CreateNotebookRequest(_notebook.Title, json, folderId));
            _workspaceNotebookId = summary.Id;
            _workspaceNotebookFolderId = folderId;

            _ = RecentItemsService.RecordVisitAsync(summary.Id, _notebook.Title, "Notebook", WorkspaceId);

            if (_selectedCatalogNames.Any())
            {
                try { await CatalogService.UpdateWorkspaceItemCatalogsAsync(summary.Id, _selectedCatalogNames.ToList()); }
                catch (Exception ex) { _error = $"Notebook saved but failed to save catalog selection: {ex.Message}"; }
            }

            if (folderId is not null)
            {
                var ancestors = await WorkspaceService.GetFolderAncestorsAsync(folderId.Value);
                _breadcrumbs = [(null, "Workspace"), ..ancestors.Select(f => ((Guid?)f.Id, f.Name))];
            }
            else
            {
                _breadcrumbs = [(null, "Workspace")];
            }

            _notebook.IsDirty = false;
            Navigation.NavigateTo($"/w/{WorkspaceId}/notebook/{_workspaceNotebookId}", replace: true);
        }
        catch (Exception ex)
        {
            _error = $"Failed to save to workspace: {ex.Message}";
        }
    }

    private async Task ExportFileAsync()
    {
        try
        {
            _notebook.AttachedCatalogs = _selectedCatalogNames.ToList();
            var json = NotebookSerializer.Serialize(_notebook);
            var filename = (_notebook.Title.Trim().Length > 0 ? _notebook.Title.Trim() : "notebook") + ".ipynb";
            await JS.InvokeVoidAsync("downloadFile", filename, json);
        }
        catch (Exception ex)
        {
            _error = $"Failed to export: {ex.Message}";
        }
    }

