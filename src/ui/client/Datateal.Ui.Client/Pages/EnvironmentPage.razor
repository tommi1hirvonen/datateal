@page "/w/{WorkspaceId:guid}/environment"
@attribute [Authorize(Policy = AuthPolicy.EnvironmentManage)]

@using System.ComponentModel.DataAnnotations
@using Datateal.Ui.Client.Validation
@using Datateal.Ui.Shared.Environment
@using Datateal.Ui.Shared.RuntimePackages
@inject IEnvironmentService EnvironmentService
@inject IWheelPackageService WheelPackageService
@inject NavigationManager Navigation

<PageTitle>Environment — Datateal</PageTitle>

<Space>
    <SpaceItem>
        <Icon Height="24px" Width="24px" Type="@IconType.Outline.Tool" />
    </SpaceItem>
    <SpaceItem>
        <h2>Environment</h2>
    </SpaceItem>
</Space>

@if (!string.IsNullOrEmpty(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
            Style="margin-bottom: 16px;" />
}

<Tabs DefaultActiveKey="variables">
    <TabPane Key="variables" Tab="Variables">
        <Flex Justify="FlexJustify.FlexEnd" Style="margin-bottom: 12px;">
            <Button Type="@ButtonType.Primary" OnClick="StartCreateVariable">
                <Icon Type="@IconType.Outline.Plus" /> New variable
            </Button>
        </Flex>
        <Spin Spinning="_loadingVars">
            <Table TItem="EnvironmentVariableDto" DataSource="_variables" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                <PropertyColumn Property="v => v.Key" Title="Key" Sortable>
                    <span style="font-family: monospace;">@context.Key</span>
                </PropertyColumn>
                <PropertyColumn Property="v => v.Value" Title="Value">
                    <span style="font-family: monospace;">@context.Value</span>
                </PropertyColumn>
                <PropertyColumn Property="v => v.Description" Title="Description">
                    @(context.Description ?? "—")
                </PropertyColumn>
                <PropertyColumn Property="v => v.UpdatedAt" Title="Updated" Sortable>
                    @context.UpdatedAt.ToString("yyyy-MM-dd")
                </PropertyColumn>
                <ActionColumn Title="Actions">
                    <Space>
                        <SpaceItem>
                            <Tooltip Title="Edit">
                                <Button Size="@ButtonSize.Small" OnClick="() => StartEditVariable(context)">
                                    <Icon Type="@IconType.Outline.Edit" />
                                </Button>
                            </Tooltip>
                        </SpaceItem>
                        <SpaceItem>
                            <Tooltip Title="Delete">
                                <Popconfirm Title="@($"Delete variable '{context.Key}'?")"
                                            OnConfirm="() => DeleteVariableAsync(context)">
                                    <Button Danger Size="@ButtonSize.Small">
                                        <Icon Type="@IconType.Outline.Delete" />
                                    </Button>
                                </Popconfirm>
                            </Tooltip>
                        </SpaceItem>
                    </Space>
                </ActionColumn>
            </Table>
        </Spin>
    </TabPane>

    <TabPane Key="secrets" Tab="Secrets">
        <Flex Justify="FlexJustify.FlexEnd" Style="margin-bottom: 12px;">
            <Button Type="@ButtonType.Primary" OnClick="StartCreateSecret">
                <Icon Type="@IconType.Outline.Plus" /> New secret
            </Button>
        </Flex>
        <Spin Spinning="_loadingSecrets">
            <Table TItem="SecretDto" DataSource="_secrets" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                <PropertyColumn Property="s => s.Key" Title="Key" Sortable>
                    <span style="font-family: monospace;">@context.Key</span>
                </PropertyColumn>
                <PropertyColumn Property="s => s.Description" Title="Description">
                    @(context.Description ?? "—")
                </PropertyColumn>
                <PropertyColumn Property="s => s.UpdatedAt" Title="Updated" Sortable>
                    @context.UpdatedAt.ToString("yyyy-MM-dd")
                </PropertyColumn>
                <ActionColumn Title="Actions">
                    <Space>
                        <SpaceItem>
                            <Tooltip Title="Edit">
                                <Button Size="@ButtonSize.Small" OnClick="() => StartEditSecret(context)">
                                    <Icon Type="@IconType.Outline.Edit" />
                                </Button>
                            </Tooltip>
                        </SpaceItem>
                        <SpaceItem>
                            <Tooltip Title="Delete">
                                <Popconfirm Title="@($"Delete secret '{context.Key}'?")"
                                            OnConfirm="() => DeleteSecretAsync(context)">
                                    <Button Danger Size="@ButtonSize.Small">
                                        <Icon Type="@IconType.Outline.Delete" />
                                    </Button>
                                </Popconfirm>
                            </Tooltip>
                        </SpaceItem>
                    </Space>
                </ActionColumn>
            </Table>
        </Spin>
    </TabPane>

    <TabPane Key="packages" Tab="Packages">
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 12px;">
            <span></span>
            <Space>
                <SpaceItem>
                    <Button OnClick="LoadPackagesAsync"
                            Disabled="_loadingPackages"
                            Icon="@IconType.Outline.Reload">
                        Refresh
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Upload Action="@_uploadUrl"
                            Name="file"
                            Accept=".whl"
                            ShowUploadList="false"
                            BeforeUpload="ValidatePackageFile"
                            OnSingleCompleted="OnPackageUploadCompleted">
                        <Button Type="ButtonType.Primary"
                                Icon="@IconType.Outline.Upload"
                                Loading="_uploading">
                            Upload .whl
                        </Button>
                    </Upload>
                </SpaceItem>
            </Space>
        </Flex>
        @if (_packagesError is not null)
        {
            <Alert Type="AlertType.Error" Message="@_packagesError" Closable ShowIcon="true"
                   OnClose="@(() => _packagesError = null)" Style="margin-bottom: 16px;" />
        }
        @if (_loadingPackages)
        {
            <Flex Justify="@("center")" Style="padding: 40px 0;">
                <Spin />
            </Flex>
        }
        else if (_packages.Count == 0)
        {
            <p><Text Type="TextElementType.Secondary">No packages yet. Upload a .whl file to get started.</Text></p>
        }
        else
        {
            <Table TItem="WheelPackageDto" DataSource="@_packages" Bordered Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                <PropertyColumn Property="p => p.Name" Title="Name">
                    <span style="font-weight: 600;">@context.Name</span>
                </PropertyColumn>
                <PropertyColumn Property="p => p.FileName" Title="Filename">
                    <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@context.FileName</Text>
                </PropertyColumn>
                <PropertyColumn Property="p => p.Size" Title="Size">
                    <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@FormatPackageSize(context.Size)</Text>
                </PropertyColumn>
                <PropertyColumn Property="p => p.UploadedAt" Title="Uploaded">
                    <Text Type="TextElementType.Secondary" Style="font-size: 0.875rem;">@context.UploadedAt.ToString("yyyy-MM-dd HH:mm")</Text>
                </PropertyColumn>
                <ActionColumn Title="Actions">
                    <Popconfirm Title="@($"Delete package '{context.Name}'?")"
                                OkText="Delete"
                                CancelText="Cancel"
                                OkType="ButtonType.Primary"
                                OkButtonProps="new ButtonProps { Danger = true }"
                                OnConfirm="@(() => DeletePackageAsync(context.Id))">
                        <Button Size="ButtonSize.Small" Danger
                                Icon="@IconType.Outline.Delete">
                            Delete
                        </Button>
                    </Popconfirm>
                </ActionColumn>
            </Table>
        }
    </TabPane>
</Tabs>

@* Variable drawer *@
<Drawer Closable="true" @bind-Visible="_showVarModal" Placement="DrawerPlacement.Right"
        Width="480" Title="@(_editVarTarget is null ? "New variable" : "Edit variable")"
        OnClose="() => _showVarModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <Form Model="@_varForm" Layout="FormLayout.Vertical" ValidateOnChange="true">
            <FormItem Label="Key">
                <Input @bind-Value="context.Key" Placeholder="MY_VARIABLE"
                       BindOnInput
                       Class="@(VarKeyDisplayError is not null ? "ant-input-status-error" : "")"
                       OnPressEnter="@(async _ => await ConfirmSaveVariable())" />
                @if (VarKeyDisplayError is not null)
                {
                    <div class="ant-form-item-explain-error">@VarKeyDisplayError</div>
                }
            </FormItem>
            <FormItem Label="Value" Rules="@_requiredRule">
                <Input @bind-Value="context.Value" Placeholder="https://example.com"
                       BindOnInput
                       OnPressEnter="@(async _ => await ConfirmSaveVariable())" />
            </FormItem>
            <FormItem Label="Description">
                <TextArea @bind-Value="context.Description" Rows="2"
                          BindOnInput />
            </FormItem>
        </Form>
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showVarModal = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmSaveVariable"
                Disabled="@(GetVarKeyError() is not null || string.IsNullOrWhiteSpace(_varForm.Value))">Save</Button>
    </div>
</Drawer>

@* Secret drawer *@
<Drawer Closable="true" @bind-Visible="_showSecretModal" Placement="DrawerPlacement.Right"
        Width="480" Title="@(_editSecretTarget is null ? "New secret" : "Edit secret")"
        OnClose="() => _showSecretModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <Form Model="@_secretForm" Layout="FormLayout.Vertical" ValidateOnChange="true">
            <FormItem Label="Key">
                <Input @bind-Value="context.Key" Placeholder="API_TOKEN"
                       BindOnInput
                       Class="@(SecretKeyDisplayError is not null ? "ant-input-status-error" : "")"
                       OnPressEnter="@(async _ => await ConfirmSaveSecret())" />
                @if (SecretKeyDisplayError is not null)
                {
                    <div class="ant-form-item-explain-error">@SecretKeyDisplayError</div>
                }
            </FormItem>
            <FormItem Label="@(_editSecretTarget is not null ? "Value (leave blank to keep current)" : "Value")"
                      Rules="@(_editSecretTarget is null ? _requiredRule : Array.Empty<FormValidationRule>())">
                <InputPassword @bind-Value="context.Value"
                               Placeholder="@(_editSecretTarget is not null ? "••••••••" : "Enter secret value")"
                               BindOnInput
                               OnPressEnter="@(async _ => await ConfirmSaveSecret())" />
            </FormItem>
            <FormItem Label="Description">
                <TextArea @bind-Value="context.Description" Rows="2"
                          BindOnInput />
            </FormItem>
        </Form>
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showSecretModal = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmSaveSecret"
                Disabled="@(GetSecretKeyError() is not null || (_editSecretTarget is null && string.IsNullOrWhiteSpace(_secretForm.Value)))">Save</Button>
    </div>
</Drawer>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }
    private IReadOnlyList<EnvironmentVariableDto> _variables = [];
    private IReadOnlyList<SecretDto> _secrets = [];
    private bool _loadingVars = true;
    private bool _loadingSecrets = true;
    private string? _error;

    // Packages state
    private List<WheelPackageDto> _packages = [];
    private bool _loadingPackages = true;
    private bool _uploading;
    private string? _packagesError;

    private string _uploadUrl => Navigation.BaseUri + "api/packages";

    // Variable modal state
    private bool _showVarModal;
    private EnvironmentVariableDto? _editVarTarget;
    private VariableFormModel _varForm = new();
    private bool _varKeySubmitAttempted;

    private string? VarKeyDisplayError =>
        (_varKeySubmitAttempted || !string.IsNullOrEmpty(_varForm.Key)) ? GetVarKeyError() : null;

    private string? GetVarKeyError()
    {
        if (string.IsNullOrEmpty(_varForm.Key)) return "Key is required.";
        if (ValidationHelper.ValidateEnvVarKey(_varForm.Key) is { } formatError) return formatError;
        var trimmed = _varForm.Key.Trim();
        if (_variables.Any(v => v.Key.Equals(trimmed, StringComparison.OrdinalIgnoreCase)
                                && v != _editVarTarget))
            return "A variable with this key already exists.";
        return null;
    }

    // Secret modal state
    private bool _showSecretModal;
    private SecretDto? _editSecretTarget;
    private SecretFormModel _secretForm = new();
    private bool _secretKeySubmitAttempted;

    private string? SecretKeyDisplayError =>
        (_secretKeySubmitAttempted || !string.IsNullOrEmpty(_secretForm.Key)) ? GetSecretKeyError() : null;

    private string? GetSecretKeyError()
    {
        if (string.IsNullOrEmpty(_secretForm.Key)) return "Key is required.";
        if (ValidationHelper.ValidateEnvVarKey(_secretForm.Key) is { } formatError) return formatError;
        var trimmed = _secretForm.Key.Trim();
        if (_secrets.Any(s => s.Key.Equals(trimmed, StringComparison.OrdinalIgnoreCase)
                              && s != _editSecretTarget))
            return "A secret with this key already exists.";
        return null;
    }

    private static readonly FormValidationRule[] _requiredRule =
    [
        new() { Required = true, Message = "This field is required." }
    ];

    private static readonly FormValidationRule[] _varKeyRules =
    [
        new() { Required = true, Message = "Key is required." },
        new() { Validator = ctx =>
            ValidationHelper.ValidateEnvVarKey(ctx.Value?.ToString()) is { } err
                ? new ValidationResult(err, [ctx.FieldName]) : null }
    ];

    private static readonly FormValidationRule[] _secretKeyRules =
    [
        new() { Required = true, Message = "Key is required." },
        new() { Validator = ctx =>
            ValidationHelper.ValidateEnvVarKey(ctx.Value?.ToString()) is { } err
                ? new ValidationResult(err, [ctx.FieldName]) : null }
    ];

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadVariablesAsync(), LoadSecretsAsync(), LoadPackagesAsync());
    }

    private async Task LoadVariablesAsync()
    {
        _loadingVars = true;
        try { _variables = await EnvironmentService.GetVariablesAsync(); }
        catch (Exception ex) { _error = $"Failed to load variables: {ex.Message}"; }
        finally { _loadingVars = false; }
    }

    private async Task LoadSecretsAsync()
    {
        _loadingSecrets = true;
        try { _secrets = await EnvironmentService.GetSecretsAsync(); }
        catch (Exception ex) { _error = $"Failed to load secrets: {ex.Message}"; }
        finally { _loadingSecrets = false; }
    }

    // ── Variable CRUD ───────────────────────────────────────────────────

    private void StartCreateVariable()
    {
        _editVarTarget = null;
        _varForm = new VariableFormModel();
        _varKeySubmitAttempted = false;
        _showVarModal = true;
    }

    private void StartEditVariable(EnvironmentVariableDto variable)
    {
        _editVarTarget = variable;
        _varKeySubmitAttempted = false;
        _varForm = new VariableFormModel { Key = variable.Key, Value = variable.Value, Description = variable.Description };
        _showVarModal = true;
    }

    private async Task ConfirmSaveVariable()
    {
        _varKeySubmitAttempted = true;
        if (GetVarKeyError() is not null) return;
        if (string.IsNullOrWhiteSpace(_varForm.Value)) return;

        try
        {
            if (_editVarTarget is null)
            {
                await EnvironmentService.CreateVariableAsync(new CreateEnvironmentVariableRequest(
                    _varForm.Key.Trim(), _varForm.Value.Trim(), _varForm.Description?.Trim()));
            }
            else
            {
                await EnvironmentService.UpdateVariableAsync(_editVarTarget.Id, new UpdateEnvironmentVariableRequest(
                    _varForm.Key.Trim(), _varForm.Value.Trim(), _varForm.Description?.Trim()));
            }
            _showVarModal = false;
            await LoadVariablesAsync();
        }
        catch (Exception ex) { _error = $"Failed to save variable: {ex.Message}"; }
    }

    private async Task DeleteVariableAsync(EnvironmentVariableDto variable)
    {
        try
        {
            await EnvironmentService.DeleteVariableAsync(variable.Id);
            await LoadVariablesAsync();
        }
        catch (Exception ex) { _error = $"Failed to delete variable: {ex.Message}"; }
    }

    // ── Secret CRUD ─────────────────────────────────────────────────────

    private void StartCreateSecret()
    {
        _editSecretTarget = null;
        _secretForm = new SecretFormModel();
        _secretKeySubmitAttempted = false;
        _showSecretModal = true;
    }

    private void StartEditSecret(SecretDto secret)
    {
        _editSecretTarget = secret;
        _secretKeySubmitAttempted = false;
        _secretForm = new SecretFormModel { Key = secret.Key, Description = secret.Description };
        _showSecretModal = true;
    }

    private async Task ConfirmSaveSecret()
    {
        _secretKeySubmitAttempted = true;
        if (GetSecretKeyError() is not null) return;
        if (_editSecretTarget is null && string.IsNullOrWhiteSpace(_secretForm.Value)) return;

        try
        {
            if (_editSecretTarget is null)
            {
                await EnvironmentService.CreateSecretAsync(new CreateSecretRequest(
                    _secretForm.Key.Trim(), _secretForm.Value, _secretForm.Description?.Trim()));
            }
            else
            {
                await EnvironmentService.UpdateSecretAsync(_editSecretTarget.Id, new UpdateSecretRequest(
                    _secretForm.Key.Trim(),
                    string.IsNullOrWhiteSpace(_secretForm.Value) ? null : _secretForm.Value,
                    _secretForm.Description?.Trim()));
            }
            _showSecretModal = false;
            await LoadSecretsAsync();
        }
        catch (Exception ex) { _error = $"Failed to save secret: {ex.Message}"; }
    }

    private async Task DeleteSecretAsync(SecretDto secret)
    {
        try
        {
            await EnvironmentService.DeleteSecretAsync(secret.Id);
            await LoadSecretsAsync();
        }
        catch (Exception ex) { _error = $"Failed to delete secret: {ex.Message}"; }
    }

    // ── Packages ─────────────────────────────────────────────────────────

    private async Task LoadPackagesAsync()
    {
        _loadingPackages = true;
        _packagesError = null;
        try
        {
            _packages = [.. await WheelPackageService.GetPackagesAsync()];
        }
        catch (Exception ex)
        {
            _packagesError = $"Failed to load packages: {ex.Message}";
        }
        finally
        {
            _loadingPackages = false;
        }
    }

    private bool ValidatePackageFile(UploadFileItem file)
    {
        _packagesError = null;
        if (!file.FileName.EndsWith(".whl", StringComparison.OrdinalIgnoreCase))
        {
            _packagesError = "Only .whl files are accepted.";
            StateHasChanged();
            return false;
        }
        if (file.Size > 5 * 1024 * 1024)
        {
            _packagesError = "File exceeds the 5 MB limit.";
            StateHasChanged();
            return false;
        }
        _uploading = true;
        StateHasChanged();
        return true;
    }

    private async Task OnPackageUploadCompleted(UploadInfo info)
    {
        _uploading = false;
        if (info.File.State == UploadState.Success)
        {
            await LoadPackagesAsync();
        }
        else
        {
            _packagesError = string.IsNullOrWhiteSpace(info.File.Response)
                ? "Upload failed."
                : info.File.Response;
        }
    }

    private async Task DeletePackageAsync(Guid id)
    {
        _packagesError = null;
        try
        {
            await WheelPackageService.DeletePackageAsync(id);
            _packages.RemoveAll(p => p.Id == id);
        }
        catch (Exception ex)
        {
            _packagesError = $"Delete failed: {ex.Message}";
        }
    }

    private static string FormatPackageSize(long bytes) =>
        bytes switch
        {
            (< 1024) => $"{bytes} B",
            (< 1024 * 1024) => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / 1024.0 / 1024.0:F1} MB"
        };
}
