@page "/w/{WorkspaceId:guid}/jobs"
@attribute [Authorize(Policy = AuthPolicy.JobRead)]

@using Datateal.Ui.Shared.Orchestration
@inject IJobService JobService
@inject IRecentItemsService RecentItemsService
@inject NavigationManager Navigation

<PageTitle>Jobs — Datateal</PageTitle>

<Space Align="SpaceAlign.Center" Size="SpaceSize.Small" Style="margin-bottom: 16px;">
    <SpaceItem>
        <Icon Height="24px" Width="24px" Type="@IconType.Outline.Partition" />
    </SpaceItem>
    <SpaceItem>
        <h2 style="margin: 0;">Jobs</h2>
    </SpaceItem>
</Space>

@if (!string.IsNullOrEmpty(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
           Style="margin-bottom: 16px;" />
}

<Tabs ActiveKey="@_activeTab" OnChange="OnTabChange">
    <TabPane Key="jobs" Tab="Jobs">
        <Flex Justify="FlexJustify.End" Style="margin-bottom: 12px;">
            <Space Size="SpaceSize.Small">
                <AuthorizeView Policy="@AuthPolicy.JobManage">
                    <SpaceItem>
                        <Button Type="@ButtonType.Primary" OnClick="StartCreate">
                            <Icon Type="@IconType.Outline.Plus" /> New job
                        </Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button OnClick="StartImport">
                            <Icon Type="@IconType.Outline.Upload" /> Import
                        </Button>
                    </SpaceItem>
                </AuthorizeView>
            </Space>
        </Flex>
        <Spin Spinning="_loading">
            <Table TItem="JobSummary" DataSource="_jobs" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
                <PropertyColumn Property="c => c.Name" Title="Name" Sortable>
                    <a href="@($"/w/{WorkspaceId}/jobs/{context.Id}")">@context.Name</a>
                </PropertyColumn>
                <PropertyColumn Property="c => c.Description" Title="Description" />
                <PropertyColumn Property="c => c.IsEnabled" Title="Enabled">
                    @if (context.IsEnabled)
                    {
                        <Tag Color="@("green")">Enabled</Tag>
                    }
                    else
                    {
                        <Tag>Disabled</Tag>
                    }
                </PropertyColumn>
                <PropertyColumn Property="c => c.TaskCount" Title="Tasks" />
                <PropertyColumn Property="c => c.ScheduleCount" Title="Schedules" />
                <PropertyColumn Property="c => c.UpdatedAt" Title="Updated" Sortable>
                    @FormatDate(context.UpdatedAt)
                </PropertyColumn>
                <ActionColumn Title="Actions">
                    <Space>
                        <SpaceItem>
                            <Tooltip Title="Edit">
                                <Button Size="@ButtonSize.Small" OnClick="@(() => Navigation.NavigateTo($"/w/{WorkspaceId}/jobs/{context.Id}"))">
                                    <Icon Type="@IconType.Outline.Edit" />
                                </Button>
                            </Tooltip>
                        </SpaceItem>
                        <SpaceItem>
                            <Tooltip Title="Export YAML">
                                <Button Size="@ButtonSize.Small" OnClick="@(() => ExportAsync(context))">
                                    <Icon Type="@IconType.Outline.Download" />
                                </Button>
                            </Tooltip>
                        </SpaceItem>
                        <SpaceItem>
                            <AuthorizeView Policy="@AuthPolicy.JobOperate" Context="auth">
                                <Tooltip Title="Run">
                                    <Button Size="@ButtonSize.Small" Type="@ButtonType.Primary"
                                            OnClick="@(() => OpenTriggerModal(context.Id))">
                                        <Icon Type="@IconType.Outline.PlayCircle" />
                                    </Button>
                                </Tooltip>
                            </AuthorizeView>
                        </SpaceItem>
                        <SpaceItem>
                            <AuthorizeView Policy="@AuthPolicy.JobManage" Context="auth">
                                <Tooltip Title="Delete">
                                    <Popconfirm Title="@($"Delete job '{context.Name}'?")" OnConfirm="() => DeleteAsync(context)">
                                        <Button Danger Size="@ButtonSize.Small">
                                            <Icon Type="@IconType.Outline.Delete" />
                                        </Button>
                                    </Popconfirm>
                                </Tooltip>
                            </AuthorizeView>
                        </SpaceItem>
                    </Space>
                </ActionColumn>
            </Table>
        </Spin>
    </TabPane>

    <TabPane Key="runs" Tab="Runs">
        <div style="margin-top: 8px;">
            <Flex Wrap="@("flex-wrap")" Gap="@("8px")" Style="margin-bottom: 12px;" Align="FlexAlign.End">
                <div>
                    <div style="font-size: 12px; margin-bottom: 4px; font-weight: 500;">Job name</div>
                    <Input @bind-Value="_filterJobName" Placeholder="Filter by job name" Style="width: 200px;"
                           OnPressEnter="@(_ => SearchRunsAsync())" AllowClear />
                </div>
                <div>
                    <div style="font-size: 12px; margin-bottom: 4px; font-weight: 500;">Status</div>
                    <Select TItem="Nullable<JobRunStatus>" TItemValue="Nullable<JobRunStatus>" @bind-Value="_filterStatus"
                            Style="width: 140px;" AllowClear Placeholder="Any status">
                        <SelectOption Value="@((JobRunStatus?)JobRunStatus.Pending)">Pending</SelectOption>
                        <SelectOption Value="@((JobRunStatus?)JobRunStatus.Running)">Running</SelectOption>
                        <SelectOption Value="@((JobRunStatus?)JobRunStatus.Succeeded)">Succeeded</SelectOption>
                        <SelectOption Value="@((JobRunStatus?)JobRunStatus.Failed)">Failed</SelectOption>
                        <SelectOption Value="@((JobRunStatus?)JobRunStatus.Cancelled)">Cancelled</SelectOption>
                    </Select>
                </div>
                <div>
                    <div style="font-size: 12px; margin-bottom: 4px; font-weight: 500;">From</div>
                    <DatePicker TValue="Nullable<DateTime>" @bind-Value="_filterFrom" ShowTime="@true" Placeholder="@("Start time")" Style="width: 190px;" />
                </div>
                <div>
                    <div style="font-size: 12px; margin-bottom: 4px; font-weight: 500;">To</div>
                    <DatePicker TValue="Nullable<DateTime>" @bind-Value="_filterTo" ShowTime="@true" Placeholder="@("End time")" Style="width: 190px;" />
                </div>
                <Button Type="@ButtonType.Primary" OnClick="SearchRunsAsync">
                    <Icon Type="@IconType.Outline.Search" /> Search
                </Button>
            </Flex>

            <Spin Spinning="_runsLoading">
                @if (_allRunsLoaded)
                {
                    <div style="margin-bottom: 8px; color: #999; font-size: 12px;">
                        Showing up to 100 results, newest first.
                    </div>
                }
                <Table TItem="JobRunSummary" DataSource="_allRuns" Size="@TableSize.Small"
                       PageSize="int.MaxValue" PaginationPosition="none" EnableVirtualization>
                    <PropertyColumn Property="c => c.JobName" Title="Job" Sortable>
                        @if (context.JobId.HasValue)
                        {
                            <a href="@($"/w/{WorkspaceId}/jobs/{context.JobId}")">@context.JobName</a>
                        }
                        else
                        {
                            <span>@context.JobName</span>
                        }
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.Status" Title="Status">
                        <a href="@($"/w/{WorkspaceId}/runs/{context.Id}")">
                            <Tag Color="@GetStatusColor(context.Status)">@context.Status</Tag>
                        </a>
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.Trigger" Title="Trigger" />
                    <PropertyColumn Property="c => c.Parameters" Title="Parameters">
                        @if (context.Parameters is { Count: > 0 })
                        {
                            <Popover ContentTemplate="@ParametersContent(context.Parameters)" Trigger="@(new AntDesign.Trigger[] { AntDesign.Trigger.Click })">
                                <Tag Style="cursor:pointer;">@context.Parameters.Count param(s)</Tag>
                            </Popover>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.CreatedAt" Title="Created" Sortable>
                        @context.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.CompletedAt" Title="Completed" Sortable>
                        @(context.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.StartedAt" Title="Duration">
                        @if (context.StartedAt.HasValue && context.CompletedAt.HasValue)
                        {
                            @FormatDuration((context.CompletedAt.Value - context.StartedAt.Value).TotalMilliseconds)
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </PropertyColumn>
                    <ActionColumn Title="">
                        <Button Size="@ButtonSize.Small"
                                OnClick="@(() => Navigation.NavigateTo($"/w/{WorkspaceId}/runs/{context.Id}"))">
                            <Icon Type="@IconType.Outline.ArrowRight" /> View
                        </Button>
                    </ActionColumn>
                </Table>
            </Spin>
        </div>
    </TabPane>
</Tabs>

<Drawer Closable="true" @bind-Visible="_showCreateModal" Placement="DrawerPlacement.Right"
        Width="480" Title="@("New job")"
        OnClose="() => _showCreateModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <Form Model="@_createForm" Layout="FormLayout.Vertical">
            <FormItem Label="Name">
                <Input @bind-Value="context.Name" Placeholder="My Job"
                       BindOnInput
                       Class="@(JobNameDisplayError is not null ? "ant-input-status-error" : "")"
                       OnPressEnter="@(_ => ConfirmCreate())" />
                @if (JobNameDisplayError is not null)
                {
                    <div class="ant-form-item-explain-error">@JobNameDisplayError</div>
                }
            </FormItem>
            <FormItem Label="Description">
                <TextArea @bind-Value="context.Description" Placeholder="Optional description" Rows="3"
                          BindOnInput />
            </FormItem>
        </Form>
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showCreateModal = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmCreate"
                Disabled="@(GetJobNameError() is not null)">Create</Button>
    </div>
</Drawer>

<Drawer Closable="true" @bind-Visible="_showImportModal" Placement="DrawerPlacement.Right"
        Width="560" Title="@("Import job from YAML")"
        OnClose="() => _showImportModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px;">
        <label style="display: block; margin-bottom: 4px; font-weight: 500;">YAML Definition</label>
        <TextArea @bind-Value="_importYaml" Placeholder="Paste YAML here..." Rows="20"
                  Style="font-family: monospace; font-size: 13px;"
                  BindOnInput />
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showImportModal = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmImport" Disabled="@(string.IsNullOrWhiteSpace(_importYaml))">Import</Button>
    </div>
</Drawer>

<Drawer Closable="true" @bind-Visible="_showExportModal" Placement="DrawerPlacement.Right"
        Width="560" Title="@("Export YAML")"
        OnClose="() => _showExportModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px;">
        <pre style="font-size: 13px; white-space: pre-wrap; margin: 0;">@_exportYaml</pre>
    </div>
</Drawer>

<TriggerJobModal @bind-Visible="_showTriggerModal"
                 JobId="_triggerJobId"
                 OnConfirm="TriggerConfirmedAsync" />

@code {
    [Parameter] public Guid WorkspaceId { get; set; }
    private IReadOnlyList<JobSummary> _jobs = [];
    private bool _loading = true;
    private string? _error;
    private string _activeTab = "jobs";

    private bool _showCreateModal;
    private CreateJobFormModel _createForm = new();
    private bool _jobNameSubmitAttempted;

    private string? JobNameDisplayError =>
        (_jobNameSubmitAttempted || !string.IsNullOrEmpty(_createForm.Name)) ? GetJobNameError() : null;

    private string? GetJobNameError()
    {
        if (string.IsNullOrEmpty(_createForm.Name)) return "Name is required.";
        var trimmed = _createForm.Name.Trim();
        if (_jobs.Any(j => j.Name.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
            return "A job with this name already exists.";
        return null;
    }

    // Import modal state
    private bool _showImportModal;
    private string _importYaml = "";

    // Export modal state
    private bool _showExportModal;
    private string _exportYaml = "";

    // Trigger modal state
    private bool _showTriggerModal;
    private Guid? _triggerJobId;

    // Runs tab state
    private IReadOnlyList<JobRunSummary> _allRuns = [];
    private bool _runsLoading;
    private bool _allRunsLoaded;
    private string? _filterJobName;
    private JobRunStatus? _filterStatus;
    private DateTime? _filterFrom;
    private DateTime? _filterTo;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task OnTabChange(string key)
    {
        _activeTab = key;
        if (key == "runs" && !_allRunsLoaded)
            await SearchRunsAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _jobs = await JobService.GetJobsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load jobs: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchRunsAsync()
    {
        _runsLoading = true;
        _error = null;
        try
        {
            // Truncate to minute precision
            var from = _filterFrom.HasValue
                ? new DateTime(_filterFrom.Value.Year, _filterFrom.Value.Month, _filterFrom.Value.Day,
                    _filterFrom.Value.Hour, _filterFrom.Value.Minute, 0, DateTimeKind.Utc)
                : (DateTime?)null;
            var to = _filterTo.HasValue
                ? new DateTime(_filterTo.Value.Year, _filterTo.Value.Month, _filterTo.Value.Day,
                    _filterTo.Value.Hour, _filterTo.Value.Minute, 59, DateTimeKind.Utc)
                : (DateTime?)null;

            _allRuns = await JobService.GetAllRunsAsync(_filterJobName, _filterStatus, from, to);
            _allRunsLoaded = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load runs: {ex.Message}";
        }
        finally
        {
            _runsLoading = false;
        }
    }

    private void StartCreate()
    {
        _createForm = new CreateJobFormModel();
        _jobNameSubmitAttempted = false;
        _showCreateModal = true;
    }

    private void StartImport()
    {
        _importYaml = "";
        _showImportModal = true;
    }

    private async Task ConfirmImport()
    {
        if (string.IsNullOrWhiteSpace(_importYaml)) return;
        try
        {
            var job = await JobService.ImportJobAsync(_importYaml);
            _showImportModal = false;
            Navigation.NavigateTo($"/w/{WorkspaceId}/jobs/{job.Id}");
        }
        catch (Exception ex)
        {
            _error = $"Failed to import job: {ex.Message}";
        }
    }

    private async Task ExportAsync(JobSummary job)
    {
        try
        {
            _exportYaml = await JobService.ExportJobAsync(job.Id);
            _showExportModal = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to export '{job.Name}': {ex.Message}";
        }
    }

    private async Task ConfirmCreate()
    {
        _jobNameSubmitAttempted = true;
        if (GetJobNameError() is not null) return;
        try
        {
            var job = await JobService.CreateJobAsync(
                new CreateJobRequest(_createForm.Name.Trim(), _createForm.Description?.Trim(), null, 1));
            _showCreateModal = false;
            Navigation.NavigateTo($"/w/{WorkspaceId}/jobs/{job.Id}");
        }
        catch (Exception ex)
        {
            _error = $"Failed to create job: {ex.Message}";
        }
    }

    private void OpenTriggerModal(Guid jobId)
    {
        _triggerJobId = jobId;
        _showTriggerModal = true;
    }

    private async Task TriggerConfirmedAsync(Dictionary<string, string>? parameters)
    {
        if (_triggerJobId is null) return;
        try
        {
            var request = parameters?.Count > 0 ? new TriggerJobRequest(parameters) : null;
            await JobService.TriggerJobAsync(_triggerJobId.Value, request);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to trigger job: {ex.Message}";
        }
    }

    private async Task DeleteAsync(JobSummary job)
    {
        try
        {
            await JobService.DeleteJobAsync(job.Id);
            _ = RecentItemsService.RemoveAsync(job.Id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete '{job.Name}': {ex.Message}";
        }
    }

    private static string GetStatusColor(JobRunStatus status) => status switch
    {
        JobRunStatus.Succeeded => "green",
        JobRunStatus.Failed => "red",
        JobRunStatus.Running => "blue",
        JobRunStatus.Cancelled => "orange",
        _ => "default",
    };

    private static RenderFragment ParametersContent(Dictionary<string, string> parameters) =>
        @<div style="font-family: monospace; font-size: 12px; min-width: 160px;">
            @foreach (var kv in parameters)
            {
                <div><strong>@kv.Key</strong> = @kv.Value</div>
            }
        </div>;

    private static string FormatDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("yyyy-MM-dd");
    }

    private static string FormatDuration(double ms)
    {
        double s = ms / 1000.0;
        if (s < 10.0) return $"{s:F1}s";
        int total = (int)s;
        if (total < 60) return $"{total}s";
        return $"{total / 60}m {total % 60}s";
    }
}
