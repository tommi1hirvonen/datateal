@using Datateal.Ui.Client.Models
@using Datateal.Ui.Client.Validation

<Drawer Closable="true" Visible="Visible" Placement="DrawerPlacement.Right"
        Width="480" Title="@(_isEdit ? "Edit parameter" : "Add parameter")"
        OnClose="HandleCancel"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <Form Model="@_form" Layout="FormLayout.Vertical">
            <FormItem Label="Name">
                <Input @bind-Value="context.Name" Placeholder="parameter_name"
                       BindOnInput
                       Class="@(NameDisplayError is not null ? "ant-input-status-error" : "")"
                       OnPressEnter="@(async _ => await HandleSave())" />
                @if (NameDisplayError is not null)
                {
                    <div class="ant-form-item-explain-error">@NameDisplayError</div>
                }
            </FormItem>
            <FormItem Label="Default value">
                <Input @bind-Value="context.DefaultValue" Placeholder="Optional default value"
                       BindOnInput
                       OnPressEnter="@(async _ => await HandleSave())" />
            </FormItem>
            <FormItem Label="Required">
                <Switch @bind-Checked="context.IsRequired" />
            </FormItem>
            <FormItem Label="Description">
                <TextArea @bind-Value="context.Description" Rows="3" Placeholder="Optional description"
                          BindOnInput />
            </FormItem>
        </Form>
    </div>
    <div class="drawer-footer">
        <Button OnClick="HandleCancel">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="HandleSave"
                Disabled="@(NameDisplayError is not null)">Save</Button>
    </div>
</Drawer>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EditableParameter? Parameter { get; set; }
    [Parameter] public EventCallback<EditableParameter> OnSave { get; set; }
    [Parameter] public IReadOnlyList<EditableParameter> ExistingParameters { get; set; } = [];

    private ParameterFormModel _form = new();
    private bool _isEdit;
    private bool _prevVisible;
    private bool _nameSubmitAttempted;

    private string? NameDisplayError =>
        (_nameSubmitAttempted || !string.IsNullOrEmpty(_form.Name)) ? GetNameError() : null;

    private string? GetNameError()
    {
        if (string.IsNullOrEmpty(_form.Name)) return "Name is required.";
        if (ValidationHelper.ValidatePythonIdentifier(_form.Name) is { } err) return err;
        var isDuplicate = ExistingParameters
            .Where(p => p != Parameter)
            .Any(p => string.Equals(p.Name, _form.Name.Trim(), StringComparison.Ordinal));
        if (isDuplicate) return "A parameter with this name already exists.";
        return null;
    }

    protected override void OnParametersSet()
    {
        if (Visible && !_prevVisible)
        {
            _nameSubmitAttempted = false;
            if (Parameter is not null)
            {
                _isEdit = true;
                _form = new ParameterFormModel
                {
                    Name = Parameter.Name,
                    DefaultValue = Parameter.DefaultValue,
                    IsRequired = Parameter.IsRequired,
                    Description = Parameter.Description,
                };
            }
            else
            {
                _isEdit = false;
                _form = new ParameterFormModel();
            }
        }
        _prevVisible = Visible;
    }

    private async Task HandleSave()
    {
        _nameSubmitAttempted = true;
        if (GetNameError() is not null) return;
        var result = new EditableParameter
        {
            Name = _form.Name.Trim(),
            DefaultValue = _form.DefaultValue,
            IsRequired = _form.IsRequired,
            Description = _form.Description
        };
        await OnSave.InvokeAsync(result);
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCancel()
    {
        await VisibleChanged.InvokeAsync(false);
    }
}
