@using Datateal.Ui.Shared.Orchestration
@inject IJobService JobService

<Drawer Closable="true" Visible="Visible" Placement="DrawerPlacement.Right"
        Width="480" Title="@(_job?.Parameters.Count > 0 ? "Trigger job — parameters" : "Trigger job")"
        OnClose="HandleCancel"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px;">
        <Spin Spinning="_loading">
            @if (_job is not null)
            {
                @if (_job.Parameters.Count == 0)
                {
                    <p>Trigger job <strong>@_job.Name</strong> now?</p>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        @foreach (var param in _job.Parameters)
                        {
                            <div>
                                <label style="display: block; margin-bottom: 4px; font-weight: 500;">
                                    @param.Name
                                    @if (param.IsRequired)
                                    {
                                        <span style="color: #ff4d4f; margin-left: 4px;">*</span>
                                    }
                                    else
                                    {
                                        <span style="color: #999; font-weight: 400; margin-left: 4px;">(optional)</span>
                                    }
                                </label>
                                @if (!string.IsNullOrEmpty(param.Description))
                                {
                                    <div style="font-size: 12px; color: #888; margin-bottom: 4px;">@param.Description</div>
                                }
                                <Input @bind-Value="_paramValues[param.Name]"
                                       Placeholder="@(param.DefaultValue ?? "")"
                                       BindOnInput
                                       OnPressEnter="@(_ => HandleConfirm())" />
                            </div>
                        }
                    </div>
                }
            }
        </Spin>
    </div>
    <div class="drawer-footer">
        <Button OnClick="HandleCancel">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="HandleConfirm"
                Disabled="@(!CanConfirm())" Loading="@_loading">Run now</Button>
    </div>
</Drawer>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public Guid? JobId { get; set; }
    [Parameter] public EventCallback<Dictionary<string, string>?> OnConfirm { get; set; }

    private JobDetail? _job;
    private bool _loading;
    private Guid? _loadedJobId;
    private Dictionary<string, string> _paramValues = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && JobId.HasValue && JobId != _loadedJobId)
        {
            _loading = true;
            _job = null;
            StateHasChanged();
            try
            {
                _job = await JobService.GetJobAsync(JobId.Value);
                _loadedJobId = JobId;
                _paramValues = new Dictionary<string, string>();
                if (_job is not null)
                {
                    foreach (var param in _job.Parameters)
                        _paramValues[param.Name] = param.DefaultValue ?? "";
                }
            }
            finally
            {
                _loading = false;
            }
        }
        else if (!Visible)
        {
            _loadedJobId = null;
        }
    }

    private bool CanConfirm()
    {
        if (_loading || _job is null) return false;
        return _job.Parameters
            .Where(p => p.IsRequired)
            .All(p => _paramValues.TryGetValue(p.Name, out var v) && !string.IsNullOrWhiteSpace(v));
    }

    private async Task HandleConfirm()
    {
        Dictionary<string, string>? parameters = null;
        if (_job?.Parameters.Count > 0)
        {
            parameters = _paramValues
                .Where(kv => !string.IsNullOrEmpty(kv.Value))
                .ToDictionary(kv => kv.Key, kv => kv.Value);
            if (parameters.Count == 0) parameters = null;
        }
        await OnConfirm.InvokeAsync(parameters);
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCancel()
    {
        await VisibleChanged.InvokeAsync(false);
    }
}
