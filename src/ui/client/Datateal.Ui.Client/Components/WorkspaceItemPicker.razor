@using Datateal.Ui.Shared.Workspace
@using Datateal.Core.Workspace
@inject IWorkspaceService WorkspaceService

<Select TItem="WorkspaceItem"
        TItemValue="Guid?"
        DataSource="_items"
        Value="SelectedId"
        ValueChanged="OnValueChanged"
        LabelName="@nameof(WorkspaceItem.Path)"
        ValueName="@nameof(WorkspaceItem.Id)"
        Placeholder="@(Placeholder ?? $"Select {ItemType}")"
        EnableSearch
        AllowClear
        Loading="_loading"
        Style="width: 100%;">
</Select>

@code {
    [Parameter] public string ItemType { get; set; } = "Notebook";
    [Parameter] public Guid? SelectedId { get; set; }
    [Parameter] public EventCallback<Guid?> SelectedIdChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }

    private List<WorkspaceItem> _items = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadItemsRecursive(null, "");
            _items.Sort((a, b) => NaturalSortComparer.OrdinalIgnoreCase.Compare(a.Path, b.Path));
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadItemsRecursive(Guid? folderId, string parentPath)
    {
        var listing = folderId.HasValue
            ? await WorkspaceService.GetFolderAsync(folderId.Value)
            : await WorkspaceService.GetRootAsync();

        if (ItemType == "Notebook")
        {
            foreach (var item in listing.Items.Where(i => i.ItemType == WorkspaceItemType.Notebook))
                _items.Add(new WorkspaceItem(item.Id, $"{parentPath}/{item.Title}"));
        }
        else if (ItemType == "Query")
        {
            foreach (var item in listing.Items.Where(i => i.ItemType == WorkspaceItemType.Query))
                _items.Add(new WorkspaceItem(item.Id, $"{parentPath}/{item.Title}"));
        }

        foreach (var folder in listing.Folders)
        {
            await LoadItemsRecursive(folder.Id, $"{parentPath}/{folder.Name}");
        }
    }

    private async Task OnValueChanged(Guid? value)
    {
        SelectedId = value;
        await SelectedIdChanged.InvokeAsync(value);
    }

    private record WorkspaceItem(Guid Id, string Path);
}
