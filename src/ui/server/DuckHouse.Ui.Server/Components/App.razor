<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link id="ant-theme-css" rel="stylesheet" href="_content/AntDesign/css/ant-design-blazor.css" />
    <link rel="stylesheet" href="@Assets["DuckHouse.Ui.Server.styles.css"]"/>
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["_content/DuckHouse.Ui.Components/defaults.css"]" />
    <ImportMap/>
    <HeadOutlet @rendermode="_renderMode"/>
    <script>
        // Apply stored theme immediately to prevent flash of unstyled content.
        (function () {
            var stored = localStorage.getItem('duckhouse-theme') || 'auto';
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            var effective = stored === 'dark' ? 'dark' : stored === 'light' ? 'light' : (prefersDark ? 'dark' : 'light');
            if (effective === 'dark') {
                var link = document.getElementById('ant-theme-css');
                if (link) link.href = '_content/AntDesign/css/ant-design-blazor.dark.css';
                document.documentElement.classList.add('ant-dark');
            }
        })();
    </script>
</head>

<body>
    <Routes @rendermode="_renderMode"/>
    <script src="_content/AntDesign/js/ant-design-blazor.js"></script>
    <script src="_content/BlazorMonaco/jsInterop.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/loader.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/editor/editor.main.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="js/app.js"></script>
</body>

</html>

@code {
    private readonly IComponentRenderMode _renderMode = new InteractiveWebAssemblyRenderMode(prerender: false);
}